# Normalize text files to LF in repo and checkout
* text=auto eol=lf

# Source and build scripts (force LF)
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
*.tpp text eol=lf
*.s text eol=lf
*.S text eol=lf
*.ld text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
CMakePresets.json text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.bat text eol=lf
*.lua text eol=lf

# Docs
*.md text eol=lf
*.txt text eol=lf

# Extensionless public headers in include/gba
include/gba/* text eol=lf

# Binary assets and outputs
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tga binary
*.wav binary
*.bin binary
*.gbfs binary
*.gba binary
*.elf binary
*.sav binary
*.bak binary
*.o binary
*.a binary
*.dll binary
*.exe binary
