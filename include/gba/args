/// @file gba/args
/// @brief Named argument binder helpers.
///
/// This header provides the generic `"name"_arg` literal used to bind named
/// arguments across APIs (formatting, codegen, and future subsystems).
///
/// @code{.cpp}
/// #include <gba/args>
/// using namespace gba::literals;
///
/// auto hp = "hp"_arg = 42;
/// @endcode
#pragma once

#include <gba/bits/format/fixed_string.hpp>

#include <tuple>
#include <type_traits>
#include <utility>

namespace gba {

	template<typename... BoundArgs>
	struct arg_pack {
		std::tuple<BoundArgs...> args;

		constexpr arg_pack(BoundArgs... a) : args{std::move(a)...} {}
	};

	template<>
	struct arg_pack<> {
		std::tuple<> args;

		constexpr arg_pack() = default;
	};

	template<unsigned int Hash, typename T>
	struct bound_arg {
		static constexpr unsigned int hash = Hash;
		static constexpr bool is_supplier = std::invocable<T>;
		T stored;

		constexpr decltype(auto) get() const {
			if constexpr (is_supplier) return stored();
			else return stored;
		}
	};

	using format::fixed_string;

	template<fixed_string Name>
	struct arg_binder {
		static constexpr auto hash = format::fnv1a_hash<Name>();

		template<typename T>
		constexpr auto operator()(T&& v) const {
			return bound_arg<hash, std::decay_t<T>>{std::forward<T>(v)};
		}

		template<typename T>
		constexpr auto operator=(T&& v) const {
			return bound_arg<hash, std::decay_t<T>>{std::forward<T>(v)};
		}
	};

} // namespace gba

namespace gba::literals {
	/// @brief Create a named argument binder.
	///
	/// The returned type is `gba::arg_binder<Name>`, which can be bound
	/// to a value via `operator=` or `operator()`, producing a `bound_arg`.
	template<fixed_string Name>
	consteval auto operator""_arg() {
		return arg_binder<Name>{};
	}
} // namespace gba::literals
