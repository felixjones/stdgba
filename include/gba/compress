/// @file compress
/// @brief Compile-time compression utilities for GBA BIOS decompression.
///
/// This header provides consteval compression functions that compress data at
/// compile time, producing output compatible with GBA BIOS decompression routines.
/// This allows embedding compressed assets directly in ROM.
///
/// @section compress_overview Overview
///
/// All compression functions are `consteval` and execute at compile time.
/// The compressed data includes the appropriate header for BIOS decompression.
///
/// Supported algorithms:
/// - **LZ77** - Best for data with repeated patterns (graphics, maps)
/// - **Huffman** - Best for data with skewed symbol frequencies (text)
/// - **RLE** - Best for data with long runs of identical values
/// - **BitPack** - Reduces bit depth of data (e.g., 32-bit to 4-bit)
///
/// @section compress_example Example Usage
///
/// @code{.cpp}
/// // Compress tilemap data at compile time
/// constexpr auto compressed_map = gba::lz77_compress([] {
///     return std::array<unsigned short, 1024>{
///         0, 0, 0, 1, 1, 1, 2, 2, 2, // ... tile indices
///     };
/// });
///
/// // Decompress at runtime using BIOS
/// void load_map() {
///     alignas(4) std::array<unsigned short, 1024> buffer;
///     gba::LZ77UnCompWram(compressed_map, buffer.data());
/// }
/// @endcode
///
/// TONCLIB Equivalent:
/// @code{.c}
/// // TONCLIB requires external tool compression (grit, etc.)
/// extern const u8 mapLZ77[];
/// u16 buffer[1024];
/// LZ77UnCompWram(mapLZ77, buffer);
/// @endcode
///
/// @see gba::LZ77UnCompWram
/// @see gba::LZ77UnCompVram
/// @see gba::HuffUnComp
/// @see gba::RLUnCompWram
/// @see gba::BitUnPack
#pragma once

#include <gba/bios>
#include <gba/bits/min_heap.hpp>
#include <gba/bits/ranges.hpp>

#include <bitset>
#include <cstdint>
#include <functional>
#include <numeric>
#include <vector>

namespace gba {

    /// @brief Pack data to lower bit depth with specified parameters.
    ///
    /// Compresses data by reducing bit depth, compatible with BitUnPack BIOS function.
    ///
    /// @param src Source data range.
    /// @param dest Destination iterator for packed bytes.
    /// @param params Packing parameters specifying bit depths and offset.
    /// @return The packing parameters used.
    consteval const unpack_parameters& bit_pack(std::ranges::input_range auto&& src,
                                                std::weakly_incrementable auto dest, const unpack_parameters& params)
        requires std::indirectly_writable<decltype(dest), std::byte>
    {
        if (params.dst_bpp == 32) {
            const auto view = bits::view_integers<std::uint32_t>(src) |
                              std::views::transform([offset = params.dst_ofs, offsetZero = params.offset_zero](auto x) {
                                  if (x || offsetZero) return static_cast<std::uint8_t>(x - offset);
                                  return static_cast<std::uint8_t>(x);
                              });

            const auto bufferLimit = 8 / params.src_bpp;

            auto iter = std::ranges::begin(view);
            while (iter != std::ranges::end(view)) {
                std::uint8_t buffer = 0;
                for (auto i = 0; i < bufferLimit; ++i) {
                    buffer |= *iter << i * params.src_bpp;
                    ++iter;
                }
                *dest++ = std::byte{buffer};
            }

            return params;
        }

        if (params.dst_bpp == 16) {
            const auto view = bits::view_integers<std::uint16_t>(src) |
                              std::views::transform([offset = params.dst_ofs, offsetZero = params.offset_zero](auto x) {
                                  if (x || offsetZero) return static_cast<std::uint8_t>(x - offset);
                                  return static_cast<std::uint8_t>(x);
                              });

            const auto bufferLimit = 8 / params.src_bpp;

            auto iter = std::ranges::begin(view);
            while (iter != std::ranges::end(view)) {
                std::uint8_t buffer = 0;
                for (auto i = 0; i < bufferLimit; ++i) {
                    buffer |= *iter << i * params.src_bpp;
                    ++iter;
                }
                *dest++ = std::byte{buffer};
            }

            return params;
        }

        if (params.dst_bpp == 8) {
            const auto view = bits::view_integers<std::uint8_t>(src) |
                              std::views::transform([offset = params.dst_ofs, offsetZero = params.offset_zero](auto x) {
                                  if (x || offsetZero) return static_cast<std::uint8_t>(x - offset);
                                  return static_cast<std::uint8_t>(x);
                              });

            const auto bufferLimit = 8 / params.src_bpp;

            auto iter = std::ranges::begin(view);
            while (iter != std::ranges::end(view)) {
                std::uint8_t buffer = 0;
                for (auto i = 0; i < bufferLimit; ++i) {
                    buffer |= *iter << i * params.src_bpp;
                    ++iter;
                }
                *dest++ = std::byte{buffer};
            }

            return params;
        }

        if (params.dst_bpp == 4) {
            // Extract nibbles (4 bits each) from source bytes
            const auto view = bits::view_integers<std::uint8_t>(src);
            const auto bufferLimit = 8 / params.src_bpp;

            auto iter = std::ranges::begin(view);
            int nibbleIndex = 0; // 0 = low nibble, 1 = high nibble
            std::uint8_t currentByte = 0;

            while (iter != std::ranges::end(view)) {
                std::uint8_t buffer = 0;
                for (auto i = 0; i < bufferLimit; ++i) {
                    // Extract current nibble from source byte
                    std::uint8_t nibble = (currentByte >> (nibbleIndex * 4)) & 0x0F;

                    // Apply offset transformation
                    if (nibble || params.offset_zero) {
                        nibble = static_cast<std::uint8_t>(nibble - params.dst_ofs);
                    }

                    buffer |= nibble << (i * params.src_bpp);

                    // Advance to next nibble
                    ++nibbleIndex;
                    if (nibbleIndex >= 2) {
                        nibbleIndex = 0;
                        if (iter != std::ranges::end(view)) {
                            currentByte = *iter;
                            ++iter;
                        }
                    }
                }
                *dest++ = std::byte{buffer};
            }

            return params;
        }

        if (params.dst_bpp == 2) {
            // Extract bit pairs (2 bits each) from source bytes
            const auto view = bits::view_integers<std::uint8_t>(src);
            const auto bufferLimit = 8 / params.src_bpp;

            auto iter = std::ranges::begin(view);
            int pairIndex = 0; // 0-3 for each bit pair in a byte
            std::uint8_t currentByte = 0;

            while (iter != std::ranges::end(view)) {
                std::uint8_t buffer = 0;
                for (auto i = 0; i < bufferLimit; ++i) {
                    // Extract current bit pair from source byte
                    std::uint8_t pair = (currentByte >> (pairIndex * 2)) & 0x03;

                    // Apply offset transformation
                    if (pair || params.offset_zero) {
                        pair = static_cast<std::uint8_t>(pair - params.dst_ofs);
                    }

                    buffer |= pair << (i * params.src_bpp);

                    // Advance to next bit pair
                    ++pairIndex;
                    if (pairIndex >= 4) {
                        pairIndex = 0;
                        if (iter != std::ranges::end(view)) {
                            currentByte = *iter;
                            ++iter;
                        }
                    }
                }
                *dest++ = std::byte{buffer};
            }

            return params;
        }

        if (params.dst_bpp == 1) {
            // Extract single bits from source bytes
            const auto view = bits::view_integers<std::uint8_t>(src);
            const auto bufferLimit = 8 / params.src_bpp;

            auto iter = std::ranges::begin(view);
            int bitIndex = 0; // 0-7 for each bit in a byte
            std::uint8_t currentByte = 0;

            while (iter != std::ranges::end(view)) {
                std::uint8_t buffer = 0;
                for (auto i = 0; i < bufferLimit; ++i) {
                    // Extract current bit from source byte
                    std::uint8_t bit = (currentByte >> bitIndex) & 0x01;

                    // Apply offset transformation
                    if (bit || params.offset_zero) {
                        bit = static_cast<std::uint8_t>(bit - params.dst_ofs);
                    }

                    buffer |= bit << (i * params.src_bpp);

                    // Advance to next bit
                    ++bitIndex;
                    if (bitIndex >= 8) {
                        bitIndex = 0;
                        if (iter != std::ranges::end(view)) {
                            currentByte = *iter;
                            ++iter;
                        }
                    }
                }
                *dest++ = std::byte{buffer};
            }

            return params;
        }

        throw "Unsupported destination bpp";
    }

    /// @brief Pack data to lower bit depth with automatic parameter detection.
    ///
    /// Analyzes the data to determine optimal packing parameters.
    ///
    /// @param src Source data range.
    /// @param dest Destination iterator for packed bytes.
    /// @param bpp Source bits per pixel (8, 16, or 32).
    /// @return The calculated packing parameters.
    consteval auto bit_pack(std::ranges::input_range auto&& src, std::weakly_incrementable auto dest, int bpp)
        -> unpack_parameters
        requires std::indirectly_writable<decltype(dest), std::byte>
    {
        static constexpr auto src_value_size = sizeof(std::ranges::range_value_t<decltype(src)>);

        if (bpp == 32) {
            const auto view = bits::view_integers<std::uint32_t>(src);
            const auto [min, max, hasZero] = bits::min_max(view);
            const auto offset = std::min(static_cast<std::size_t>(min - hasZero),
                                         static_cast<std::size_t>(std::numeric_limits<int>::max()));
            const auto range = max - offset;

            if (range < 256) {
                const auto packedBpp = std::bit_ceil(static_cast<std::size_t>(
                    std::ranges::max(view | std::views::filter([](auto x) { return !!x; }) |
                                     std::views::transform([offset](auto x) { return std::bit_width(x - offset); }))));
                const auto elemsPerByte = 8 / packedBpp;

                return bit_pack(src, dest,
                                {.src_len = static_cast<unsigned short>(
                                     ((std::ranges::size(src) * src_value_size) + elemsPerByte - 1) / elemsPerByte),
                                 .src_bpp = static_cast<unsigned char>(packedBpp & 0xf),
                                 .dst_bpp = 32,
                                 .dst_ofs = offset,
                                 .offset_zero = !hasZero});
            }

            bpp = 16;
        }

        if (bpp == 16) {
            const auto view = bits::view_integers<std::uint16_t>(src);
            const auto [min, max, hasZero] = bits::min_max(view);
            const auto offset = std::min(static_cast<std::size_t>(min - hasZero),
                                         static_cast<std::size_t>(std::numeric_limits<int>::max()));
            const auto range = max - offset;

            if (range < 256) {
                const auto packedBpp = std::bit_ceil(static_cast<std::size_t>(
                    std::ranges::max(view | std::views::filter([](auto x) { return !!x; }) |
                                     std::views::transform([offset](auto x) { return std::bit_width(x - offset); }))));
                const auto elemsPerByte = 8 / packedBpp;

                return bit_pack(src, dest,
                                {.src_len = static_cast<unsigned short>(
                                     ((std::ranges::size(src) * src_value_size) + elemsPerByte - 1) / elemsPerByte),
                                 .src_bpp = static_cast<unsigned char>(packedBpp & 0xf),
                                 .dst_bpp = 16,
                                 .dst_ofs = offset,
                                 .offset_zero = !hasZero});
            }
        }

        const auto view = bits::view_integers<std::uint8_t>(src);
        const auto [min, max, hasZero] = bits::min_max(view);
        const auto offset = std::min(static_cast<std::size_t>(min - hasZero),
                                     static_cast<std::size_t>(std::numeric_limits<int>::max()));
        const auto range = max - offset;

        const auto packedBpp = std::bit_ceil(static_cast<std::size_t>(
            std::ranges::max(view | std::views::filter([](auto x) { return !!x; }) |
                             std::views::transform([offset](auto x) { return std::bit_width(x - offset); }))));
        const auto elemsPerByte = 8 / packedBpp;
        const auto sourcelen = ((std::ranges::size(src) * src_value_size) + elemsPerByte - 1) / elemsPerByte;

        return bit_pack(src, dest,
                        {.src_len = static_cast<unsigned short>(sourcelen + 3 & ~3),
                         .src_bpp = static_cast<unsigned char>(packedBpp & 0xf),
                         .dst_bpp = 8,
                         .dst_ofs = offset,
                         .offset_zero = !hasZero});
    }

    /// @brief Pack data from a supplier lambda at compile time.
    ///
    /// This is the primary interface for compile-time bit packing. Pass a lambda
    /// that returns the data to pack.
    ///
    /// @param supplier Lambda returning the data to pack.
    /// @return A combined type containing unpack_parameters header and packed data.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Pack 4-bit palette indices at compile time
    /// constexpr auto packed_indices = gba::bit_pack([] {
    ///     return std::array<unsigned char, 64>{
    ///         0, 1, 2, 3, 4, 5, 6, 7, // Only uses values 0-15
    ///         // ...
    ///     };
    /// });
    ///
    /// // Unpack at runtime
    /// void load_indices() {
    ///     std::array<unsigned char, 64> buffer;
    ///     gba::BitUnPack(packed_indices.data(), buffer.data(), packed_indices);
    /// }
    /// @endcode
    consteval auto bit_pack(auto supplier) {
        using supplied_type = decltype(supplier());

        static constexpr std::size_t supplied_bpp =
            std::numeric_limits<std::make_unsigned_t<typename supplied_type::value_type>>::digits;
        static_assert(std::has_single_bit(supplied_bpp));
        static constexpr auto supplied_length =
            std::conditional_t<bits::StringViewLike<supplied_type>,
                               std::integral_constant<std::size_t, supplier().size()>,
                               std::tuple_size<supplied_type>>::value;
        static constexpr auto large_buffer_size = supplied_length * supplied_bpp / 8 +
                                                  3; // +3 bytes to handle 4 byte alignement woes

        static constexpr auto oversized =
            [&supplier] consteval -> std::pair<unpack_parameters, std::array<std::byte, large_buffer_size>> {
            std::array<std::byte, large_buffer_size> largeBuffer;
            return {bit_pack(supplier(), largeBuffer.begin(), std::min(supplied_bpp, 32u)), largeBuffer};
        }();

        static_assert(oversized.first.src_len <= large_buffer_size &&
                      oversized.first.src_len <= oversized.first.dst_len());
        using buffer_type = std::array<std::byte, oversized.first.src_len>;

        buffer_type resizedBuffer;
        std::copy_n(oversized.second.begin(), resizedBuffer.size(), resizedBuffer.begin());

        static_assert(oversized.first.dst_len() / sizeof(typename supplied_type::value_type) >= supplied_length);
        struct combined : unpack_parameters, buffer_type {
            using unpacked_array = std::array<typename supplied_type::value_type,
                                              oversized.first.dst_len() / sizeof(typename supplied_type::value_type)>;
            using unpacked_size = std::integral_constant<std::size_t, supplied_length>;
        };
        return combined{oversized.first, resizedBuffer};
    }

    /// @brief LZ77 compress data to a destination iterator.
    ///
    /// @param src Source data range.
    /// @param dest Destination iterator for compressed bytes.
    /// @return Pair of (compressed size, uncompress_header).
    consteval auto lz77_compress(std::ranges::input_range auto&& src, std::weakly_incrementable auto dest)
        -> std::pair<std::size_t, uncompress_header>
        requires std::indirectly_writable<decltype(dest), std::byte>
    {
        union block {
            std::uint8_t uncompressed{};
            struct {
                unsigned short msb  : 4;
                unsigned short size : 4;
                unsigned short lsb  : 8;
            } compressed;
        };
        std::bitset<8> blockTypes;
        std::vector<block> blockBuffer;
        std::vector<std::uint8_t> lookBackBuffer;
        static constexpr auto capacity = 1 << 12;

        const auto pushBack = [&lookBackBuffer](const std::uint8_t x) {
            if (lookBackBuffer.size() == capacity) {
                lookBackBuffer.erase(lookBackBuffer.begin());
            }
            lookBackBuffer.push_back(x);
        };

        const auto view = bits::view_integers<std::uint8_t>(src);
        auto left = view.begin();
        auto right = left;

        const auto compressedStart = dest;

        while (left != view.end()) {
            auto lookBackStart = lookBackBuffer.end();
            auto size = 0u;
            while (right != view.end()) {
                ++right;
                const auto lookBackCandidate = std::search(lookBackBuffer.begin(), lookBackBuffer.end(), left, right);
                if (lookBackCandidate == lookBackBuffer.end()) {
                    break;
                }
                ++size;
                lookBackStart = lookBackCandidate;
            }

            if (size >= 3) {
                // Compressed run
                if (size > 18) {
                    size = 18;
                }
                const auto displacement = std::distance(lookBackStart, lookBackBuffer.end()) - 1;
                blockTypes.set(blockBuffer.size(), true);
                blockBuffer.push_back({
                    .compressed = {
                                   .msb = static_cast<unsigned short>((displacement >> 8) & 0xf),
                                   .size = static_cast<unsigned short>((size - 3) & 0xf),
                                   .lsb = static_cast<unsigned short>(displacement & 0xff),
                                   }
                });
                while (size--) {
                    pushBack(*left);
                    ++left;
                }
            } else {
                // Uncompressed byte
                blockBuffer.push_back({.uncompressed = *left});
                pushBack(*left);
                ++left;
            }
            right = left;

            if (blockBuffer.size() == 8) {
                std::bitset<8> reversed;
                for (std::size_t i = 0; i < 8; ++i) {
                    reversed[i] = blockTypes[7 - i];
                }
                *dest++ = static_cast<std::byte>(reversed.to_ulong());

                for (std::size_t i = 0; i < blockBuffer.size(); ++i) {
                    if (blockTypes.test(i)) {
                        const auto [a, b] = std::bit_cast<std::array<std::byte, 2>>(blockBuffer[i].compressed);
                        *dest++ = a;
                        *dest++ = b;
                    } else {
                        *dest++ = std::bit_cast<std::byte>(blockBuffer[i].uncompressed);
                    }
                }

                blockTypes.reset();
                blockBuffer.clear();
            }
        }

        if (blockBuffer.size() < 8) {
            std::bitset<8> reversed;
            for (std::size_t i = 0; i < 8; ++i) {
                reversed[i] = blockTypes[7 - i];
            }
            *dest++ = static_cast<std::byte>(reversed.to_ulong());

            std::size_t i = 0;
            for (; i < blockBuffer.size(); ++i) {
                if (blockTypes.test(i)) {
                    const auto [a, b] = std::bit_cast<std::array<std::byte, 2>>(blockBuffer[i].compressed);
                    *dest++ = a;
                    *dest++ = b;
                } else {
                    *dest++ = static_cast<std::byte>(blockBuffer[i].uncompressed);
                }
            }

            for (; i < 8; ++i) {
                *dest++ = {};
            }
        }

        return std::make_pair(std::distance(compressedStart, dest),
                              uncompress_header{
                                  .comp_algo = comp_algo_lz77,
                                  .dst_len = static_cast<unsigned int>(
                                      std::ranges::size(src) * sizeof(std::ranges::range_value_t<decltype(src)>) + 1 &
                                      ~1), // 2 byte aligned for vram
                              });
    }

    /// @brief LZ77 compress data from a supplier lambda at compile time.
    ///
    /// This is the primary interface for compile-time LZ77 compression. Pass a
    /// lambda that returns the data to compress.
    ///
    /// @param supplier Lambda returning the data to compress.
    /// @return A combined type containing uncompress_header and compressed data.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Compress tile data at compile time
    /// constexpr auto compressed_tiles = gba::lz77_compress([] {
    ///     return std::array<unsigned int, 256>{
    ///         0x00000000, 0x00000000, 0x11111111, 0x11111111,
    ///         // ... repeated patterns compress well
    ///     };
    /// });
    ///
    /// // Decompress to VRAM at runtime
    /// void load_tiles() {
    ///     gba::LZ77UnCompVram(compressed_tiles, reinterpret_cast<void*>(0x06000000));
    /// }
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// // Compressed with external tool
    /// extern const u8 tilesLZ77[];
    /// LZ77UnCompVram(tilesLZ77, tile_mem);
    /// @endcode
    consteval auto lz77_compress(auto supplier) {
        using supplied_type = decltype(supplier());
        static constexpr auto supplied_length =
            std::conditional_t<bits::StringViewLike<supplied_type>,
                               std::integral_constant<std::size_t, supplier().size()>,
                               std::tuple_size<supplied_type>>::value;
        static constexpr auto supplied_bytes = sizeof(typename supplied_type::value_type) * supplied_length;
        static constexpr auto large_buffer_size =
            supplied_bytes +
            (supplied_bytes + 7 / 8); // At worst, it is uncompressable, so every 8 bytes gains a new byte

        static constexpr auto oversized = [&supplier] consteval
            -> std::tuple<std::size_t, uncompress_header, std::array<std::byte, large_buffer_size>> {
            std::array<std::byte, large_buffer_size> largeBuffer;
            const auto [compressedSize, compressedData] = lz77_compress(supplier(), largeBuffer.begin());
            return {compressedSize, compressedData, largeBuffer};
        }();

        using buffer_type = std::array<std::byte, std::get<0>(oversized)>;

        buffer_type resizedBuffer;
        std::copy_n(std::get<2>(oversized).begin(), resizedBuffer.size(), resizedBuffer.begin());

        struct combined : uncompress_header, buffer_type {
            using unpacked_array =
                std::array<typename supplied_type::value_type,
                           std::get<1>(oversized).dst_len / sizeof(typename supplied_type::value_type)>;
            using unpacked_size = std::integral_constant<std::size_t, supplied_length>;
        };
        return combined{std::get<1>(oversized), resizedBuffer};
    }

    /// @brief Huffman compress data to a destination iterator.
    ///
    /// @tparam Bits Symbol size in bits (4 or 8).
    /// @param src Source data range.
    /// @param dest Destination iterator for compressed bytes.
    /// @return Pair of (compressed size, uncompress_header).
    template<std::size_t Bits = 8>
    consteval auto huffman_compress(std::ranges::input_range auto&& src, std::weakly_incrementable auto dest)
        -> std::pair<std::size_t, uncompress_header>
        requires std::indirectly_writable<decltype(dest), std::byte>
    {
        static_assert(Bits == 4 || Bits == 8);

        std::vector<std::uint8_t> view;
        {
            const auto byteView = bits::view_integers<std::uint8_t>(src);

            if constexpr (Bits == 8) {
                view = std::ranges::to<std::vector>(byteView);
            } else if constexpr (Bits == 4) {
                for (auto byte : byteView) {
                    view.push_back(byte & 0xf);
                    view.push_back((byte >> 4) & 0xf);
                }
            }
        }

        std::unique_ptr<bits::huffman_node> root;
        {
            bits::min_heap<bits::huffman_node> heap;
            {
                const auto [frequencies, frequencyCount] = bits::ranges_frequency(view);

                for (std::size_t i = 0; i < frequencyCount; ++i) {
                    heap.emplace(frequencies[i].first, frequencies[i].second);
                }
            }

            if (heap.size() == 1) {
                const auto& node = heap.front();
                heap.emplace(node->symbol, node->frequency);
            }

            while (heap.size() > 1) {
                auto left = heap.pop();
                auto right = heap.pop();
                heap.emplace(std::move(left), std::move(right));
            }
            root = heap.pop();
        }

        const auto compressedStart = dest;

        {
            std::vector<std::pair<const bits::huffman_node*, std::size_t>> linearNodes;
            linearNodes.emplace_back(root.get(), 0);
            bits::huffman_node::traverse(*root, [&](const auto& node) consteval {
                linearNodes.emplace_back(node.left.get(), 0);
                linearNodes.emplace_back(node.right.get(), 0);
            });

            *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>((linearNodes.size() / 2) | 1));

            auto iter = linearNodes.begin();
            while (iter != linearNodes.end()) {
                if (!iter->first->is_leaf()) {
                    iter->second = std::distance(iter, std::find_if(iter, linearNodes.end(), [&](const auto& p) {
                                                     return p.first == iter->first->left.get();
                                                 }));
                }
                ++iter;
            }

            struct branch {
                std::uint8_t offset : 6;
                bool node1_leaf     : 1;
                bool node0_leaf     : 1;
            };

            for (const auto& n : linearNodes) {
                if (n.first->is_leaf()) {
                    *dest++ = std::bit_cast<std::byte>(n.first->symbol);
                } else {
                    *dest++ = std::bit_cast<std::byte>(branch{.offset = static_cast<std::uint8_t>((n.second - 1) / 2),
                                                              .node1_leaf = n.first->right->is_leaf(),
                                                              .node0_leaf = n.first->left->is_leaf()});
                }
            }

            if (((linearNodes.size() + 1) % 4) != 0) {
                *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>(0xff));
                *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>(0xff));
            }
        }

        std::array<std::vector<bool>, 255> codes;
        bits::huffman_node::to_keys(*root, [&](auto key, const auto& code) consteval { codes[key] = code; });

        std::vector<bool> buffer;
        buffer.reserve(32);
        for (auto key : view) {
            for (auto bit : codes[key]) {
                buffer.push_back(bit);

                if (buffer.size() == 32) {
                    const auto data = accumulate(buffer.begin(), buffer.end(), std::uint32_t{},
                                                 [](auto x, auto y) { return (x << 1) + y; });
                    *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>(data & 0xff));
                    *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>((data >> 8) & 0xff));
                    *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>((data >> 16) & 0xff));
                    *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>((data >> 24) & 0xff));

                    buffer.clear();
                }
            }
        }

        if (!buffer.empty()) {
            buffer.resize(32);
            const auto data = accumulate(buffer.begin(), buffer.end(), std::uint32_t{},
                                         [](auto x, auto y) { return (x << 1) + y; });
            *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>(data & 0xff));
            *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>((data >> 8) & 0xff));
            *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>((data >> 16) & 0xff));
            *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>((data >> 24) & 0xff));
        }

        return std::make_pair(
            std::distance(compressedStart, dest),
            uncompress_header{.src_len = Bits,
                              .comp_algo = comp_algo_huff,
                              .dst_len = static_cast<unsigned int>(std::ranges::size(src) *
                                                                   sizeof(std::ranges::range_value_t<decltype(src)>))});
    }

    /// @brief Huffman compress data from a supplier lambda at compile time.
    ///
    /// This is the primary interface for compile-time Huffman compression. Pass a
    /// lambda that returns the data to compress. Huffman is best for data with
    /// skewed symbol frequencies (e.g., text, sparse data).
    ///
    /// @tparam Bits Symbol size in bits (4 or 8, default 8).
    /// @param supplier Lambda returning the data to compress.
    /// @return A combined type containing uncompress_header and compressed data.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Compress text data at compile time
    /// constexpr auto compressed_text = gba::huffman_compress([] {
    ///     return std::array<char, 64>{
    ///         'H', 'e', 'l', 'l', 'o', ' ', 'W', 'o', 'r', 'l', 'd', '!',
    ///         // ... text with repeated characters compresses well
    ///     };
    /// });
    ///
    /// // Decompress at runtime
    /// void load_text() {
    ///     alignas(4) std::array<char, 64> buffer;
    ///     gba::HuffUnComp(compressed_text, buffer.data());
    /// }
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// extern const u8 textHuff[];
    /// HuffUnComp(textHuff, buffer);
    /// @endcode
    template<std::size_t Bits = 8>
    consteval auto huffman_compress(auto supplier) {
        using supplied_type = decltype(supplier());
        static constexpr auto supplied_length =
            std::conditional_t<bits::StringViewLike<supplied_type>,
                               std::integral_constant<std::size_t, supplier().size()>,
                               std::tuple_size<supplied_type>>::value;
        static constexpr auto supplied_bytes = sizeof(typename supplied_type::value_type) * supplied_length;
        static constexpr auto large_buffer_size = supplied_bytes * 3;

        static constexpr auto oversized = [&supplier] consteval
            -> std::tuple<std::size_t, uncompress_header, std::array<std::byte, large_buffer_size>> {
            std::array<std::byte, large_buffer_size> largeBuffer;
            const auto [compressedSize, compressedData] = huffman_compress<Bits>(supplier(), largeBuffer.begin());
            return {compressedSize, compressedData, largeBuffer};
        }();

        using buffer_type = std::array<std::byte, std::get<0>(oversized)>;

        buffer_type resizedBuffer;
        std::copy_n(std::get<2>(oversized).begin(), resizedBuffer.size(), resizedBuffer.begin());

        struct combined : uncompress_header, buffer_type {
            using unpacked_array =
                std::array<typename supplied_type::value_type,
                           std::get<1>(oversized).dst_len / sizeof(typename supplied_type::value_type)>;
            using unpacked_size = std::integral_constant<std::size_t, supplied_length>;
        };
        return combined{std::get<1>(oversized), resizedBuffer};
    }

    /// @brief RLE compress data to a destination iterator.
    ///
    /// Run-length encoding is best for data with long runs of identical values.
    ///
    /// @param src Source data range.
    /// @param dest Destination iterator for compressed bytes.
    /// @return Pair of (compressed size, uncompress_header).
    consteval auto rle_compress(std::ranges::input_range auto&& src, std::weakly_incrementable auto dest)
        -> std::pair<std::size_t, uncompress_header>
        requires std::indirectly_writable<decltype(dest), std::byte>
    {
        const auto view = bits::view_integers<std::uint8_t>(src);

        const auto compressedStart = dest;

        auto iter = view.begin();
        while (iter != view.end()) {
            std::ptrdiff_t length = 0;
            auto run = iter;
            do {
                ++run;
                ++length;
            } while (length < 130 && *run == *iter && run != view.end());

            if (length >= 3) {
                // RLE repeat
                *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>((length - 3) | 0x80));
                *dest++ = std::bit_cast<std::byte>(*iter);
                iter = run;
            } else {
                do {
                    std::ptrdiff_t repeatLength = 0;
                    auto repeatRun = run;
                    do {
                        ++repeatRun;
                        ++repeatLength;
                    } while (repeatLength < 3 && *repeatRun == *run && repeatRun != view.end());

                    if (repeatLength == 3) {
                        break;
                    }

                    run = repeatRun;
                    length += repeatLength;
                } while (length < 128 && *run != *iter && run != view.end());

                // RLE copy
                *dest++ = std::bit_cast<std::byte>(static_cast<std::uint8_t>(length - 1));
                do {
                    *dest++ = std::bit_cast<std::byte>(*iter);
                    ++iter;
                } while (iter != run && iter != view.end());
            }
        }

        return std::make_pair(
            std::distance(compressedStart, dest),
            uncompress_header{.comp_algo = comp_algo_rl,
                              .dst_len = static_cast<unsigned int>(std::ranges::size(src) *
                                                                   sizeof(std::ranges::range_value_t<decltype(src)>))});
    }

    /// @brief RLE compress data from a supplier lambda at compile time.
    ///
    /// This is the primary interface for compile-time RLE compression. Pass a
    /// lambda that returns the data to compress. RLE is best for data with
    /// long runs of identical values (e.g., simple sprites, backgrounds).
    ///
    /// @param supplier Lambda returning the data to compress.
    /// @return A combined type containing uncompress_header and compressed data.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Compress sprite with many repeated pixels
    /// constexpr auto compressed_sprite = gba::rle_compress([] {
    ///     return std::array<unsigned char, 256>{
    ///         0, 0, 0, 0, 0, 0, 0, 0,  // Runs of zeros
    ///         1, 1, 1, 1, 1, 1, 1, 1,  // Runs of ones
    ///         // ... RLE compresses runs efficiently
    ///     };
    /// });
    ///
    /// // Decompress at runtime
    /// void load_sprite() {
    ///     std::array<unsigned char, 256> buffer;
    ///     gba::RLUnCompWram(compressed_sprite, buffer.data());
    /// }
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// extern const u8 spriteRL[];
    /// RLUnCompWram(spriteRL, buffer);
    /// @endcode
    consteval auto rle_compress(auto supplier) {
        using supplied_type = decltype(supplier());
        static constexpr auto supplied_length =
            std::conditional_t<bits::StringViewLike<supplied_type>,
                               std::integral_constant<std::size_t, supplier().size()>,
                               std::tuple_size<supplied_type>>::value;
        static constexpr auto supplied_bytes = sizeof(typename supplied_type::value_type) * supplied_length;
        static constexpr auto large_buffer_size = supplied_bytes + ((supplied_bytes + 127) / 128);

        static constexpr auto oversized = [&supplier] consteval
            -> std::tuple<std::size_t, uncompress_header, std::array<std::byte, large_buffer_size>> {
            std::array<std::byte, large_buffer_size> largeBuffer;
            const auto [compressedSize, compressedData] = rle_compress(supplier(), largeBuffer.begin());
            return {compressedSize, compressedData, largeBuffer};
        }();

        using buffer_type = std::array<std::byte, std::get<0>(oversized)>;

        buffer_type resizedBuffer;
        std::copy_n(std::get<2>(oversized).begin(), resizedBuffer.size(), resizedBuffer.begin());

        struct combined : uncompress_header, buffer_type {
            using unpacked_array =
                std::array<typename supplied_type::value_type,
                           std::get<1>(oversized).dst_len / sizeof(typename supplied_type::value_type)>;
            using unpacked_size = std::integral_constant<std::size_t, supplied_length>;
        };
        return combined{std::get<1>(oversized), resizedBuffer};
    }

