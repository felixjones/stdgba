/// @file color
/// @brief GBA 15-bit colour type, palette memory registers, and web-colour literals.
///
/// Provides the `gba::color` struct (5-bit xBGR), compile-time conversion from
/// CSS hex strings and named colours, and `inline constexpr` registral wrappers for
/// all four palette RAM regions.
///
/// Example:
/// @code{.cpp}
/// using namespace gba::literals;
/// gba::pal_bg_mem[0] = "#FF8040"_clr;   // backdrop colour
/// gba::pal_bg_bank[1][3] = "cornflowerblue"_clr;
/// @endcode
///
/// TONCLIB Equivalent:
/// @code{.c}
/// pal_bg_mem[0] = RGB8(0xFF, 0x80, 0x40);
/// pal_bg_mem[16 + 3] = RGB8(0x64, 0x95, 0xED); // cornflowerblue (#6495ED)
/// @endcode
#pragma once

#include <gba/peripherals>

#include <cstddef>
#include <string_view>

namespace gba {

    /// @brief Raw palette RAM (512 halfwords, BG + OBJ combined, 0x5000000).
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// pal_mem[n] = color_value;
    /// @endcode
    inline constexpr auto mem_pal = registral<short[512]>{0x5000000};

    /// @brief Background palette RAM (256 entries, 0x5000000).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::mem_pal_bg[0] = 0; // black backdrop
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// pal_bg_mem[0] = 0;
    /// @endcode
    inline constexpr auto mem_pal_bg = registral<short[256]>{0x5000000};

    /// @brief Object palette RAM (256 entries, 0x5000200).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::mem_pal_obj[0] = 0x7FFF; // white sprite color
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// pal_obj_mem[0] = RGB15(31, 31, 31);
    /// @endcode
    inline constexpr auto mem_pal_obj = registral<short[256]>{0x5000200};

    /// @brief 15-bit xBGR colour value (2 bytes, GBA native format).
    ///
    /// Each channel is 5 bits (0-31). The `grn_lo` field captures the low bit of the
    /// green channel that spills out of the 5-bit green field when building from 6-bit
    /// source data; leave it zero for normal use.
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::color red = { .red = 31 };
    /// gba::color white = { .red = 31, .green = 31, .blue = 31 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// COLOR red = RGB15(31, 0, 0);
    /// COLOR white = RGB15(31, 31, 31);
    /// @endcode
    struct alignas(unsigned short) color {
        unsigned short red    : 5; ///< Red channel (0-31)
        unsigned short green  : 5; ///< Green channel (0-31)
        unsigned short blue   : 5; ///< Blue channel (0-31)
        unsigned short grn_lo : 1; ///< Low green bit (leave 0 for normal use)

        [[nodiscard]] friend constexpr bool operator==(color, color) = default;
    };
    static_assert(sizeof(color) == 2);
    static_assert(alignof(color) == 2);

    namespace bits {

        /// @brief Convert a single ASCII hex digit to its 4-bit value.
        /// @param c ASCII character ('0'-'9', 'a'-'f', 'A'-'F').
        /// @return Numeric value 0-15.
        consteval unsigned short hex_nibble(char c) {
            if (c >= '0' && c <= '9') return c - '0';
            if (c >= 'a' && c <= 'f') return c - 'a' + 10;
            if (c >= 'A' && c <= 'F') return c - 'A' + 10;
            throw "invalid hex digit";
        }

        /// @brief Convert two ASCII hex digits to a byte value.
        /// @param hi High nibble character.
        /// @param lo Low nibble character.
        /// @return Byte value 0-255.
        consteval unsigned short hex_byte(char hi, char lo) {
            return (hex_nibble(hi) << 4) | hex_nibble(lo);
        }

        /// @brief Parse a `#RRGGBB` hex color string to a packed 24-bit RGB value.
        /// @param str Pointer to the string (must start with '#').
        /// @param len Length of the string (must be 7).
        /// @return Packed RGB as `(R << 16) | (G << 8) | B`.
        consteval unsigned int hex_to_rgb(const char* str, std::size_t len) {
            if (len != 7 || str[0] != '#') throw "expected \"#RRGGBB\" format";
            unsigned short r = hex_byte(str[1], str[2]);
            unsigned short g = hex_byte(str[3], str[4]);
            unsigned short b = hex_byte(str[5], str[6]);
            return (r << 16) | (g << 8) | b;
        }

