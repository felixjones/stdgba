    namespace literals {

        /// @brief User-defined literal for compile-time web colours.
        /// @param str Colour string: `"#RRGGBB"` hex or a CSS named colour (e.g. `"cornflowerblue"`).
        /// @param len Length of the string.
        /// @return `gba::color` value with 5-bit RGB channels.
        ///
        /// Example:
        /// @code{.cpp}
        /// using namespace gba::literals;
        /// gba::pal_bg_mem[0] = "#FF8040"_clr;
        /// gba::pal_bg_mem[1] = "cornflowerblue"_clr;
        /// @endcode
        consteval color operator""_clr(const char* str, std::size_t len) {
            std::string_view view(str, len);

            if (len == 7 && str[0] == '#') {
                return bits::from_rgb(bits::hex_to_rgb(str, len));
            }

            if (len > 0 && str[0] != '#') {
                return bits::from_rgb(bits::css_color_to_rgb(view));
            }

            throw "expected \"#RRGGBB\" or CSS color name";
        }

    } // namespace literals

    using literals::operator""_clr;

    /// @brief Background palette RAM as typed `color` array (256 entries, 0x5000000).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::pal_bg_mem[0] = { .blue = 16 };              // navy backdrop
    /// gba::pal_bg_mem[1] = { .red = 31 };               // red
    /// gba::pal_bg_mem[2] = { .red = 31, .green = 31 };  // yellow
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// pal_bg_mem[0] = RGB15(0, 0, 16);
    /// pal_bg_mem[1] = RGB15(31, 0, 0);
    /// pal_bg_mem[2] = RGB15(31, 31, 0);
    /// @endcode
    inline constexpr auto pal_bg_mem = registral_cast<color[256]>(mem_pal_bg);

    /// @brief Object palette RAM as typed `color` array (256 entries, 0x5000200).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::pal_obj_mem[0] = {};                                    // transparent (black)
    /// gba::pal_obj_mem[1] = { .red = 31 };                        // red
    /// gba::pal_obj_mem[2] = { .red = 31, .green = 31, .blue = 31 }; // white
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// pal_obj_mem[0] = 0;
    /// pal_obj_mem[1] = RGB15(31, 0, 0);
    /// pal_obj_mem[2] = RGB15(31, 31, 31);
    /// @endcode
    inline constexpr auto pal_obj_mem = registral_cast<color[256]>(mem_pal_obj);

    /// @brief Background palette RAM as 16 banks of 16 colours (0x5000000).
    ///
    /// Useful for 4bpp backgrounds where each bank is a separate 16-colour palette.
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::pal_bg_bank[0][0] = {};                                       // transparent (black)
    /// gba::pal_bg_bank[1][3] = { .red = 12, .green = 18, .blue = 29 };  // cornflower blue
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// pal_bg_mem[0 * 16 + 0] = 0;
    /// pal_bg_mem[1 * 16 + 3] = RGB15(12, 18, 29);
    /// @endcode
    inline constexpr auto pal_bg_bank = registral<color[16][16]>(0x5000000);

    /// @brief Object palette RAM as 16 banks of 16 colours (0x5000200).
    ///
    /// Useful for 4bpp sprites where each bank is a separate 16-colour palette.
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::pal_obj_bank[2][0] = {};                                        // transparent (black)
    /// gba::pal_obj_bank[2][1] = { .red = 31, .green = 31, .blue = 31 };   // white
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// pal_obj_mem[2 * 16 + 0] = 0;
    /// pal_obj_mem[2 * 16 + 1] = RGB15(31, 31, 31);
    /// @endcode
    inline constexpr auto pal_obj_bank = registral<color[16][16]>(0x5000200);

} // namespace gba
