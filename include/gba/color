        /// @brief Convert a packed 24-bit RGB value to a `gba::color`.
        /// @param rgb Packed value as `(R << 16) | (G << 8) | B` with 8-bit channels.
        /// @return GBA color with 5-bit channels.
        consteval color from_rgb(unsigned int rgb) {
            unsigned short r = (rgb >> 16) & 0xFF;
            unsigned short g = (rgb >> 8) & 0xFF;
            unsigned short b = rgb & 0xFF;
            return {.red = static_cast<unsigned short>(r >> 3),
                    .green = static_cast<unsigned short>(g >> 3),
                    .blue = static_cast<unsigned short>(b >> 3),
                    .grn_lo = static_cast<unsigned short>((g >> 2) & 1)};
        }

