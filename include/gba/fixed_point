#pragma once


/**
 * @file fixed_point
 * @brief Fixed-point arithmetic with flexible conversion policies.
 *
 * This header provides a flexible fixed-point arithmetic implementation
 * optimized for GBA development. Fixed-point arithmetic avoids the overhead
 * of floating-point emulation on the ARM7TDMI processor.
 *
 * @section basic_usage Basic Usage
 *
 * @code{.cpp}
 * using namespace gba::literals;
 *
 * // Create fixed-point values (8.8 format by default for short)
 * gba::fixed<short> a = 3.5_fx;
 * gba::fixed<short> b = 1.25_fx;
 *
 * // Arithmetic operations
 * auto sum = a + b;      // 4.75
 * auto product = a * b;  // 4.375
 * auto quotient = a / b; // 2.8
 *
 * // Convert to integer (truncates)
 * int whole = static_cast<int>(a); // 3
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * // TONCLIB uses FIXED typedef (typically 24.8)
 * FIXED a = float2fx(3.5f);
 * FIXED b = float2fx(1.25f);
 * FIXED sum = a + b;
 * FIXED product = fxmul(a, b);
 * FIXED quotient = fxdiv(a, b);
 * int whole = fx2int(a);
 * @endcode
 *
 * @section fixed_class The fixed<> Class Template
 *
 * @code{.cpp}
 * template<
 *     std::integral Rep = int,              // Underlying integer type
 *     unsigned int FracBits = ...,          // Fractional bits (default: half of Rep)
 *     std::integral IntermediateRep = ...   // Type for intermediate calculations
 * >
 * class fixed;
 * @endcode
 *
 * Common configurations:
 * - `fixed<short>` - 8.8 format (8 integer bits, 8 fractional bits)
 * - `fixed<int>` - 16.16 format
 * - `fixed<int, 8>` - 24.8 format (matches TONCLIB FIXED)
 * - `fixed<short, 4>` - 12.4 format
 *
 * @section literals Fixed-Point Literals (_fx)
 *
 * The `_fx` suffix creates compile-time fixed-point literals that convert
 * to any `fixed<>` type:
 *
 * @code{.cpp}
 * using namespace gba::literals;
 *
 * gba::fixed<int, 8> a = 3.14159_fx;  // Converts at compile time
 * auto b = 2_fx * 3_fx;               // Intermediate literal type
 * gba::fixed<short> c = b;            // Converts on assignment
 *
 * // Compile-time constant
 * constexpr auto pi = 3.14159_fx;
 * constexpr gba::fixed<int, 16> precise_pi = pi;
 * @endcode
 *
 * @section conversions Type Conversions
 *
 * Fixed-point types with different configurations require explicit conversion
 * policies to avoid accidental precision loss:
 *
 * @code{.cpp}
 * gba::fixed<int, 8> a = 3.5_fx;   // 24.8 format
 * gba::fixed<int, 4> b = 1.25_fx;  // 28.4 format
 *
 * // Direct operations require same type
 * // auto c = a + b;  // Error: different types
 *
 * // Use conversion wrappers for mixed operations
 * auto c = gba::as_lhs(a) + b;      // Result is fixed<int, 8>
 * auto d = gba::as_widening(a) + b; // Result uses more precision
 * @endcode
 *
 * @section converters Conversion Wrappers
 *
 * ### Performance-oriented (recommended for most cases)
 *
 * | Wrapper | Description | Use Case |
 * |---------|-------------|----------|
 * | `as_lhs(x)` | Result type matches wrapped operand | When you know the desired type |
 * | `as_rhs(x)` | Result type matches other operand | When other operand is the target |
 *
 * @code{.cpp}
 * auto result = gba::as_lhs(a) + b; // Result is same type as 'a'
 * @endcode
 *
 * ### Precision-oriented
 *
 * | Wrapper | Description | Use Case |
 * |---------|-------------|----------|
 * | `as_narrowing(x)` | Converts to smaller precision | Intentional precision loss |
 * | `as_widening(x)` | Converts to larger precision | Maximum precision |
 * | `as_average_frac(x)` | Averages fractional bits | Balanced precision |
 * | `as_average_int(x)` | Averages integer bits | Balanced range |
 *
 * @code{.cpp}
 * // Widen to preserve precision
 * auto wide = gba::as_widening(low_precision) + high_precision;
 *
 * // Narrow when precision not needed
 * auto narrow = gba::as_narrowing(high_precision) + low_precision;
 * @endcode
 *
 * ### Container-oriented
 *
 * | Wrapper | Description | Use Case |
 * |---------|-------------|----------|
 * | `as_next_container(x)` | Promotes to larger integer type | Overflow prevention |
 * | `as_signed(x)` | Converts to signed representation | Sign-aware operations |
 * | `as_unsigned(x)` | Converts to unsigned representation | Bit manipulation |
 * | `as_word_storage(x)` | Uses int/unsigned for storage | GBA performance |
 *
 * @code{.cpp}
 * // Use word-sized storage for better ARM performance
 * auto fast = gba::as_word_storage(small_fixed) + other;
 * @endcode
 *
 * ### Rounding
 *
 * @code{.cpp}
 * // Add rounding to any converter
 * auto rounded = gba::with_rounding(gba::as_narrowing(x)) + y;
 * @endcode
 *
 * @section bit_access Raw Bit Access
 *
 * @code{.cpp}
 * gba::fixed<short> value = 1.5_fx;
 *
 * // Get underlying bits
 * short raw = gba::bit_cast(value);        // 0x0180 for 8.8 format
 * int raw_int = gba::bit_cast<int>(value); // Cast to different integer type
 *
 * // Useful for hardware register writes
 * gba::reg_bg2x = gba::bit_cast<int>(x_position);
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * // TONCLIB stores fixed values as plain integers
 * FIXED value = 0x0180; // 1.5 in 24.8 format
 * REG_BG2X = x_position; // Direct integer assignment
 * @endcode
 *
 * @section traits Type Traits
 *
 * @code{.cpp}
 * // Check if type is fixed-point
 * static_assert(gba::is_fixed_point_v<gba::fixed<int>>);
 * static_assert(gba::fixed_point<gba::fixed<short>>); // Concept
 *
 * // Access type properties
 * using T = gba::fixed<int, 8>;
 * using Traits = gba::fixed_point_traits<T>;
 * static_assert(Traits::frac_bits == 8);
 * static_assert(std::is_same_v<Traits::rep, int>);
 * @endcode
 *
 * @section overflow_warning Multiplication Overflow Warning
 *
 * @warning For performance, multiplication uses a default intermediate type that
 * may overflow for certain configurations. Specifically, `fixed<int, 16>` (16.16 format)
 * uses `int` as the intermediate type, which can overflow when multiplying values
 * where `|a * b| > 32767`.
 *
 * This trade-off prioritizes speed on ARM7TDMI (avoiding 64-bit operations) over
 * correctness for edge cases. For applications requiring full precision, use
 * `precise<>` type aliases:
 *
 * @code{.cpp}
 * // Default: fast but may overflow for large values
 * gba::fixed<int, 16> a = 100.0_fx;
 * gba::fixed<int, 16> b = 400.0_fx;
 * auto c = a * b;  // May overflow!
 *
 * // Safe: uses 64-bit intermediate, slower on GBA
 * gba::precise<int, 16> a = 100.0_fx;
 * gba::precise<int, 16> b = 400.0_fx;
 * auto c = a * b;  // Correct result: 40000.0
 * @endcode
 *
 * Safe configurations (no overflow risk):
 * - `fixed<short>` / `fixed<short, N>` - 16-bit values use 32-bit intermediate
 * - `fixed<int, 8>` (24.8 format) - smaller fractional part reduces overflow risk
 *
 * @see gba::precise
 * @see gba::fixed
 * @see gba::fixed_point_traits
 * @see gba::is_fixed_point_v
 */

// Core fixed-point implementation
#include <gba/bits/fixed_point/fixed_point_base.hpp>
#include <gba/bits/fixed_point/fixed_literal.hpp>

// Conversion infrastructure
#include <gba/bits/fixed_point/conversion_wrapper.hpp>
#include <gba/bits/fixed_point/operators.hpp>

// Conversion policies
#include <gba/bits/fixed_point/converters/lhs.hpp>
#include <gba/bits/fixed_point/converters/rhs.hpp>
#include <gba/bits/fixed_point/converters/narrowing.hpp>
#include <gba/bits/fixed_point/converters/widening.hpp>
#include <gba/bits/fixed_point/converters/average_frac.hpp>
#include <gba/bits/fixed_point/converters/average_int.hpp>
#include <gba/bits/fixed_point/converters/next_container.hpp>
#include <gba/bits/fixed_point/converters/to_signed.hpp>
#include <gba/bits/fixed_point/converters/to_unsigned.hpp>
#include <gba/bits/fixed_point/converters/word_storage.hpp>
#include <gba/bits/fixed_point/converters/with_rounding.hpp>

namespace gba {

/**
 * @brief Fixed-point type with full-precision intermediate calculations.
 *
 * Unlike `fixed<>`, this type alias uses a 64-bit intermediate for multiplication
 * and division, preventing overflow at the cost of performance on ARM7TDMI.
 *
 * Use this when correctness is more important than speed, or when working with
 * large values that would overflow the default intermediate type.
 *
 * @tparam Rep Underlying integer representation type.
 * @tparam FracBits Number of fractional bits (default: half of Rep's bits).
 *
 * @code{.cpp}
 * // 16.16 format with 64-bit intermediate - safe for large multiplications
 * gba::precise<int, 16> a = 1000.5_fx;
 * gba::precise<int, 16> b = 2000.25_fx;
 * auto c = a * b;  // Correct: uses long long intermediate
 * @endcode
 *
 * @see gba::fixed
 */
template<std::integral Rep = int,
         unsigned int FracBits = std::numeric_limits<std::make_unsigned_t<Rep>>::digits / 2>
using precise = fixed<Rep, FracBits,
    std::conditional_t<std::is_signed_v<Rep>, long long, unsigned long long>>;

} // namespace gba
