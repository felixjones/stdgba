#pragma once

/**
 * @file fixed_point
 * @brief Fixed-point arithmetic with flexible conversion policies
 *
 * This library provides a flexible fixed-point arithmetic implementation with
 * configurable conversion policies through wrapper types.
 *
 * ## Basic Usage
 *
 * ```cpp
 * gba::fixed<int, 8> a = 3.5;    // 8 fractional bits
 * gba::fixed<int, 4> b = 1.25;   // 4 fractional bits
 *
 * // Direct operations (same type only)
 * auto same = a + a;  // OK - same type
 *
 * // Different types require conversion wrapper
 * // auto mixed = a + b;  // Error - different types
 * auto mixed = as_lhs(a) + b;  // OK - explicit conversion policy
 *
 * // Implicit conversion only works when safe (no precision loss)
 * fixed<int, 8> c = b;  // OK - widening (4 frac -> 8 frac, safe)
 *
 * // Narrowing conversions not allowed - use converter in operation
 * // fixed<int, 4> d = a;  // Error - would lose precision
 *
 * // For "assignment", add zero with target type
 * auto d = as_narrowing(a) + fixed<int, 4>(0);  // Result: fixed<int, 4>
 * ```
 *
 * ## Fixed-Point Literals (_fx)
 *
 * Use the `_fx` suffix for compile-time fixed-point literals that can convert
 * to any `fixed<>` type. Import just the literal namespace to avoid pulling in
 * all of `gba`:
 *
 * ```cpp
 * // Option 1: Import just the literals namespace
 * using namespace gba::literals;
 * auto a = 1_fx + 2.3_fx;
 * gba::fixed<int, 8> b = a;
 *
 * // Option 2: Import just the _fx operator
 * using gba::literals::operator""_fx;
 * auto c = 5_fx * 2_fx;
 *
 * // Option 3: Use with full gba namespace
 * using namespace gba;
 * fixed<int, 8> d = 1_fx + 2.3_fx;
 *
 * // Mix with other numeric types
 * fixed<int, 16> e = 1_fx + 2.3f + 4LL;
 *
 * // Complex expressions
 * constexpr auto result = (10_fx / 4_fx) * 2_fx - 1.5_fx;
 * fixed<int, 8> f = result;  // f = 3.5
 * ```
 *
 * The `_fx` literals are `consteval` only and exist purely at compile-time.
 * They automatically convert to the appropriate `fixed<>` type on assignment.
 *
 * ## Conversion Wrappers
 *
 * ### Performance-oriented (best for most cases)
 * - `as_lhs(x)` - Result matches wrapped operand's type
 * - `as_rhs(x)` - Result matches unwrapped operand's type
 *
 * ### Precision-oriented
 * - `as_narrowing(x)` - Narrow to RHS type (may lose precision)
 * - `as_widening(x)` - Widen to higher precision (never loses data)
 * - `as_average_frac(x)` - Average fractional bits
 * - `as_average_int(x)` - Average integer bits
 *
 * ### Container-oriented
 * - `as_next_container(x)` - Use next larger container type
 * - `as_signed(x)` - Convert to signed (safe promotion if needed)
 * - `as_unsigned(x)` - Convert to unsigned (lossy for negatives)
 * - `as_word_storage(x)` - Use word-sized storage (int/unsigned int) for GBA performance
 *
 * ### Rounding
 * - `with_rounding(converter)` - Add rounding to any converter
 *
 * ## Type Parameters
 *
 * ```cpp
 * template<
 *     std::integral Rep = int,             // Underlying integer type
 *     unsigned int FracBits = ...,         // Number of fractional bits
 *     std::integral IntermediateRep = ...  // Type for intermediate calculations
 * >
 * class fixed;
 * ```
 */

