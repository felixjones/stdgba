/// @file peripherals
/// @brief GBA hardware register abstractions and memory-mapped IO.
///
/// This header provides C++ abstractions for GBA hardware registers using the `registral` template.
/// Registers are defined as `inline constexpr` variables, matching their hardware addresses.
///
/// Example:
/// @code{.cpp}
/// // Set video mode 3, enable BG2
/// gba::reg_dispcnt = { .video_mode = 3, .enable_bg2 = true };
/// @endcode
///
/// TONCLIB/LIBTONC Equivalent:
/// @code{.c}
/// REG_DISPCNT = DCNT_MODE3 | DCNT_BG2;
/// @endcode
#pragma once

#include <gba/bits/registral_ops.hpp>
#include <gba/fixed_point>
#include <gba/memory>

#include <algorithm>
#include <concepts>
#include <cstdint>
#include <type_traits>
#include <utility>

namespace gba {

    /// @brief Template for memory-mapped hardware registers.
    /// @tparam ValueType The type of the register (e.g., struct, integral, array).
    template<typename>
    struct registral {};

    /// @brief Concept for non-array, trivially copyable types.
    template<typename T>
    concept IsNonArrayTriviallyCopiable = !std::is_array_v<T> && std::is_trivially_copyable_v<T>;

    /// Register wrapper for non-array, trivially copyable types.
    ///
    /// Read-only if ValueType is const, write-only if volatile, read/write otherwise.
    ///
    /// @code{.cpp}
    /// gba::reg_dispcnt = { .video_mode = 3 };
    /// auto value = gba::reg_dispcnt;
    /// @endcode
    ///
    /// @par tonclib equivalent
    /// @code{.c}
    /// REG_DISPCNT = DCNT_MODE3;
    /// u16 value = REG_DISPCNT;
    /// @endcode
    template<IsNonArrayTriviallyCopiable ValueType>
    struct registral<ValueType>
        : std::conditional_t<std::is_const_v<ValueType>,
                             std::conditional_t<std::is_volatile_v<ValueType>, void, bits::read_ops>,
                             std::conditional_t<std::is_volatile_v<ValueType>, bits::write_ops, bits::read_write_ops>> {
        friend bits::read_ops;
        friend bits::write_ops;
        friend bits::read_write_ops;

        using value_type = std::remove_cvref_t<ValueType>;

        registral(const registral&) = default;
        explicit constexpr registral(const std::uintptr_t address) noexcept : m_address{address} {}

        [[gnu::always_inline]]
        explicit(false) operator value_type() const noexcept
            requires std::derived_from<registral, bits::read_ops>
        {
            return this->value();
        }

        [[gnu::always_inline]]
        const registral& operator=(value_type&& value) const noexcept
            requires std::derived_from<registral, bits::write_ops>
        { // NOLINT(*-unconventional-assign-operator)
            bits::write_ops::write(static_cast<value_type&&>(value));
            return *this;
        }

        [[gnu::always_inline]]
        const registral& operator=(const value_type& value) const noexcept
            requires std::derived_from<registral, bits::write_ops>
        { // NOLINT(*-unconventional-assign-operator)
            bits::write_ops::write(value);
            return *this;
        }

        /// Assign an integer value directly (for non-integral, non-fixed_point register types).
        [[gnu::always_inline]]
        const registral& operator=(std::integral auto&& value) const noexcept
            requires(std::derived_from<registral, bits::write_ops> && !std::integral<value_type> &&
                     !fixed_point<value_type>)
        { // NOLINT(*-unconventional-assign-operator)
            bits::write_ops::write_integer(static_cast<decltype(value)&&>(value));
            return *this;
        }

        /// Convert to a read-only register view.
        explicit(false) constexpr operator registral<const value_type>() const noexcept
            requires std::derived_from<registral, bits::read_write_ops>
        {
            return {m_address};
        }

        /// Convert to a write-only register view.
        explicit(false) constexpr operator gba::registral<volatile value_type>() const noexcept
            requires std::derived_from<registral, bits::read_write_ops>
        {
            return {m_address};
        }

    private:
        std::uintptr_t m_address;
    };

    /// @brief Get a raw pointer to the memory-mapped register.
    /// @param r The register wrapper.
    /// @return A pointer to the register's memory address.
    ///
    /// Example:
    /// @code{.cpp}
    /// auto* ptr = gba::memory_map(gba::reg_dispcnt);
    /// ptr->enable_bg2 = true;
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// volatile u16* ptr = &REG_DISPCNT;
    /// *ptr |= DCNT_BG2;
    /// @endcode
    template<IsNonArrayTriviallyCopiable ValueType>
    [[gnu::always_inline]]
    inline auto* memory_map(const registral<ValueType>& r) noexcept {
        return __builtin_bit_cast(std::remove_volatile_t<ValueType>*, r);
    }

    /// @brief Concept for arrays of trivially copyable types.
    template<typename T>
    concept IsArrayOfTriviallyCopiable = std::is_array_v<T> &&
                                         std::is_trivially_copyable_v<std::remove_cv_t<std::remove_extent_t<T>>>;

    /// @brief Register wrapper for arrays of trivially copyable types.
    ///
    /// Provides indexed access to hardware register arrays.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Access timer 0 reload register
    /// gba::reg_tmcnt_l[0] = 0xFFFF;
    /// // Iterate over all timer control registers
    /// for (auto tmcnt : gba::reg_tmcnt_h) { }
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// // Access timer 0 reload register
    /// REG_TM0D = 0xFFFF;
    /// // Iterate over all timers (manual loop)
    /// for (int i = 0; i < 4; i++) { }
    /// @endcode
    template<IsArrayOfTriviallyCopiable ValueType>
    struct registral<ValueType> {
        using value_type = std::remove_extent_t<ValueType>;
        using size_type = std::size_t;

        registral(const registral&) = default;

        /// @param address The memory-mapped register base address.
        /// @param stride Byte offset between consecutive elements (default: sizeof(value_type)).
        explicit constexpr registral(const std::uintptr_t address,
                                     const std::size_t stride = sizeof(value_type)) noexcept
            : m_address{address}, m_stride{stride} {}

        [[gnu::always_inline]]
        constexpr registral<value_type> operator[](const std::size_t index) const noexcept {
            return registral<value_type>{m_address + index * m_stride};
        }

        [[gnu::always_inline]] // NOLINT(*-unconventional-assign-operator)
        const registral& operator=(const std::initializer_list<std::remove_cv_t<value_type>>& ilist) const noexcept {
            std::copy(ilist.begin(), ilist.end(), begin());
            return *this;
        }

        /// Forward iterator for register arrays.
        template<typename IterValueType>
        struct iterator_impl {
            using value_type = IterValueType;
            using reference = registral<value_type>;
            using pointer = value_type*;
            using difference_type = std::ptrdiff_t;
            using iterator_category = std::forward_iterator_tag;
            using iterator_concept = std::forward_iterator_tag;

            reference operator*() const noexcept { return registral<value_type>{m_address}; }

            pointer operator->() const noexcept { return gba::memory_map(registral<value_type>{m_address}); }

            constexpr iterator_impl& operator++() noexcept {
                m_address += m_stride;
                return *this;
            }
            constexpr iterator_impl operator++(int) noexcept {
                iterator_impl temp = *this;
                ++*this;
                return temp;
            }
            constexpr iterator_impl& operator--() noexcept {
                m_address -= m_stride;
                return *this;
            }
            constexpr iterator_impl operator--(int) noexcept {
                iterator_impl temp = *this;
                --*this;
                return temp;
            }
            constexpr iterator_impl& operator+=(const difference_type offset) noexcept {
                m_address += m_stride * offset;
                return *this;
            }
            constexpr iterator_impl& operator-=(const difference_type offset) noexcept {
                m_address -= m_stride * offset;
                return *this;
            }
            constexpr iterator_impl operator+(const difference_type offset) const noexcept {
                return {m_address + m_stride * offset, m_stride};
            }
            constexpr iterator_impl operator-(const difference_type offset) const noexcept {
                return {m_address - m_stride * offset, m_stride};
            }
            constexpr difference_type operator-(const iterator_impl& other) const noexcept {
                return (m_address - other.m_address) / m_stride;
            }

            auto operator<=>(const iterator_impl& other) const noexcept = default;
            bool operator==(const iterator_impl& rhs) const noexcept { return m_address == rhs.m_address; }
            bool operator!=(const iterator_impl& rhs) const noexcept { return m_address != rhs.m_address; }

            constexpr iterator_impl(const std::uintptr_t address, const std::size_t stride) noexcept
                : m_address{address}, m_stride{stride} {}
            constexpr iterator_impl() noexcept : m_address{0}, m_stride{sizeof(value_type)} {}

        private:
            std::uintptr_t m_address;
            std::size_t m_stride;
        };

        using iterator = iterator_impl<value_type>;
        using const_iterator = iterator_impl<const value_type>;

        static consteval size_type size() noexcept { return sizeof(ValueType) / sizeof(value_type); }

        [[nodiscard]]
        constexpr iterator begin() const noexcept {
            return {m_address, m_stride};
        }
        [[nodiscard]]
        constexpr iterator end() const noexcept {
            return {m_address + m_stride * size(), m_stride};
        }
        [[nodiscard]]
        constexpr const_iterator cbegin() const noexcept {
            return {m_address, m_stride};
        }
        [[nodiscard]]
        constexpr const_iterator cend() const noexcept {
            return {m_address + m_stride * size(), m_stride};
        }

    private:
        std::uintptr_t m_address;
        std::size_t m_stride;
    };

    /// @brief Get a raw pointer to the memory-mapped register array.
    /// @param r The register array wrapper.
    /// @return A pointer to the register array's base address.
    ///
    /// Example:
    /// @code{.cpp}
    /// auto* ptr = gba::memory_map(gba::reg_bgcnt);
    /// ptr[0].priority = 1;
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// volatile u16* ptr = &REG_BG0CNT;
    /// ptr[0] = BG_PRIO(1);
    /// @endcode
    template<IsArrayOfTriviallyCopiable ValueType>
    [[gnu::always_inline]]
    inline auto* memory_map(const registral<ValueType>& r) noexcept {
        struct temp_type { // NOLINT(*-pro-type-member-init)
            std::remove_volatile_t<std::remove_extent_t<ValueType>>* address;
            int : 32;
        };
        return __builtin_bit_cast(temp_type, r).address;
    }

    /// @brief Cast a register to a different type.
    /// @tparam To The target register type.
    /// @tparam From The source register type.
    /// @param r The source register.
    /// @return A registral wrapper with the target type at the same address.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Reinterpret DISPCNT as a raw u16
    /// auto raw = gba::registral_cast<unsigned short>(gba::reg_dispcnt);
    /// raw = 0x0403;
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_DISPCNT = 0x0403;
    /// @endcode
    template<typename To, IsNonArrayTriviallyCopiable From>
        requires(IsNonArrayTriviallyCopiable<To> || IsArrayOfTriviallyCopiable<To>)
    constexpr auto registral_cast(const registral<From>& r) noexcept {
        return registral<To>{__builtin_bit_cast(std::uintptr_t, r)};
    }

    /// @brief Cast an array register to a different array type.
    /// @tparam To The target array register type.
    /// @tparam From The source array register type.
    /// @param r The source register.
    /// @return A registral wrapper with the target type, preserving address and stride.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Reinterpret BGCNT array as raw u16 array
    /// auto raw = gba::registral_cast<unsigned short[4]>(gba::reg_bgcnt);
    /// raw[0] = 0x0080;
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_BG0CNT = 0x0080;
    /// @endcode
    template<IsArrayOfTriviallyCopiable To, IsArrayOfTriviallyCopiable From>
    constexpr auto registral_cast(const registral<From>& r) noexcept {
        struct {
            std::uintptr_t address;
            std::size_t stride;
        } temp = __builtin_bit_cast(decltype(temp), r);
        return registral<To>{temp.address, temp.stride};
    }

    /// @brief Cast an array register to a non-array type.
    /// @tparam To The target non-array register type.
    /// @tparam From The source array register type.
    /// @param r The source register.
    /// @return A registral wrapper with the target type at the base address.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Access the first BGCNT as a single register
    /// auto bg0cnt = gba::registral_cast<gba::background_control>(gba::reg_bgcnt);
    /// bg0cnt = { .priority = 1 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_BG0CNT = BG_PRIO(1);
    /// @endcode
    template<IsNonArrayTriviallyCopiable To, IsArrayOfTriviallyCopiable From>
    constexpr auto registral_cast(const registral<From>& r) noexcept {
        struct {
            std::uintptr_t address;
            std::size_t stride;
        } temp = __builtin_bit_cast(decltype(temp), r);
        return registral<To>{temp.address};
    }

    /// @brief Display control bitfield (DISPCNT, 0x4000000).
    ///
    /// Controls video mode, background/OBJ enables, and windowing.
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_dispcnt = { .video_mode = 3, .enable_bg2 = true };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_DISPCNT = DCNT_MODE3 | DCNT_BG2;
    /// @endcode
    struct display_control {
        unsigned short video_mode : 3; ///< Video mode (0-5)
        bool cgb                  : 1; ///< CGB mode flag (read-only)
        unsigned short page       : 1; ///< Page select for mode 4/5
        bool hblank_oam_free      : 1; ///< Allow OAM access during HBlank
        bool linear_obj_tilemap   : 1; ///< OBJ VRAM mapping (1D if true)
        bool disable              : 1; ///< Force blank display
        bool enable_bg0           : 1; ///< Enable BG0
        bool enable_bg1           : 1; ///< Enable BG1
        bool enable_bg2           : 1; ///< Enable BG2
        bool enable_bg3           : 1; ///< Enable BG3
        bool enable_obj           : 1; ///< Enable OBJ
        bool enable_win0          : 1; ///< Enable window 0
        bool enable_win1          : 1; ///< Enable window 1
        bool enable_obj_win       : 1; ///< Enable OBJ window
    };

    /// @brief Display control register (DISPCNT, 0x4000000).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_dispcnt = { .video_mode = 3, .enable_bg2 = true };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_DISPCNT = DCNT_MODE3 | DCNT_BG2;
    /// @endcode
    inline constexpr auto reg_dispcnt = registral<display_control>{0x4000000};

    namespace undocumented {
        /// @brief Stereo 3D enable register (0x4000002).
        ///
        /// Enables an unused stereo 3D display mode. Historically known as "GREENSWAP".
        /// Not considered "documented" by the community.
        ///
        /// Example:
        /// @code{.cpp}
        /// gba::undocumented::reg_stereo_3d = true;
        /// @endcode
        ///
        /// TONCLIB Equivalent:
        /// @code{.c}
        /// #define REG_GREENSWAP (*(volatile u16*)0x4000002)
        /// REG_GREENSWAP = 1;
        /// @endcode
        inline constexpr auto reg_stereo_3d = registral<bool>{0x4000002};
    } // namespace undocumented

    /// @brief Display status bitfield (DISPSTAT, 0x4000004).
    ///
    /// Provides VBlank/HBlank status and IRQ enables.
    struct display_status {
        const bool currently_vblank   : 1; ///< Currently in VBlank
        const bool currently_hblank   : 1; ///< Currently in HBlank
        const bool currently_vcount   : 1; ///< VCount match flag
        bool enable_irq_vblank        : 1; ///< Enable VBlank IRQ
        bool enable_irq_hblank        : 1; ///< Enable HBlank IRQ
        bool enable_irq_vcount        : 1; ///< Enable VCount IRQ
        short                         : 2;
        unsigned short vcount_setting : 8; ///< VCount trigger value
    };

    /// @brief Display status register (DISPSTAT, 0x4000004).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_dispstat = { .enable_irq_vblank = true };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_DISPSTAT = DSTAT_VBL_IRQ;
    /// @endcode
    inline constexpr auto reg_dispstat = registral<display_status>{0x4000004};

    /// @brief Vertical counter register (VCOUNT, 0x4000006). Read-only, returns current scanline.
    ///
    /// Example:
    /// @code{.cpp}
    /// while (gba::reg_vcount < 160) { }
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// while (REG_VCOUNT < 160) { }
    /// @endcode
    inline constexpr auto reg_vcount = registral<const unsigned short>{0x4000006};

    /// @brief Background control bitfield (BGCNT).
    ///
    /// Controls priority, tile/map base, mosaic, color depth, and size.
    struct background_control {
        unsigned short priority    : 2; ///< BG priority (0 = highest)
        unsigned short charblock   : 2; ///< Character base block
        short                      : 2;
        bool mosaic                : 1; ///< Enable mosaic effect
        bool bpp8                  : 1; ///< 8bpp mode (false = 4bpp)
        unsigned short screenblock : 5; ///< Screen base block
        bool wrap_affine_tiles     : 1; ///< Wrap for affine BGs
        unsigned short size        : 2; ///< BG size
    };

    /// @brief Background control registers (BG0CNT-BG3CNT, 0x4000008-0x400000F).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_bgcnt[0] = { .screenblock = 31, .charblock = 0 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_BG0CNT = BG_SBB(31) | BG_CBB(0);
    /// @endcode
    inline constexpr auto reg_bgcnt = registral<background_control[4]>{0x4000008};

    /// @brief Background scroll offset registers (write-only).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_bgofs[0][0] = 8; // BG0 X offset
    /// gba::reg_bgofs[0][1] = 4; // BG0 Y offset
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_BG0HOFS = 8;
    /// REG_BG0VOFS = 4;
    /// @endcode
    inline constexpr auto reg_bgofs = registral<volatile short[4][2]>{0x4000010};

    /// @brief Affine BG rotation/scaling parameters (write-only).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_bgp[0][0] = 1.0_fx; // BG2 PA = 1.0
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_BG2PA = 0x0100; // 1.0 in 8.8 fixed-point
    /// @endcode
    inline constexpr auto reg_bgp = registral<volatile fixed<short>[2][4]>{0x4000020};

    /// @brief Affine BG reference point X (write-only).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_bgx[0] = 120.0_fx; // BG2 X reference
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_BG2X = 120 << 8;
    /// @endcode
    inline constexpr auto reg_bgx = registral<volatile fixed<int, 8>[2]>{0x4000028, 0x10};

    /// @brief Affine BG reference point Y (write-only).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_bgy[0] = 80.0_fx; // BG2 Y reference
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_BG2Y = 80 << 8;
    /// @endcode
    inline constexpr auto reg_bgy = registral<volatile fixed<int, 8>[2]>{0x400002C, 0x10};

    /// @brief Affine background transformation matrix.
    ///
    /// Used for rotation/scaling of BG2/BG3 in affine modes.
    struct background_matrix { // NOLINT(*-pro-type-member-init)
        fixed<short> p[4];     ///< Matrix coefficients (pa, pb, pc, pd)
        fixed<int, 8> x;       ///< Reference point X
        fixed<int, 8> y;       ///< Reference point Y
    };

    /// @brief Affine BG matrix registers (BG2/BG3).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_bg_affine[0] = { .p = {1.0_fx, 0.0_fx, 0.0_fx, 1.0_fx}, .x = 0.0_fx, .y = 0.0_fx };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_BG2PA = 0x0100; REG_BG2PB = 0; REG_BG2PC = 0; REG_BG2PD = 0x0100;
    /// REG_BG2X = 0; REG_BG2Y = 0;
    /// @endcode
    inline constexpr auto reg_bg_affine = registral<volatile background_matrix[2]>{0x4000020};

    /// @brief Window horizontal dimensions (write-only).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_winh[0] = 240; // WIN0 right edge
    /// gba::reg_winh[1] = 0;   // WIN0 left edge
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_WIN0H = WIN_BUILD(0, 240);
    /// @endcode
    inline constexpr auto reg_winh = registral<volatile unsigned char[2]>{0x4000040};

    /// @brief Window vertical dimensions (write-only).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_winv[0] = 160; // WIN0 bottom edge
    /// gba::reg_winv[1] = 0;   // WIN0 top edge
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_WIN0V = WIN_BUILD(0, 160);
    /// @endcode
    inline constexpr auto reg_winv = registral<volatile unsigned char[2]>{0x4000044};

    /// @brief Window control bitfield.
    ///
    /// Controls which layers are visible inside a window.
    struct window_control {
        bool enable_bg0          : 1; ///< Show BG0
        bool enable_bg1          : 1; ///< Show BG1
        bool enable_bg2          : 1; ///< Show BG2
        bool enable_bg3          : 1; ///< Show BG3
        bool enable_obj          : 1; ///< Show OBJ
        bool enable_color_effect : 1; ///< Enable color effects
    };

    /// @brief Window inside control (WIN0IN, WIN1IN).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_winin[0] = { .enable_bg0 = true, .enable_obj = true };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_WININ = WIN_BG0 | WIN_OBJ;
    /// @endcode
    inline constexpr auto reg_winin = registral<window_control[2]>{0x4000048};

    /// @brief Window outside control (WINOUT).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_winout = { .enable_bg1 = true };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_WINOUT = WIN_BG1;
    /// @endcode
    inline constexpr auto reg_winout = registral<window_control>{0x400004a};

    /// @brief OBJ window control (OBJWIN).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_winobj = { .enable_color_effect = true };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_WINOUT = (REG_WINOUT & 0xFF) | (WIN_BLD << 8);
    /// @endcode
    inline constexpr auto reg_winobj = registral<window_control>{0x400004b};

    /// @brief Mosaic control bitfield.
    ///
    /// Controls mosaic effect size for BG/OBJ.
    struct mosaic_control {
        unsigned char add_h : 4; ///< Horizontal stretch (0-15)
        unsigned char add_v : 4; ///< Vertical stretch (0-15)
    };

    /// @brief BG mosaic control register.
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::reg_mosaicbg = { .add_h = 3, .add_v = 3 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// REG_MOSAIC = MOS_BH(3) | MOS_BV(3);
    /// @endcode
    inline constexpr auto reg_mosaicbg = registral<mosaic_control>{0x400004c};

    /// @brief OBJ mosaic control register.
    ///
    /// Example:
