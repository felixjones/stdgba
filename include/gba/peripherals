    template<typename>
    struct registral {};

    template<typename T>
    concept IsNonArrayTriviallyCopiable = !std::is_array_v<T> && std::is_trivially_copyable_v<T>;

    template<IsNonArrayTriviallyCopiable ValueType>
    struct registral<ValueType> : std::conditional_t<std::is_const_v<ValueType>, std::conditional_t<std::is_volatile_v<ValueType>, void, bits::read_ops>, std::conditional_t<std::is_volatile_v<ValueType>, bits::write_ops, bits::read_write_ops>> {
        friend bits::read_ops;
        friend bits::write_ops;
        friend bits::read_write_ops;

        using value_type = std::remove_cvref_t<ValueType>;

        registral(const registral&) = default;

        explicit constexpr registral(const std::uintptr_t address) noexcept : m_address{address} {}

        [[gnu::always_inline]]
        // ReSharper disable once CppNonExplicitConversionOperator
        operator value_type() const noexcept requires std::derived_from<registral, bits::read_ops> { // NOLINT(*-explicit-constructor)
            return this->value();
        }

        [[gnu::always_inline]]
        const registral& operator=(value_type&& value) const noexcept requires std::derived_from<registral, bits::write_ops> { // NOLINT(*-unconventional-assign-operator)
            bits::write_ops::write(static_cast<value_type&&>(value));
            return *this;
        }

        [[gnu::always_inline]]
        const registral& operator=(const value_type& value) const noexcept requires std::derived_from<registral, bits::write_ops> { // NOLINT(*-unconventional-assign-operator)
            bits::write_ops::write(value);
            return *this;
        }

        [[gnu::always_inline]]
        const registral& operator=(std::integral auto&& value) const noexcept requires (std::derived_from<registral, bits::write_ops> && !std::integral<value_type> && !fixed_point<value_type>) { // NOLINT(*-unconventional-assign-operator)
            bits::write_ops::write_integer(static_cast<decltype(value)&&>(value));
            return *this;
        }

        // ReSharper disable once CppNonExplicitConversionOperator
        constexpr operator registral<const value_type>() const noexcept requires std::derived_from<registral, bits::read_write_ops> { // NOLINT(*-explicit-constructor)
            return {m_address};
        }

        // ReSharper disable once CppNonExplicitConversionOperator
        constexpr operator gba::registral<volatile value_type>() const noexcept requires std::derived_from<registral, bits::read_write_ops> { // NOLINT(*-explicit-constructor)
            return {m_address};
        }

    private:
        std::uintptr_t m_address;
    };

    template<IsNonArrayTriviallyCopiable ValueType>
    [[gnu::always_inline]]
    // ReSharper disable once CppRedundantInlineSpecifier
    inline auto* memory_map(const registral<ValueType>& r) noexcept {
        return __builtin_bit_cast(std::remove_volatile_t<ValueType>*, r);
    }

    template<typename T>
    concept IsArrayOfTriviallyCopiable = std::is_array_v<T> && std::is_trivially_copyable_v<std::remove_extent_t<T>>;

    template<IsArrayOfTriviallyCopiable ValueType> //TODO: Multidimensional stride support
    struct registral<ValueType> {
        using value_type = std::remove_extent_t<ValueType>;
        using size_type = std::size_t;

        registral(const registral&) = default;

        explicit constexpr registral(const std::uintptr_t address, const std::size_t stride = sizeof(value_type)) noexcept : m_address{address}, m_stride{stride} {}

        [[gnu::always_inline]]
        constexpr registral<value_type> operator[](const std::size_t index) const noexcept {
            return registral<value_type>{m_address + index * m_stride};
        }

        [[gnu::always_inline]]
        const registral& operator=(const std::initializer_list<std::remove_cv_t<value_type>>& ilist) const noexcept { // NOLINT(*-unconventional-assign-operator)
            std::copy(ilist.begin(), ilist.end(), begin());
            return *this;
        }

        template<typename IterValueType>
        struct iterator_impl {
            using value_type = IterValueType;
            using reference = registral<value_type>;
            using pointer = value_type*;
            using difference_type = std::ptrdiff_t;
            using iterator_category = std::forward_iterator_tag;
            using iterator_concept = std::forward_iterator_tag;

            reference operator*() const noexcept {
                return registral<value_type>{m_address};
            }

            pointer operator->() const noexcept {
                return gba::memory_map(registral<value_type>{m_address});
            }

            constexpr iterator_impl& operator++() noexcept { m_address += m_stride; return *this; }
            constexpr iterator_impl operator++(int) noexcept { iterator_impl temp = *this; ++*this; return temp; }
            constexpr iterator_impl& operator--() noexcept { m_address -= m_stride; return *this; }
            constexpr iterator_impl operator--(int) noexcept { iterator_impl temp = *this; --*this; return temp; }
            constexpr iterator_impl& operator+=(const difference_type offset) noexcept { m_address += m_stride * offset; return *this; }
            constexpr iterator_impl& operator-=(const difference_type offset) noexcept { m_address -= m_stride * offset; return *this; }
            constexpr iterator_impl operator+(const difference_type offset) const noexcept { return {m_address + m_stride * offset, m_stride}; }
            constexpr iterator_impl operator-(const difference_type offset) const noexcept { return {m_address - m_stride * offset, m_stride}; }
            constexpr difference_type operator-(const iterator_impl& other) const noexcept { return (m_address - other.m_address) / m_stride; }

            auto operator<=>(const iterator_impl& other) const noexcept = default;
            bool operator==(const iterator_impl& rhs) const noexcept { return m_address == rhs.m_address; }
            bool operator!=(const iterator_impl& rhs) const noexcept { return m_address != rhs.m_address; }

            constexpr iterator_impl(const std::uintptr_t address, const std::size_t stride) noexcept : m_address{address}, m_stride{stride} {}
            constexpr iterator_impl() noexcept : m_address{0}, m_stride{sizeof(value_type)} {}
        private:
            std::uintptr_t m_address;
            std::size_t m_stride;
        };

        using iterator = iterator_impl<value_type>;
        using const_iterator = iterator_impl<const value_type>;

        static consteval size_type size() noexcept {
            return sizeof(ValueType) / sizeof(value_type);
        }

        [[nodiscard]]
        constexpr iterator begin() const noexcept {
            return {m_address, m_stride};
        }
        [[nodiscard]]
        constexpr iterator end() const noexcept {
            return {m_address + m_stride * size(), m_stride};
        }
        [[nodiscard]]
        constexpr const_iterator cbegin() const noexcept {
            return {m_address, m_stride};
        }
        [[nodiscard]]
        constexpr const_iterator cend() const noexcept {
            return {m_address + m_stride * size(), m_stride};
        }
    private:
        std::uintptr_t m_address;
        std::size_t m_stride;
    };

    template<IsArrayOfTriviallyCopiable ValueType>
    [[gnu::always_inline]]
    // ReSharper disable once CppRedundantInlineSpecifier
    inline auto* memory_map(const registral<ValueType>& r) noexcept {
        struct temp_type {
            std::remove_volatile_t<std::remove_extent_t<ValueType>>* address;
            int : 32;
        };
        return __builtin_bit_cast(temp_type, r).address;
    }

    template<typename To, IsNonArrayTriviallyCopiable From> requires(IsNonArrayTriviallyCopiable<To> || IsArrayOfTriviallyCopiable<To>)
    constexpr auto registral_cast(const registral<From>& r) noexcept {
        return registral<To>{__builtin_bit_cast(std::uintptr_t, r)};
    }

    template<IsArrayOfTriviallyCopiable To, IsArrayOfTriviallyCopiable From>
    constexpr auto registral_cast(const registral<From>& r) noexcept {
        struct {
            std::uintptr_t address;
            std::size_t stride;
        } temp = __builtin_bit_cast(decltype(temp), r);
        return registral<To>{temp.address, temp.stride};
    }

    template<IsNonArrayTriviallyCopiable To, IsArrayOfTriviallyCopiable From>
    constexpr auto registral_cast(const registral<From>& r) noexcept {
        struct {
            std::uintptr_t address;
            std::size_t stride;
        } temp = __builtin_bit_cast(decltype(temp), r);
        return registral<To>{temp.address};
    }

