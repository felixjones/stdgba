    /// REG_DMA3CNT_H = DMA_ENABLE;
    /// @endcode
    inline constexpr auto reg_dmacnt_h = registral<dma_control[4]>{0x40000BA, 12};

    /**
     * @brief DMA transfer descriptor.
     *
     * Combines source, destination, count, and control for a DMA channel.
     * Static member functions provide factory methods for common configurations.
     *
     * Example:
     * @code{.cpp}
     * gba::reg_dma[3] = gba::dma::copy(src, dst, 256);
     * gba::reg_dma[3] = gba::dma::fill(&value, dst, 256);
     * gba::reg_dma[3] = gba::dma::on_vblank(oam_buffer, oam_mem, 128);
     * @endcode
     */
    struct dma {
        const void* source;      ///< Source address
        void* destination;       ///< Destination address
        unsigned short units;    ///< Number of units to transfer
        dma_control control;     ///< DMA control settings

        /**
         * @brief Create an immediate 32-bit copy configuration.
         *
         * @param src Source address.
         * @param dst Destination address.
         * @param count Number of 32-bit words to copy.
         * @return DMA configuration ready to assign to reg_dma[N].
         *
         * Example:
         * @code{.cpp}
         * gba::reg_dma[3] = gba::dma::copy(tile_data, vram, 256);
         * @endcode
         *
         * TONCLIB Equivalent:
         * @code{.c}
         * dma3_cpy(vram, tile_data, 256);
         * @endcode
         */
        [[nodiscard]]
        static constexpr dma copy(const void* src, void* dst, std::size_t count) noexcept {
            return {src, dst, static_cast<unsigned short>(count), {.dma_type = dma_type::word, .enable = true}};
        }

        /**
         * @brief Create an immediate 16-bit copy configuration.
         *
         * @param src Source address.
         * @param dst Destination address.
         * @param count Number of 16-bit halfwords to copy.
         * @return DMA configuration ready to assign to reg_dma[N].
         *
         * Example:
         * @code{.cpp}
         * gba::reg_dma[3] = gba::dma::copy16(palette_data, pal_mem, 256);
         * @endcode
         *
         * TONCLIB Equivalent:
         * @code{.c}
         * DMA_TRANSFER(pal_mem, palette_data, 256, 3, DMA_CPY16);
         * @endcode
         */
        [[nodiscard]]
        static constexpr dma copy16(const void* src, void* dst, std::size_t count) noexcept {
            return {src, dst, static_cast<unsigned short>(count), {.dma_type = dma_type::half, .enable = true}};
        }

        /**
         * @brief Create a 32-bit fill configuration.
         *
         * Fills destination with copies of the value at the source address.
         *
         * @param src Address of fill value (must remain valid during transfer).
         * @param dst Destination address.
         * @param count Number of 32-bit words to fill.
         * @return DMA configuration ready to assign to reg_dma[N].
         *
         * @warning The source address must remain valid until the transfer completes.
         *
         * Example:
         * @code{.cpp}
         * static constexpr unsigned int black = 0;
         * gba::reg_dma[3] = gba::dma::fill(&black, vram, 240*160/2);
         * @endcode
         *
         * TONCLIB Equivalent:
         * @code{.c}
         * dma3_fill(vram, 0, 240*160/2);
         * @endcode
         */
        [[nodiscard]]
        static constexpr dma fill(const void* src, void* dst, std::size_t count) noexcept {
            return {src, dst, static_cast<unsigned short>(count), {.src_op = src_op_fixed, .dma_type = dma_type::word, .enable = true}};
        }

        /**
         * @brief Create a 16-bit fill configuration.
         *
         * @param src Address of 16-bit fill value.
         * @param dst Destination address.
         * @param count Number of 16-bit halfwords to fill.
         * @return DMA configuration ready to assign to reg_dma[N].
         *
         * TONCLIB Equivalent:
         * @code{.c}
         * DMA_TRANSFER(dst, &fill_value, count, 3, DMA_FILL16);
         * @endcode
         */
        [[nodiscard]]
        static constexpr dma fill16(const void* src, void* dst, std::size_t count) noexcept {
            return {src, dst, static_cast<unsigned short>(count), {.src_op = src_op_fixed, .dma_type = dma_type::half, .enable = true}};
        }

        /**
         * @brief Create a VBlank-triggered repeating transfer.
         *
         * The DMA runs automatically at the start of each VBlank period.
         *
         * @param src Source address (must remain valid while active).
         * @param dst Destination address.
         * @param count Number of 32-bit words per transfer.
         * @return DMA configuration ready to assign to reg_dma[N].
         *
         * Example:
         * @code{.cpp}
         * gba::reg_dma[3] = gba::dma::on_vblank(oam_buffer, oam_mem, 128);
         * // ... game loop ...
         * gba::reg_dmacnt_h[3] = {};  // Stop
         * @endcode
         *
         * TONCLIB Equivalent:
         * @code{.c}
         * REG_DMA3SAD = (u32)oam_buffer;
         * REG_DMA3DAD = (u32)oam_mem;
         * REG_DMA3CNT = 128 | DMA_AT_VBLANK | DMA_REPEAT | DMA_32 | DMA_DST_RELOAD | DMA_ENABLE;
         * @endcode
         */
        [[nodiscard]]
        static constexpr dma on_vblank(const void* src, void* dst, std::size_t count) noexcept {
            return {src, dst, static_cast<unsigned short>(count), {.dest_op = dest_op_increment_reload, .repeat = true, .dma_type = dma_type::word, .dma_cond = dma_cond_vblank, .enable = true}};
        }

        /**
         * @brief Create an HBlank-triggered repeating transfer (HDMA).
         *
         * The DMA runs automatically at the start of each HBlank period.
         *
         * @param src Source address (table of values, one per scanline).
         * @param dst Destination address (typically a register).
         * @param count Number of 16-bit halfwords per HBlank (usually 1).
         * @return DMA configuration ready to assign to reg_dma[N].
         *
         * @note DMA0 has highest priority and is recommended for HDMA effects.
         *
         * Example:
         * @code{.cpp}
         * gba::reg_dma[0] = gba::dma::on_hblank(scroll_table, memory_map(gba::reg_bg0hofs), 1);
         * // ... game loop ...
         * gba::reg_dmacnt_h[0] = {};  // Stop
         * @endcode
         *
         * TONCLIB Equivalent:
         * @code{.c}
         * REG_DMA0SAD = (u32)scroll_table;
         * REG_DMA0DAD = (u32)&REG_BG0HOFS;
         * REG_DMA0CNT = 1 | DMA_AT_HBLANK | DMA_REPEAT | DMA_16 | DMA_DST_RELOAD | DMA_ENABLE;
         * @endcode
         */
        [[nodiscard]]
        static constexpr dma on_hblank(const void* src, void* dst, std::size_t count) noexcept {
            return {src, dst, static_cast<unsigned short>(count), {.dest_op = dest_op_increment_reload, .repeat = true, .dma_type = dma_type::half, .dma_cond = dma_cond_hblank, .enable = true}};
        }

        /**
         * @brief Create audio streaming configuration for FIFO A.
         *
         * Sets up continuous DMA to DirectSound FIFO A. Use with DMA1.
         *
         * @param samples Source PCM sample data.
         * @return DMA configuration ready to assign to reg_dma[1].
         *
         * Example:
         * @code{.cpp}
         * gba::reg_dma[1] = gba::dma::to_fifo_a(pcm_data);
         * @endcode
         *
         * TONCLIB Equivalent:
         * @code{.c}
         * REG_DMA1SAD = (u32)pcm_data;
         * REG_DMA1DAD = (u32)&REG_FIFO_A;
         * REG_DMA1CNT = 1 | DMA_DST_FIXED | DMA_REPEAT | DMA_32 | DMA_AT_FIFO | DMA_ENABLE;
         * @endcode
         */
        [[nodiscard]]
        static constexpr dma to_fifo_a(const void* samples) noexcept {
            return {samples, reinterpret_cast<void*>(0x40000A0), 1, {.dest_op = dest_op_fixed, .repeat = true, .dma_type = dma_type::word, .dma_cond = dma_cond_sound_fifo, .enable = true}};
        }

        /**
         * @brief Create audio streaming configuration for FIFO B.
         *
         * Sets up continuous DMA to DirectSound FIFO B. Use with DMA2.
         *
         * @param samples Source PCM sample data.
         * @return DMA configuration ready to assign to reg_dma[2].
         *
         * TONCLIB Equivalent:
         * @code{.c}
         * REG_DMA2SAD = (u32)pcm_data;
         * REG_DMA2DAD = (u32)&REG_FIFO_B;
         * REG_DMA2CNT = 1 | DMA_DST_FIXED | DMA_REPEAT | DMA_32 | DMA_AT_FIFO | DMA_ENABLE;
         * @endcode
         */
        [[nodiscard]]
        static constexpr dma to_fifo_b(const void* samples) noexcept {
            return {samples, reinterpret_cast<void*>(0x40000A4), 1, {.dest_op = dest_op_fixed, .repeat = true, .dma_type = dma_type::word, .dma_cond = dma_cond_sound_fifo, .enable = true}};
        }
    };

