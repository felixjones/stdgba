#pragma once

#include <gba/peripherals>

#include <functional>

namespace gba {

    struct key {
        explicit constexpr key(const int data) noexcept : m_data{data} {}

        constexpr key operator|(const key rhs) const noexcept {
            return key{m_data | rhs.m_data};
        }

        constexpr key& operator|=(const key rhs) noexcept {
            m_data |= rhs.m_data;
            return *this;
        }
    private:
        int m_data;
    };

    inline constexpr auto key_a = key{0x0001};
    inline constexpr auto key_b = key{0x0002};
    inline constexpr auto key_select = key{0x0004};
    inline constexpr auto key_start = key{0x0008};
    inline constexpr auto key_right = key{0x0010};
    inline constexpr auto key_left = key{0x0020};
    inline constexpr auto key_up = key{0x0040};
    inline constexpr auto key_down = key{0x0080};
    inline constexpr auto key_r = key{0x0100};
    inline constexpr auto key_l = key{0x0200};

    inline constexpr auto reset_combo = key_a | key_b | key_select | key_start;

    struct keypad {
        constexpr keypad& operator=(const key_control keys) noexcept {
            if consteval {
                const auto data = __builtin_bit_cast(short, keys);
                m_data ^= data; // Calculate difference with previous keys
                m_data <<= 16; // Shift into hi-half (mask)
                m_data |= data; // Lo-half is current keys
            } else {
                asm volatile (
                    "eor %[data], %[keys]\n" // m_data ^= keys
#if __thumb__
                    "lsl %[data], #16\n"     // m_data <<= 16
                    "orr %[data], %[keys]"   // m_data |= keys
#else
                    "orr %[data], %[keys], %[data], lsl #16"   // m_data = keys | (m_data << 16)
#endif
                    : [data]"+l"(m_data) : [keys]"l"(keys)
                );
            }
            return *this;
        }

        template<template<typename> typename LogicalOp = std::logical_and, typename... Keys> requires (std::same_as<key, Keys> && ...)
        [[nodiscard]]
        constexpr bool pressed(Keys... keys) const noexcept {
            const auto actual = m_data >> 16;
            const auto expected = (... | __builtin_bit_cast(int, keys));

            if constexpr (std::same_as<LogicalOp<void>, std::logical_and<>>) {
                const auto pressed = expected & actual;
                return pressed == expected && (m_data & pressed) == 0;
            } else if constexpr (std::same_as<LogicalOp<void>, std::logical_or<>>) {
                const auto pressed = expected & actual;
                return pressed && (m_data & pressed) == 0;
            } else if constexpr (std::same_as<LogicalOp<void>, std::logical_not<>>) {
                const auto pressed = ~expected & actual;
                return pressed && (m_data & pressed) == 0;
            } else {
                static_assert(false, "Unsupported logical operator");
                __builtin_unreachable();
            }
        }

        template<template<typename> typename LogicalOp = std::logical_and, typename... Keys> requires (std::same_as<key, Keys> && ...)
        [[nodiscard]]
        constexpr bool released(Keys... keys) const noexcept {
            const auto actual = m_data >> 16;
            const auto expected = (... | __builtin_bit_cast(int, keys));

            if constexpr (std::same_as<LogicalOp<void>, std::logical_and<>>) {
                const auto released = expected & actual;
                return released == expected && (m_data & released) == expected;
            } else if constexpr (std::same_as<LogicalOp<void>, std::logical_or<>>) {
                const auto released = expected & actual;
                return released && (m_data & released) != 0;
            } else if constexpr (std::same_as<LogicalOp<void>, std::logical_not<>>) {
                const auto released = ~expected & actual;
                return released && m_data & released;
            } else {
                static_assert(false, "Unsupported logical operator");
                __builtin_unreachable();
            }
        }

        template<template<typename> typename LogicalOp = std::logical_and, typename... Keys> requires (std::same_as<key, Keys> && ...)
        [[nodiscard]]
        constexpr bool held(Keys... keys) const noexcept {
            const auto expected = (... | __builtin_bit_cast(int, keys));

            if constexpr (std::same_as<LogicalOp<void>, std::logical_and<>>) {
                return (expected & m_data) == 0;
            } else if constexpr (std::same_as<LogicalOp<void>, std::logical_or<>>) {
                return (expected & m_data) != expected;
            } else if constexpr (std::same_as<LogicalOp<void>, std::logical_not<>>) {
                return (m_data & 0x3ff) != 0x3ff && (expected & m_data) == expected;
            } else {
                static_assert(false, "Unsupported logical operator");
                __builtin_unreachable();
            }
        }

        [[nodiscard]]
        constexpr int xaxis() const noexcept {
            int keys = m_data;
            keys = (keys << 26) >> 30; // Sign extend
#if defined(__thumb__)
            return (0 - keys) >> 1; // Optimize for register pressure
#else
            return (keys >> 1) - keys; // Optimize for code density
#endif
        }

        [[nodiscard]]
        constexpr int yaxis() const noexcept {
            int keys = m_data;
            keys = (keys << 24) >> 30; // Sign extend
#if defined(__thumb__)
            return (0 - keys) >> 1; // Optimize for register pressure
#else
            return (keys >> 1) - keys; // Optimize for code density
#endif
        }

        [[nodiscard]]
        constexpr int i_xaxis() const noexcept {
            int keys = m_data;
            keys = (keys << 26) >> 30; // Sign extend
#if defined(__thumb__)
            return (keys + 1) >> 1; // Optimize for register pressure
#else
            return keys - (keys >> 1); // Optimize for code density
#endif
        }

        [[nodiscard]]
        constexpr int i_yaxis() const noexcept {
            int keys = m_data;
            keys = (keys << 24) >> 30; // Sign extend
#if defined(__thumb__)
            return (keys + 1) >> 1; // Optimize for register pressure
#else
            return keys - (keys >> 1); // Optimize for code density
#endif
        }

        [[nodiscard]]
        constexpr int lraxis() const noexcept {
            int keys = m_data;
            keys = (keys << 22) >> 30; // Sign extend
#if defined(__thumb__)
            return (0 - keys) >> 1; // Optimize for register pressure
#else
            return (keys >> 1) - keys; // Optimize for code density
#endif
        }

        [[nodiscard]]
        constexpr int i_lraxis() const noexcept {
            int keys = m_data;
            keys = (keys << 22) >> 30; // Sign extend
#if defined(__thumb__)
            return (keys + 1) >> 1; // Optimize for register pressure
#else
            return keys - (keys >> 1); // Optimize for code density
#endif
        }

    private:
        int m_data{0x3ff};
    };

}
