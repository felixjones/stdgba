/// @file embed
/// @brief Compile-time asset embedding for the GBA.
///
/// Converts PPM (P6), TGA, and BDF files into GBA-ready pixel data,
/// palettes, tiles, tilemaps, and font bitmaps entirely at compile time.
/// Designed for use with C23 `#embed` or pre-generated byte arrays.
///
/// @section embed_formats Supported Formats
///
/// - **PPM (P6)**: Raw 24-bit RGB. Palette index 0 is transparent.
/// - **TGA**: All standard types - uncompressed and RLE, true-color
///   (15/16/24/32bpp), color-mapped, and grayscale. Alpha < 128 is
///   transparent (32bpp true-color, 16bpp with attribute bit).
/// - **BDF**: Bitmap Distribution Format fonts converted into glyph
///   metadata plus BIOS `BitUnPack`-compatible 1bpp bitmap rows.
///
/// Format is auto-detected from the file header.
///
/// @section embed_usage Usage
///
/// @code{.cpp}
/// #include <gba/embed>
///
/// // Mode 3 bitmap (flat 15-bit pixel array)
/// constexpr auto splash = gba::embed::bitmap15([] {
///     return std::to_array<unsigned char>({ #embed "splash.ppm" });
/// });
/// // splash.width, splash.height, splash.data
///
/// // 4bpp tiles + palette + tilemap
/// constexpr auto tileset = gba::embed::indexed4([] {
///     return std::to_array<unsigned char>({ #embed "tileset.ppm" });
/// });
/// // tileset.palette, tileset.tiles, tileset.map
///
/// // 4bpp tiles without deduplication (for sprites)
/// constexpr auto sprite = gba::embed::indexed4<gba::embed::dedup::none>([] {
///     return std::to_array<unsigned char>({ #embed "sprite.tga" });
/// });
/// // sprite.obj(tile_idx) - pre-filled regular OAM attributes
/// // sprite.obj_aff(tile_idx) - pre-filled affine OAM attributes
///
/// // 8bpp tiles + palette + tilemap
/// constexpr auto bg = gba::embed::indexed8([] {
///     return std::to_array<unsigned char>({ #embed "bg.tga" });
/// });
///
/// // BDF font -> glyph metadata + packed 1bpp rows
/// constexpr auto font = gba::embed::bdf([] {
///     return std::to_array<unsigned char>({ #embed "font.bdf" });
/// });
/// // font.glyph_or_default('A'), font.bitmap_data('A')
/// @endcode
///
/// TONCLIB Equivalent:
/// @code{.c}
/// // Use grit to convert at build time:
/// //   grit sprite.png -gB4 -mLs -ftc
/// #include "sprite.h"
/// @endcode

#ifndef GBA_EMBED
#define GBA_EMBED

#include <gba/bits/embed/bdf.hpp>
#include <gba/bits/embed/image.hpp>
#include <gba/bits/flipbook.hpp>
#include <gba/sprite>
#include <gba/video>

#include <array>
#include <cstddef>
#include <cstdint>

namespace gba::embed {

    /// @brief Tile deduplication mode for indexed tile converters.
    ///
    /// Controls how `indexed4` and `indexed8` handle duplicate tiles.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Background: deduplicate with flip detection (default)
    /// constexpr auto bg = gba::embed::indexed4(supplier);
    ///
    /// // Sprite: no deduplication (sequential tiles for 1D mapping)
    /// constexpr auto spr = gba::embed::indexed4(supplier, gba::embed::dedup::none);
    /// @endcode
    enum class dedup {
        none,     ///< No deduplication (tiles stored sequentially)
        identity, ///< Deduplicate exact matches only
        flip,     ///< Deduplicate exact matches and horizontal/vertical flips
    };

    /// @brief Flat 15-bit color bitmap result (Mode 3).
    /// @tparam Width Image width in pixels.
    /// @tparam Height Image height in pixels.
    /// @tparam N Total pixel count.
    template<unsigned int Width, unsigned int Height, std::size_t N>
    struct bitmap15_result {
        static constexpr unsigned int width = Width;   ///< Image width in pixels
        static constexpr unsigned int height = Height; ///< Image height in pixels
        std::array<gba::color, N> data;
    };

    /// @brief 4bpp indexed tile result with palette and tilemap.
    /// @tparam Width Image width in pixels.
    /// @tparam Height Image height in pixels.
    /// @tparam PaletteSize Number of palette entries.
    /// @tparam TileCount Number of unique tiles.
    /// @tparam MapSize Number of screen entries in the tilemap.
    template<unsigned int Width, unsigned int Height, std::size_t PaletteSize, std::size_t TileCount,
             std::size_t MapSize>
    struct indexed4_result {
        static constexpr unsigned int width = Width;   ///< Image width in pixels
        static constexpr unsigned int height = Height; ///< Image height in pixels
        std::array<gba::color, PaletteSize> palette;   ///< Indexed palette (index 0 is transparent)
        gba::sprite4<Width, Height, TileCount> sprite; ///< Sprite tile payload with obj()/obj_aff() helpers
        std::array<gba::screen_entry, MapSize> map;    ///< Tilemap in screenblock order
    };

    /// @brief 8bpp indexed tile result with palette and tilemap.
    /// @tparam Width Image width in pixels.
    /// @tparam Height Image height in pixels.
    /// @tparam PaletteSize Number of palette entries.
    /// @tparam TileCount Number of unique tiles.
    /// @tparam MapSize Number of screen entries in the tilemap.
    template<unsigned int Width, unsigned int Height, std::size_t PaletteSize, std::size_t TileCount,
             std::size_t MapSize>
    struct indexed8_result {
        static constexpr unsigned int width = Width;   ///< Image width in pixels
        static constexpr unsigned int height = Height; ///< Image height in pixels
        std::array<gba::color, PaletteSize> palette;
        std::array<gba::tile8bpp, TileCount> tiles;
        std::array<gba::screen_entry, MapSize> map;

        /// @brief Create regular object attributes for this image.
        /// @param tile_idx Base tile index in OBJ VRAM (from gba::tile_index()).
        /// @return A gba::object with shape, size, depth, and tile_index filled in.
        ///
        /// Only valid when the image dimensions match a GBA sprite size.
        ///
        /// Example:
        /// @code{.cpp}
        /// constexpr auto sprite = gba::embed::indexed8<gba::embed::dedup::none>([] {
        ///     return std::to_array<unsigned char>({ #embed "sprite.tga" });
        /// });
        /// gba::obj_mem[0] = sprite.obj(0);
        /// @endcode
        [[nodiscard]]
        static constexpr gba::object obj(unsigned short tile_idx = 0) {
            static_assert(gba::bits::is_valid_sprite_size(Width, Height),
                          "Image dimensions do not match a valid GBA sprite size");
            return {.depth = depth_8bpp,
                    .shape = static_cast<gba::shape>(gba::bits::oam_shape_for(Width, Height)),
                    .size = static_cast<unsigned short>(gba::bits::oam_size_for(Width, Height)),
                    .tile_index = tile_idx};
        }

        /// @brief Create affine object attributes for this image.
        /// @param tile_idx Base tile index in OBJ VRAM (from gba::tile_index()).
        /// @return A gba::object_affine with affine, shape, size, depth, and tile_index filled in.
        ///
        /// Example:
        /// @code{.cpp}
        /// constexpr auto sprite = gba::embed::indexed8<gba::embed::dedup::none>([] {
        ///     return std::to_array<unsigned char>({ #embed "sprite.tga" });
        /// });
        /// gba::obj_aff_mem[0] = sprite.obj_aff(0);
        /// @endcode
        [[nodiscard]]
        static constexpr gba::object_affine obj_aff(unsigned short tile_idx = 0) {
            static_assert(gba::bits::is_valid_sprite_size(Width, Height),
                          "Image dimensions do not match a valid GBA sprite size");
            return {.depth = depth_8bpp,
                    .shape = static_cast<gba::shape>(gba::bits::oam_shape_for(Width, Height)),
                    .size = static_cast<unsigned short>(gba::bits::oam_size_for(Width, Height)),
                    .tile_index = tile_idx};
        }
    };

    /// @brief Convert an image to a flat 15-bit color array (Mode 3).
    ///
    /// Example:
    /// @code{.cpp}
    /// constexpr auto splash = gba::embed::bitmap15([] {
    ///     return std::to_array<unsigned char>({ #embed "splash.ppm" });
    /// });
    /// @endcode
    consteval auto bitmap15(auto supplier) {
        using raw_type = decltype(supplier());
        static constexpr auto size = std::tuple_size<raw_type>::value;
        static constexpr auto pixel_count = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            return h.width * h.height;
        }();
        static constexpr auto buf_size = size > pixel_count ? size : pixel_count;

        static constexpr auto oversized = [&supplier] consteval {
            const auto raw = supplier();
            const auto hdr = bits::parse_header(raw);
            struct result_type {
                unsigned int width, height;
                gba::color data[buf_size];
            } r{hdr.width, hdr.height, {}};
            if (hdr.is_png) {
                bool transparent[buf_size]{};
                bits::png_decode_all(raw, hdr.width, hdr.height, hdr.png_color_type, r.data, transparent);
                for (unsigned int i = 0; i < hdr.width * hdr.height; ++i)
                    if (transparent[i]) r.data[i] = {};
            } else if (hdr.is_tga) {
                bool transparent[buf_size]{};
                bits::tga_decode_all(raw, hdr, r.data, transparent);
                for (unsigned int i = 0; i < hdr.width * hdr.height; ++i)
                    if (transparent[i]) r.data[i] = {};
            } else {
                for (unsigned int y = 0; y < hdr.height; ++y)
                    for (unsigned int x = 0; x < hdr.width; ++x)
                        r.data[y * hdr.width + x] = bits::ppm_read_pixel(raw, hdr, x, y);
            }
            return r;
        }();

        constexpr auto n = oversized.width * oversized.height;
        bitmap15_result<oversized.width, oversized.height, n> result{};
        for (unsigned int i = 0; i < n; ++i) result.data[i] = oversized.data[i];
        return result;
    }

    /// @brief Convert an image to 4bpp tiles, palette, and tilemap.
    ///
    /// Palette index 0 is transparent. For PPM, the first color found
    /// becomes index 1. For TGA, pixels with alpha < 128 map to index 0.
    ///
    /// Image dimensions must be multiples of 8.
    ///
    /// @param supplier A callable returning a std::array<unsigned char, N>.
    /// @tparam Mode Tile deduplication mode (default: dedup::flip).
    ///
    /// Example:
    /// @code{.cpp}
    /// constexpr auto tileset = gba::embed::indexed4([] {
    ///     return std::to_array<unsigned char>({ #embed "tileset.ppm" });
    /// });
    ///
    /// constexpr auto sprite = gba::embed::indexed4<gba::embed::dedup::none>([] {
    ///     return std::to_array<unsigned char>({ #embed "sprite.tga" });
    /// });
    /// @endcode
    template<dedup Mode = dedup::flip>
    consteval auto indexed4(auto supplier) {
        using raw_type = decltype(supplier());
        static constexpr auto raw_size = std::tuple_size<raw_type>::value;
        static constexpr auto pixel_count = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            return h.width * h.height;
        }();
        static constexpr auto buf_size = raw_size > pixel_count ? raw_size : pixel_count;
        static constexpr auto map_buf_size = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            auto sb = ((h.width / 8 + 31) / 32) * ((h.height / 8 + 31) / 32);
            auto n = sb * 1024;
            return n > buf_size ? n : buf_size;
        }();

        static constexpr auto oversized = [&supplier] consteval {
            const auto raw = supplier();
            const auto hdr = bits::parse_header(raw);
            if (hdr.width % 8 != 0) throw "embed: image width must be a multiple of 8";
            if (hdr.height % 8 != 0) throw "embed: image height must be a multiple of 8";
            const auto ws = bits::build_indexed<buf_size>(raw, hdr);
            const auto tw_val = hdr.width / 8;
            const auto th_val = hdr.height / 8;

            struct result_type {
                unsigned int width, height;
                unsigned int palette_count;
                unsigned int tile_count;
                unsigned int map_w, map_h;
                gba::color palette[256];
                gba::tile4bpp tiles[buf_size];
                gba::screen_entry map[map_buf_size];
            } r{hdr.width, hdr.height, ws.palette_count, 0, tw_val, th_val, {}, {}, {}};

            unsigned int bank_count = 0;
            unsigned char bank_used[16]{};
            gba::color bank_palette[16][16]{};

            auto init_bank = [&](unsigned int bank) {
                bank_used[bank] = 1; // index 0 is transparent
                bank_palette[bank][0] = {};
            };

            auto find_in_bank = [&](unsigned int bank, gba::color c) {
                for (unsigned int i = 1; i < bank_used[bank]; ++i) {
                    if (bank_palette[bank][i] == c) {
                        return i;
                    }
                }
                return 0u;
            };

            // Build tiles inline
            for (unsigned int ty = 0; ty < th_val; ++ty) {
                for (unsigned int tx = 0; tx < tw_val; ++tx) {
                    unsigned char tile_colors[15]{};
                    unsigned int tile_color_count = 0;

                    for (unsigned int row = 0; row < 8; ++row) {
                        const unsigned int py = ty * 8 + row;
                        for (unsigned int col = 0; col < 8; ++col) {
                            const unsigned int px = tx * 8 + col;
                            const unsigned char idx = (px < ws.width && py < ws.height) ? ws.indices[py * ws.width + px]
                                                                                        : 0;
                            if (idx == 0) {
                                continue;
                            }

                            bool seen = false;
                            for (unsigned int i = 0; i < tile_color_count; ++i) {
                                if (tile_colors[i] == idx) {
                                    seen = true;
                                    break;
                                }
                            }
                            if (!seen) {
                                if (tile_color_count >= 15) {
                                    throw "embed::indexed4: tile uses more than 15 opaque colors";
                                }
                                tile_colors[tile_color_count++] = idx;
                            }
                        }
                    }

                    unsigned int tile_bank = 16;
                    unsigned int best_new_needed = 17;

                    for (unsigned int bank = 0; bank < bank_count; ++bank) {
                        unsigned int new_needed = 0;
                        for (unsigned int i = 0; i < tile_color_count; ++i) {
                            if (find_in_bank(bank, ws.palette[tile_colors[i]]) == 0) {
                                ++new_needed;
                            }
                        }
                        if (bank_used[bank] + new_needed <= 16 && new_needed < best_new_needed) {
                            best_new_needed = new_needed;
                            tile_bank = bank;
                        }
                    }

                    if (tile_bank == 16) {
                        if (bank_count >= 16) {
                            throw "embed::indexed4: image requires more than 16 palette banks";
                        }
                        tile_bank = bank_count++;
                        init_bank(tile_bank);
                    }

                    for (unsigned int i = 0; i < tile_color_count; ++i) {
                        if (find_in_bank(tile_bank, ws.palette[tile_colors[i]]) == 0) {
                            if (bank_used[tile_bank] >= 16) {
                                throw "embed::indexed4: selected palette bank overflow";
                            }
                            bank_palette[tile_bank][bank_used[tile_bank]++] = ws.palette[tile_colors[i]];
                        }
                    }

                    gba::tile4bpp tile{};
                    for (unsigned int row = 0; row < 8; ++row) {
                        unsigned int py = ty * 8 + row;
                        unsigned int word = 0;
                        for (unsigned int col = 0; col < 8; ++col) {
                            unsigned int px = tx * 8 + col;
                            unsigned char idx = (px < ws.width && py < ws.height) ? ws.indices[py * ws.width + px] : 0;
                            unsigned int local_idx = 0;
                            if (idx != 0) {
                                local_idx = find_in_bank(tile_bank, ws.palette[idx]);
                                if (local_idx == 0) {
                                    throw "embed::indexed4: internal palette bank mapping failed";
                                }
                            }
                            word |= (local_idx & 0xFu) << (col * 4);
                        }
                        tile[row] = word;
                    }

                    bool found = false;
                    if constexpr (Mode != dedup::none) {
                        for (unsigned int i = 0; i < r.tile_count && !found; ++i) {
                            const auto mi = bits::sb_index(tx, ty, tw_val);

                            bool match = true;
                            for (int rr = 0; rr < 8 && match; ++rr) match = r.tiles[i][rr] == tile[rr];
                            if (match) {
                                r.map[mi] = {.tile_index = static_cast<unsigned short>(i),
                                             .palette_index = static_cast<unsigned short>(tile_bank)};
                                found = true;
                                continue;
                            }

                            if constexpr (Mode == dedup::flip) {
                                match = true;
                                for (int rr = 0; rr < 8 && match; ++rr)
                                    match = bits::flip_nibbles(r.tiles[i][rr]) == tile[rr];
                                if (match) {
                                    r.map[mi] = {.tile_index = static_cast<unsigned short>(i),
                                                 .flip_horizontal = true,
                                                 .palette_index = static_cast<unsigned short>(tile_bank)};
                                    found = true;
                                    continue;
                                }

                                match = true;
                                for (int rr = 0; rr < 8 && match; ++rr) match = r.tiles[i][7 - rr] == tile[rr];
                                if (match) {
                                    r.map[mi] = {.tile_index = static_cast<unsigned short>(i),
                                                 .flip_vertical = true,
                                                 .palette_index = static_cast<unsigned short>(tile_bank)};
                                    found = true;
                                    continue;
                                }

                                match = true;
                                for (int rr = 0; rr < 8 && match; ++rr)
                                    match = bits::flip_nibbles(r.tiles[i][7 - rr]) == tile[rr];
                                if (match) {
                                    r.map[mi] = {.tile_index = static_cast<unsigned short>(i),
                                                 .flip_horizontal = true,
                                                 .flip_vertical = true,
                                                 .palette_index = static_cast<unsigned short>(tile_bank)};
                                    found = true;
                                    continue;
                                }
                            }
                        }
                    }

                    if (!found) {
                        r.tiles[r.tile_count] = tile;
                        r.map[bits::sb_index(tx, ty, tw_val)] = {
                            .tile_index = static_cast<unsigned short>(r.tile_count),
                            .palette_index = static_cast<unsigned short>(tile_bank)};
                        ++r.tile_count;
                    }
                }
            }

            r.palette_count = 1;
            for (unsigned int bank = 0; bank < bank_count; ++bank) {
                for (unsigned int i = 0; i < bank_used[bank]; ++i) {
                    const unsigned int dst = bank * 16 + i;
                    r.palette[dst] = bank_palette[bank][i];
                    if (dst + 1 > r.palette_count) {
                        r.palette_count = dst + 1;
                    }
                }
            }
            return r;
        }();

        constexpr auto mw = oversized.map_w;
        constexpr auto mh = oversized.map_h;
        constexpr auto sb_count = ((mw + 31) / 32) * ((mh + 31) / 32);
        indexed4_result<oversized.width, oversized.height, oversized.palette_count, oversized.tile_count,
                        sb_count * 1024>
            result{};
        for (unsigned int i = 0; i < oversized.palette_count; ++i) result.palette[i] = oversized.palette[i];
        for (unsigned int i = 0; i < oversized.tile_count; ++i) result.sprite.tiles[i] = oversized.tiles[i];
        for (unsigned int i = 0; i < sb_count * 1024; ++i) result.map[i] = oversized.map[i];
        return result;
    }

    /// @brief Convert an image to 8bpp tiles, palette, and tilemap.
    ///
    /// Same as `indexed4()` but with 8 bits per pixel (up to 256 colors).
    ///
    /// @param supplier A callable returning a std::array<unsigned char, N>.
    /// @tparam Mode Tile deduplication mode (default: dedup::flip).
    ///
    /// Example:
    /// @code{.cpp}
    /// constexpr auto bg = gba::embed::indexed8([] {
    ///     return std::to_array<unsigned char>({ #embed "bg.tga" });
    /// });
    /// @endcode
    template<dedup Mode = dedup::flip>
    consteval auto indexed8(auto supplier) {
        using raw_type = decltype(supplier());
        static constexpr auto raw_size = std::tuple_size<raw_type>::value;
        static constexpr auto pixel_count = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            return h.width * h.height;
        }();
        static constexpr auto buf_size = raw_size > pixel_count ? raw_size : pixel_count;
        static constexpr auto map_buf_size = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            auto sb = ((h.width / 8 + 31) / 32) * ((h.height / 8 + 31) / 32);
            auto n = sb * 1024;
            return n > buf_size ? n : buf_size;
        }();

        static constexpr auto oversized = [&supplier] consteval {
            const auto raw = supplier();
            const auto hdr = bits::parse_header(raw);
            if (hdr.width % 8 != 0) throw "embed: image width must be a multiple of 8";
            if (hdr.height % 8 != 0) throw "embed: image height must be a multiple of 8";
            const auto ws = bits::build_indexed<buf_size>(raw, hdr);
            const auto tw_val = hdr.width / 8;
            const auto th_val = hdr.height / 8;

            struct result_type {
                unsigned int width, height;
                unsigned int palette_count;
                unsigned int tile_count;
                unsigned int map_w, map_h;
                gba::color palette[256];
                gba::tile8bpp tiles[buf_size];
                gba::screen_entry map[map_buf_size];
            } r{hdr.width, hdr.height, ws.palette_count, 0, tw_val, th_val, {}, {}, {}};

            for (unsigned int i = 0; i < ws.palette_count; ++i) r.palette[i] = ws.palette[i];

            for (unsigned int ty = 0; ty < th_val; ++ty) {
                for (unsigned int tx = 0; tx < tw_val; ++tx) {
                    gba::tile8bpp tile{};
                    for (unsigned int row = 0; row < 8; ++row) {
                        unsigned int py = ty * 8 + row;
                        unsigned int word0 = 0, word1 = 0;
                        for (unsigned int col = 0; col < 4; ++col) {
                            unsigned int px = tx * 8 + col;
                            unsigned char idx = (px < ws.width && py < ws.height) ? ws.indices[py * ws.width + px] : 0;
                            word0 |= static_cast<unsigned int>(idx) << (col * 8);
                        }
                        for (unsigned int col = 4; col < 8; ++col) {
                            unsigned int px = tx * 8 + col;
                            unsigned char idx = (px < ws.width && py < ws.height) ? ws.indices[py * ws.width + px] : 0;
                            word1 |= static_cast<unsigned int>(idx) << ((col - 4) * 8);
                        }
                        tile[row * 2] = word0;
                        tile[row * 2 + 1] = word1;
                    }

                    bool found = false;
                    if constexpr (Mode != dedup::none) {
                        for (unsigned int i = 0; i < r.tile_count && !found; ++i) {
                            bool match = true;
                            for (int rr = 0; rr < 16 && match; ++rr) match = r.tiles[i][rr] == tile[rr];
                            if (match) {
                                r.map[bits::sb_index(tx, ty, tw_val)] = {.tile_index = static_cast<unsigned short>(i)};
                                found = true;
                            }
                        }
                    }

                    if (!found) {
                        r.tiles[r.tile_count] = tile;
                        r.map[bits::sb_index(tx, ty, tw_val)] = {
                            .tile_index = static_cast<unsigned short>(r.tile_count)};
                        ++r.tile_count;
                    }
                }
            }
            return r;
        }();

        constexpr auto mw = oversized.map_w;
        constexpr auto mh = oversized.map_h;
        constexpr auto sb_count = ((mw + 31) / 32) * ((mh + 31) / 32);
        indexed8_result<oversized.width, oversized.height, oversized.palette_count, oversized.tile_count,
                        sb_count * 1024>
            result{};
        for (unsigned int i = 0; i < oversized.palette_count; ++i) result.palette[i] = oversized.palette[i];
        for (unsigned int i = 0; i < oversized.tile_count; ++i) result.tiles[i] = oversized.tiles[i];
        for (unsigned int i = 0; i < sb_count * 1024; ++i) result.map[i] = oversized.map[i];
        return result;
    }

    /// @brief Row view into a sprite sheet - scoped flipbook builders for one row.
    ///
    /// Frame indices produced by `forward()`, `ping_pong()`, and `sequence()`
    /// are absolute (sheet-global), not row-relative, so they can be fed
    /// directly to `sheet4_result::tile_offset()`.
    template<unsigned int RowStart, unsigned int FrameCountInRow>
    struct row_view {
        template<unsigned int Start, unsigned int Count>
        static consteval auto forward() {
            static_assert(Start + Count <= FrameCountInRow, "Forward range exceeds row frame count");
            flipbook<Count> result{};
            for (unsigned int i = 0; i < Count; ++i) result.frames[i] = RowStart + Start + i;
            return result;
        }

        template<unsigned int Start, unsigned int Count>
        static consteval auto ping_pong() {
            static_assert(Start + Count <= FrameCountInRow, "Ping-pong range exceeds row frame count");
            static_assert(Count > 0, "Ping-pong requires at least one frame");
            constexpr auto N = Count > 1 ? Count * 2 - 2 : 1;
            flipbook<N> result{};
            for (unsigned int i = 0; i < Count; ++i) result.frames[i] = RowStart + Start + i;
            for (unsigned int i = 1; i + 1 < Count; ++i)
                result.frames[Count - 1 + i] = RowStart + Start + Count - 1 - i;
            return result;
        }

        template<bits::ct_string Seq>
        static consteval auto sequence() {
            constexpr auto len = decltype(Seq)::length;
            static_assert(len > 0, "Sequence string must not be empty");
            flipbook<len> result{};
            for (std::size_t i = 0; i < len; ++i) {
                char c = Seq.data[i];
                unsigned int idx;
                if (c >= '0' && c <= '9') idx = c - '0';
                else if (c >= 'a' && c <= 'z') idx = 10 + (c - 'a');
                else if (c >= 'A' && c <= 'Z') idx = 10 + (c - 'A');
                else throw "embed::sheet4: invalid character in row sequence string";
                if (idx >= FrameCountInRow) throw "embed::sheet4: frame index out of range for row";
                result.frames[i] = RowStart + idx;
            }
            return result;
        }
    };

    /// @brief 4bpp sprite sheet result - all frames share one palette bank,
    ///        tiles are packed in per-frame contiguous order for OBJ 1D mapping.
    ///
    /// @tparam FrameW     Frame width in pixels (must be a valid GBA sprite width).
    /// @tparam FrameH     Frame height in pixels (must be a valid GBA sprite height).
    /// @tparam Cols       Number of frame columns in the sheet.
    /// @tparam Rows       Number of frame rows in the sheet.
    /// @tparam PaletteSize Number of palette entries used (including transparent index 0).
    template<unsigned int FrameW, unsigned int FrameH, unsigned int Cols, unsigned int Rows, std::size_t PaletteSize>
    struct sheet4_result {
        static constexpr unsigned int frame_width = FrameW;
        static constexpr unsigned int frame_height = FrameH;
        static constexpr unsigned int columns = Cols;
        static constexpr unsigned int rows = Rows;
        static constexpr unsigned int frame_count = Cols * Rows;
        static constexpr unsigned int tiles_per_frame = (FrameW / 8u) * (FrameH / 8u);
        static constexpr std::size_t total_tiles = frame_count * tiles_per_frame;

        std::array<gba::color, PaletteSize> palette{};
        gba::sprite4<FrameW, FrameH, total_tiles> sprite{};

        /// @brief Tile offset (in tile count) for a given frame index.
        [[nodiscard]]
        static constexpr unsigned int tile_offset(unsigned int frame) noexcept {
            return frame * tiles_per_frame;
        }

        /// @brief Build a regular OAM object for a specific animation frame.
        /// @param base_tile  Tile index returned by uploading `sprite` to VRAM.
        /// @param frame      Frame index (0-based).
        /// @param pal_idx    OBJ palette bank (default 0).
        [[nodiscard]]
        static constexpr gba::object frame_obj(unsigned short base_tile, unsigned int frame,
                                               unsigned short pal_idx = 0) {
            return gba::sprite4<FrameW, FrameH>::obj(static_cast<unsigned short>(base_tile + frame * tiles_per_frame),
                                                     pal_idx);
        }

        /// @brief Build an affine OAM object for a specific animation frame.
        [[nodiscard]]
        static constexpr gba::object_affine frame_obj_aff(unsigned short base_tile, unsigned int frame,
                                                          unsigned short pal_idx = 0) {
            return gba::sprite4<FrameW, FrameH>::obj_aff(
                static_cast<unsigned short>(base_tile + frame * tiles_per_frame), pal_idx);
        }

        // -- Flipbook builders ----------------------------------------

        /// @brief Sequential frames: Start, Start+1, ..., Start+Count-1.
        template<unsigned int Start, unsigned int Count>
        static consteval auto forward() {
            static_assert(Start + Count <= frame_count, "Forward range exceeds frame count");
            flipbook<Count> result{};
            for (unsigned int i = 0; i < Count; ++i) result.frames[i] = Start + i;
            return result;
        }

        /// @brief Ping-pong: Start..Start+Count-1..Start+1. Length = 2??Count-2.
        template<unsigned int Start, unsigned int Count>
        static consteval auto ping_pong() {
            static_assert(Start + Count <= frame_count, "Ping-pong range exceeds frame count");
            static_assert(Count > 0, "Ping-pong requires at least one frame");
            constexpr auto N = Count > 1 ? Count * 2 - 2 : 1;
            flipbook<N> result{};
            for (unsigned int i = 0; i < Count; ++i) result.frames[i] = Start + i;
            for (unsigned int i = 1; i + 1 < Count; ++i) result.frames[Count - 1 + i] = Start + Count - 1 - i;
            return result;
        }

        /// @brief Custom frame sequence from a string literal.
        ///
        /// Each character selects a frame: '0'..'9' - 0..9, 'a'..'z' - 10..35.
        ///
        /// Example:
        /// @code{.cpp}
        /// static constexpr auto walk = sheet.sequence<"01232212">();
        /// @endcode
        template<bits::ct_string Seq>
        static consteval auto sequence() {
            constexpr auto len = decltype(Seq)::length;
            static_assert(len > 0, "Sequence string must not be empty");
            flipbook<len> result{};
            for (std::size_t i = 0; i < len; ++i) {
                char c = Seq.data[i];
                unsigned int idx;
                if (c >= '0' && c <= '9') idx = c - '0';
                else if (c >= 'a' && c <= 'z') idx = 10 + (c - 'a');
                else if (c >= 'A' && c <= 'Z') idx = 10 + (c - 'A');
                else throw "embed::sheet4: invalid character in sequence string";
                if (idx >= frame_count) throw "embed::sheet4: frame index out of range in sequence";
                result.frames[i] = idx;
            }
            return result;
        }

        /// @brief Get a row view for building row-scoped flipbooks.
        ///
        /// Example (RPG Maker 4??4 sheet):
        /// @code{.cpp}
        /// static constexpr auto down  = actor.row<0>();  // frames 0..3
        /// static constexpr auto left  = actor.row<1>();  // frames 4..7
        /// static constexpr auto walk  = down.ping_pong<0, 4>();
        /// @endcode
        template<unsigned int R>
        static consteval auto row() {
            static_assert(R < Rows, "Row index out of range");
            return row_view<R * Cols, Cols>{};
        }
    };

    // -- indexed4_sheet converter -------------------------------------

    /// @brief Convert a sprite sheet image to frame-ordered 4bpp tile data.
    ///
    /// Decodes a PPM/TGA image, validates that dimensions are exact multiples
    /// of `FrameW` ?? `FrameH`, builds a single -15-color palette (+ transparent
    /// index 0), and repacks tiles so each frame's tiles are contiguous in the
    /// output - ready for GBA OBJ 1D tile mapping.
    ///
    /// @tparam FrameW  Width of each animation frame (must be a valid GBA sprite width).
    /// @tparam FrameH  Height of each animation frame (must be a valid GBA sprite height).
    /// @param supplier A callable returning `std::array<unsigned char, N>` (image data).
    ///
    /// Example:
    /// @code{.cpp}
    /// static constexpr auto fish = gba::embed::indexed4_sheet<16, 16>([] {
    ///     return std::to_array<unsigned char>({ #embed "fish.tga" });
    /// });
    /// // fish.frame_count == 3 (for a 48??16 source)
    /// // fish.tiles_per_frame == 4 (for 16??16 frames)
    /// const auto base = upload(pool, fish.sprite);
    /// auto obj = fish.frame_obj(base, current_frame, palette_bank);
    ///
    /// static constexpr auto swim = fish.ping_pong<0, 3>();
    /// renderable.tile_index = base + swim.tile_offset(counter, fish.tiles_per_frame);
    /// @endcode
    template<unsigned int FrameW, unsigned int FrameH>
    consteval auto indexed4_sheet(auto supplier) {
        static_assert(gba::bits::is_valid_sprite_size(FrameW, FrameH),
                      "Frame dimensions must match a valid GBA sprite size");
        static_assert(FrameW % 8 == 0 && FrameH % 8 == 0, "Frame dimensions must be multiples of 8");

        using raw_type = decltype(supplier());
        static constexpr auto raw_size = std::tuple_size<raw_type>::value;
        static constexpr auto pixel_count = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            return h.width * h.height;
        }();
        static constexpr auto buf_size = raw_size > pixel_count ? raw_size : pixel_count;

        static constexpr auto oversized = [&supplier] consteval {
            const auto raw = supplier();
            const auto hdr = bits::parse_header(raw);

            if (hdr.width % FrameW != 0) throw "indexed4_sheet: image width is not a multiple of frame width";
            if (hdr.height % FrameH != 0) throw "indexed4_sheet: image height is not a multiple of frame height";

            const auto cols = hdr.width / FrameW;
            const auto rows = hdr.height / FrameH;
            const auto fc = cols * rows;
            const auto tpf = (FrameW / 8u) * (FrameH / 8u);
            const auto total_t = fc * tpf;

            struct result_type {
                unsigned int cols, rows;
                unsigned int pal_count;
                gba::color palette[16];
                gba::tile4bpp tiles[buf_size]; // oversized; only total_t entries used
            } r{cols, rows, 1, {}, {}};

            // Decode all pixels
            gba::color pixels[buf_size]{};
            bool transparent[buf_size]{};
            if (hdr.is_png) {
                bits::png_decode_all(raw, hdr.width, hdr.height, hdr.png_color_type, pixels, transparent);
            } else if (hdr.is_tga) {
                bits::tga_decode_all(raw, hdr, pixels, transparent);
            } else {
                for (unsigned int y = 0; y < hdr.height; ++y)
                    for (unsigned int x = 0; x < hdr.width; ++x)
                        pixels[y * hdr.width + x] = bits::ppm_read_pixel(raw, hdr, x, y);
            }

            // Build single -15-color palette (index 0 = transparent)
            r.palette[0] = {};
            for (unsigned int i = 0; i < hdr.width * hdr.height; ++i) {
                if (transparent[i]) continue;
                auto c = pixels[i];
                bool found = false;
                for (unsigned int j = 1; j < r.pal_count; ++j) {
                    if (r.palette[j] == c) {
                        found = true;
                        break;
                    }
                }
                if (!found) {
                    if (r.pal_count >= 16) throw "indexed4_sheet: sprite sheet has more than 15 opaque colors";
                    r.palette[r.pal_count++] = c;
                }
            }

            // Build per-pixel palette indices
            unsigned char indices[buf_size]{};
            for (unsigned int i = 0; i < hdr.width * hdr.height; ++i) {
                if (transparent[i]) {
                    indices[i] = 0;
                    continue;
                }
                auto c = pixels[i];
                for (unsigned int j = 1; j < r.pal_count; ++j) {
                    if (r.palette[j] == c) {
                        indices[i] = static_cast<unsigned char>(j);
                        break;
                    }
                }
            }

            // Build tiles in frame-contiguous order
            for (unsigned int fr = 0; fr < rows; ++fr) {
                for (unsigned int fc_col = 0; fc_col < cols; ++fc_col) {
                    const auto frame_idx = fr * cols + fc_col;
                    const auto tile_base = frame_idx * tpf;
                    for (unsigned int ty = 0; ty < FrameH / 8; ++ty) {
                        for (unsigned int tx = 0; tx < FrameW / 8; ++tx) {
                            const auto ti = tile_base + ty * (FrameW / 8) + tx;
                            gba::tile4bpp tile{};
                            for (unsigned int row = 0; row < 8; ++row) {
                                const unsigned int py = fr * FrameH + ty * 8 + row;
                                unsigned int word = 0;
                                for (unsigned int col = 0; col < 8; ++col) {
                                    const unsigned int px = fc_col * FrameW + tx * 8 + col;
                                    const auto pi = py * hdr.width + px;
                                    word |= (static_cast<unsigned int>(indices[pi]) & 0xFu) << (col * 4);
                                }
                                tile[row] = word;
                            }
                            r.tiles[ti] = tile;
                        }
                    }
                }
            }

            return r;
        }();

        constexpr auto cols = oversized.cols;
        constexpr auto rows = oversized.rows;
        constexpr auto fc = cols * rows;
        constexpr auto tpf = (FrameW / 8u) * (FrameH / 8u);
        constexpr auto total_t = fc * tpf;

        sheet4_result<FrameW, FrameH, cols, rows, oversized.pal_count> result{};
        for (unsigned int i = 0; i < oversized.pal_count; ++i) result.palette[i] = oversized.palette[i];
        for (unsigned int i = 0; i < total_t; ++i) result.sprite.tiles[i] = oversized.tiles[i];
        return result;
    }

