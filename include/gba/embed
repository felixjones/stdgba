/// @file embed
/// @brief Compile-time image embedding for the GBA.
///
/// Converts PPM (P6) and TGA image files into GBA-ready pixel data,
/// palettes, tiles, and tilemaps entirely at compile time. Designed for
/// use with C23 `#embed` or pre-generated byte arrays.
///
/// @section embed_formats Supported Formats
///
/// - **PPM (P6)**: Raw 24-bit RGB. Palette index 0 is transparent.
/// - **TGA**: All standard types - uncompressed and RLE, true-color
///   (15/16/24/32bpp), color-mapped, and grayscale. Alpha < 128 is
///   transparent (32bpp true-color, 16bpp with attribute bit).
///
/// Format is auto-detected from the file header.
///
/// @section embed_usage Usage
///
/// @code{.cpp}
/// #include <gba/embed>
///
/// // Mode 3 bitmap (flat 15-bit pixel array)
/// constexpr auto splash = gba::embed::bitmap15([] {
///     return std::to_array<unsigned char>({ #embed "splash.ppm" });
/// });
/// // splash.width, splash.height, splash.data
///
/// // 4bpp tiles + palette + tilemap
/// constexpr auto tileset = gba::embed::indexed4([] {
///     return std::to_array<unsigned char>({ #embed "tileset.ppm" });
/// });
/// // tileset.palette, tileset.tiles, tileset.map
///
/// // 4bpp tiles without deduplication (for sprites)
/// constexpr auto sprite = gba::embed::indexed4<gba::embed::dedup::none>([] {
///     return std::to_array<unsigned char>({ #embed "sprite.tga" });
/// });
/// // sprite.obj(tile_idx) - pre-filled regular OAM attributes
/// // sprite.obj_aff(tile_idx) - pre-filled affine OAM attributes
///
/// // 8bpp tiles + palette + tilemap
/// constexpr auto bg = gba::embed::indexed8([] {
///     return std::to_array<unsigned char>({ #embed "bg.tga" });
/// });
/// @endcode
///
/// TONCLIB Equivalent:
/// @code{.c}
/// // Use grit to convert at build time:
/// //   grit sprite.png -gB4 -mLs -ftc
/// #include "sprite.h"
/// @endcode

#ifndef GBA_EMBED
#define GBA_EMBED

#include <gba/video>
#include <gba/sprite>

#include <array>
#include <cstddef>
#include <cstdint>

namespace gba::embed {

    /// @brief Tile deduplication mode for indexed tile converters.
    ///
    /// Controls how `indexed4` and `indexed8` handle duplicate tiles.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Background: deduplicate with flip detection (default)
    /// constexpr auto bg = gba::embed::indexed4(supplier);
    ///
    /// // Sprite: no deduplication (sequential tiles for 1D mapping)
    /// constexpr auto spr = gba::embed::indexed4(supplier, gba::embed::dedup::none);
    /// @endcode
    enum class dedup {
        none,     ///< No deduplication (tiles stored sequentially)
        identity, ///< Deduplicate exact matches only
        flip,     ///< Deduplicate exact matches and horizontal/vertical flips
    };

    namespace bits {

        consteval gba::color to_gba_color(unsigned char r, unsigned char g, unsigned char b) {
            return {
                .red = static_cast<unsigned short>(r >> 3),
                .green = static_cast<unsigned short>(g >> 3),
                .blue = static_cast<unsigned short>(b >> 3),
                .grn_lo = static_cast<unsigned short>((g >> 2) & 1)
            };
        }

        consteval bool color_eq(gba::color a, gba::color b) {
            return a.red == b.red && a.green == b.green && a.blue == b.blue && a.grn_lo == b.grn_lo;
        }

        consteval bool is_ws(unsigned char c) {
            return c == ' ' || c == '\t' || c == '\n' || c == '\r';
        }

        consteval unsigned int parse_uint(const unsigned char* d, std::size_t size, std::size_t& pos) {
            while (pos < size && is_ws(d[pos])) ++pos;
            if (pos < size && d[pos] == '#')
                while (pos < size && d[pos] != '\n') ++pos;
            if (pos < size && is_ws(d[pos])) ++pos;
            unsigned int v = 0;
            while (pos < size && d[pos] >= '0' && d[pos] <= '9')
                v = v * 10 + (d[pos++] - '0');
            return v;
        }

        struct image_header {
            unsigned int width;
            unsigned int height;
            std::size_t pixel_offset; // PPM only: offset to raw RGB data
            bool is_tga;
            // TGA fields
            unsigned int tga_image_type;
            unsigned int tga_bpp;
            bool tga_origin_top;
            unsigned int tga_cmap_offset;
            unsigned int tga_cmap_length;
            unsigned int tga_cmap_bpp;
        };

        template<std::size_t Size>
        consteval image_header parse_header(const std::array<unsigned char, Size>& data) {
            if (Size >= 2 && data[0] == 'P' && data[1] == '6') {
                std::size_t pos = 2;
                auto w = parse_uint(data.data(), Size, pos);
                auto h = parse_uint(data.data(), Size, pos);
                auto maxval = parse_uint(data.data(), Size, pos);
                if (w == 0 || h == 0) throw "PPM: invalid dimensions";
                if (maxval != 255) throw "PPM: only maxval 255 supported";
                if (pos < Size && is_ws(data[pos])) ++pos;
                return {w, h, pos, false, 0, 24, false, 0, 0, 0};
            }
            if (Size >= 18) {
                unsigned int id_length = data[0];
                unsigned int cmap_type = data[1];
                unsigned int image_type = data[2];
                unsigned int cmap_origin = data[3] | (data[4] << 8);
                unsigned int cmap_length = data[5] | (data[6] << 8);
                unsigned int cmap_bpp = data[7];
                unsigned int w = data[12] | (data[13] << 8);
                unsigned int h = data[14] | (data[15] << 8);
                unsigned int bpp = data[16];
                bool top = (data[17] & 0x20) != 0;

                if (w == 0 || h == 0) throw "TGA: invalid dimensions";

                // Validate image type
                bool is_cmap = (image_type == 1 || image_type == 9);
                bool is_true = (image_type == 2 || image_type == 10);
                bool is_gray = (image_type == 3 || image_type == 11);
                if (!is_cmap && !is_true && !is_gray)
                    throw "TGA: unsupported image type";

                if (is_cmap && cmap_type != 1)
                    throw "TGA: color-mapped image requires color map";
                if (is_true && bpp != 15 && bpp != 16 && bpp != 24 && bpp != 32)
                    throw "TGA: unsupported true-color bit depth";
                if (is_gray && bpp != 8)
                    throw "TGA: grayscale must be 8bpp";
                if (is_cmap && bpp != 8 && bpp != 16)
                    throw "TGA: color-mapped index must be 8 or 16 bpp";

                std::size_t pixel_offset = 18 + id_length;
                unsigned int cmap_off = 0;
                if (cmap_type == 1) {
                    cmap_off = pixel_offset;
                    pixel_offset += cmap_length * ((cmap_bpp + 7) / 8);
                }

                return {w, h, pixel_offset, true, image_type, bpp, top,
                        cmap_off, cmap_length, cmap_bpp};
            }
            throw "embed: unrecognized image format";
        }

        // Decode a single TGA color from raw bytes at offset i
        template<std::size_t Size>
        consteval gba::color tga_decode_color(const std::array<unsigned char, Size>& data,
                                              std::size_t i, unsigned int bpp) {
            if (bpp == 32 || bpp == 24)
                return to_gba_color(data[i + 2], data[i + 1], data[i]);
            if (bpp == 16 || bpp == 15) {
                unsigned int v = data[i] | (data[i + 1] << 8);
                return {
                    .red = static_cast<unsigned short>(v & 0x1F),
                    .green = static_cast<unsigned short>((v >> 5) & 0x1F),
                    .blue = static_cast<unsigned short>((v >> 10) & 0x1F),
                    .grn_lo = 0
                };
            }
            // 8bpp grayscale
            auto g = data[i];
            return to_gba_color(g, g, g);
        }

        template<std::size_t Size>
        consteval bool tga_decode_alpha(const std::array<unsigned char, Size>& data,
                                        std::size_t i, unsigned int bpp) {
            if (bpp == 32) return data[i + 3] < 128;
            if (bpp == 16) return (data[i + 1] & 0x80) == 0; // bit 15 = alpha (0 = transparent)
            return false;
        }

        // Decode full TGA image into caller-provided pixel/transparency buffers
        template<std::size_t Size>
        consteval void tga_decode_all(const std::array<unsigned char, Size>& data,
                                      const image_header& hdr,
                                      gba::color* pixels, bool* transparent) {
            auto total = hdr.width * hdr.height;

            bool is_rle = (hdr.tga_image_type >= 9);
            bool is_cmap = (hdr.tga_image_type == 1 || hdr.tga_image_type == 9);
            bool has_alpha = (hdr.tga_bpp == 32) || (hdr.tga_bpp == 16 && !is_cmap);
            unsigned int cmap_entry_bytes = (hdr.tga_cmap_bpp + 7) / 8;
            unsigned int pixel_bytes = (hdr.tga_bpp + 7) / 8;

            std::size_t pos = hdr.pixel_offset;
            unsigned int pixel_idx = 0;

            auto decode_one = [&](std::size_t src) {
                if (pixel_idx >= total) return;
                unsigned int actual_y = hdr.tga_origin_top
                    ? (pixel_idx / hdr.width)
                    : (hdr.height - 1 - pixel_idx / hdr.width);
                unsigned int actual_x = pixel_idx % hdr.width;
                auto di = actual_y * hdr.width + actual_x;

                if (is_cmap) {
                    unsigned int ci = data[src];
                    if (pixel_bytes == 2) ci = data[src] | (data[src + 1] << 8);
                    auto cmap_pos = hdr.tga_cmap_offset + ci * cmap_entry_bytes;
                    pixels[di] = tga_decode_color(data, cmap_pos, hdr.tga_cmap_bpp);
                    transparent[di] = (hdr.tga_cmap_bpp == 32 || hdr.tga_cmap_bpp == 16)
                        ? tga_decode_alpha(data, cmap_pos, hdr.tga_cmap_bpp)
                        : false;
                } else {
                    pixels[di] = tga_decode_color(data, src, hdr.tga_bpp);
                    transparent[di] = has_alpha ? tga_decode_alpha(data, src, hdr.tga_bpp) : false;
                }
                ++pixel_idx;
            };

            if (is_rle) {
                while (pixel_idx < total && pos < Size) {
                    auto packet = data[pos++];
                    auto count = (packet & 0x7F) + 1;
                    if (packet & 0x80) {
                        auto src = pos;
                        pos += pixel_bytes;
                        for (unsigned int j = 0; j < count; ++j)
                            decode_one(src);
                    } else {
                        for (unsigned int j = 0; j < count; ++j) {
                            decode_one(pos);
                            pos += pixel_bytes;
                        }
                    }
                }
            } else {
                for (unsigned int j = 0; j < total; ++j) {
                    decode_one(pos);
                    pos += pixel_bytes;
                }
            }
        }

        // PPM pixel access (direct, no decoding needed)
        template<std::size_t Size>
        consteval gba::color ppm_read_pixel(const std::array<unsigned char, Size>& data,
                                            const image_header& hdr, unsigned int x, unsigned int y) {
            auto i = hdr.pixel_offset + (y * hdr.width + x) * 3;
            return to_gba_color(data[i], data[i + 1], data[i + 2]);
        }

        template<std::size_t MaxPixels>
        struct indexed_workspace {
            unsigned int width;
            unsigned int height;
            unsigned int palette_count;
            gba::color palette[256];
            unsigned char indices[MaxPixels];
        };

        template<std::size_t BufSize, std::size_t Size>
        consteval auto build_indexed(const std::array<unsigned char, Size>& data, const image_header& hdr) {
            indexed_workspace<BufSize> ws{};
            ws.width = hdr.width;
            ws.height = hdr.height;
            ws.palette_count = 1; // index 0 = transparent
            ws.palette[0] = {};

            if (hdr.is_tga) {
                gba::color pixels[BufSize]{};
                bool transparent[BufSize]{};
                tga_decode_all(data, hdr, pixels, transparent);
                for (unsigned int y = 0; y < hdr.height; ++y) {
                    for (unsigned int x = 0; x < hdr.width; ++x) {
                        auto pi = y * hdr.width + x;
                        if (transparent[pi]) { ws.indices[pi] = 0; continue; }
                        auto c = pixels[pi];
                        unsigned int idx = 0;
                        for (unsigned int i = 1; i < ws.palette_count; ++i) {
                            if (color_eq(ws.palette[i], c)) { idx = i; break; }
                        }
                        if (idx == 0) {
                            idx = ws.palette_count++;
                            if (idx >= 256) throw "embed: image has more than 256 unique colors";
                            ws.palette[idx] = c;
                        }
                        ws.indices[pi] = static_cast<unsigned char>(idx);
                    }
                }
            } else {
                for (unsigned int y = 0; y < hdr.height; ++y) {
                    for (unsigned int x = 0; x < hdr.width; ++x) {
                        auto pi = y * hdr.width + x;
                        auto c = ppm_read_pixel(data, hdr, x, y);
                        unsigned int idx = 0;
                        for (unsigned int i = 1; i < ws.palette_count; ++i) {
                            if (color_eq(ws.palette[i], c)) { idx = i; break; }
                        }
                        if (idx == 0) {
                            idx = ws.palette_count++;
                            if (idx >= 256) throw "embed: image has more than 256 unique colors";
                            ws.palette[idx] = c;
                        }
                        ws.indices[pi] = static_cast<unsigned char>(idx);
                    }
                }
            }
            return ws;
        }

        consteval unsigned int flip_nibbles(unsigned int word) {
            unsigned int out = 0;
            for (int c = 0; c < 8; ++c)
                out |= ((word >> (c * 4)) & 0xF) << ((7 - c) * 4);
            return out;
        }

        /// @brief Convert tile coordinates to GBA screenblock-order map index.
        ///
        /// The GBA stores wide/tall backgrounds as consecutive 32x32 screenblocks.
        /// For a 512x256 background (64x32 tiles), the layout is:
        ///   SB0 (columns 0-31), SB1 (columns 32-63)
        /// Each screenblock is 1024 entries in row-major order.
        consteval unsigned int sb_index(unsigned int tx, unsigned int ty, unsigned int map_w) {
            const auto sb_cols = (map_w + 31) / 32;
            const auto sb_x = tx / 32;
            const auto sb_y = ty / 32;
            return (sb_y * sb_cols + sb_x) * 1024 + (ty % 32) * 32 + (tx % 32);
        }

    } // namespace bits

    /// @brief Flat 15-bit color bitmap result (Mode 3).
    /// @tparam Width Image width in pixels.
    /// @tparam Height Image height in pixels.
    /// @tparam N Total pixel count.
    template<unsigned int Width, unsigned int Height, std::size_t N>
    struct bitmap15_result {
        static constexpr unsigned int width = Width;   ///< Image width in pixels
        static constexpr unsigned int height = Height; ///< Image height in pixels
        std::array<gba::color, N> data;
    };

    /// @brief 4bpp indexed tile result with palette and tilemap.
    /// @tparam Width Image width in pixels.
    /// @tparam Height Image height in pixels.
    /// @tparam PaletteSize Number of palette entries.
    /// @tparam TileCount Number of unique tiles.
    /// @tparam MapSize Number of screen entries in the tilemap.
    template<unsigned int Width, unsigned int Height, std::size_t PaletteSize, std::size_t TileCount, std::size_t MapSize>
    struct indexed4_result {
        static constexpr unsigned int width = Width;   ///< Image width in pixels
        static constexpr unsigned int height = Height; ///< Image height in pixels
        std::array<gba::color, PaletteSize> palette;   ///< Indexed palette (index 0 is transparent)
        gba::sprite4<Width, Height, TileCount> sprite; ///< Sprite tile payload with obj()/obj_aff() helpers
        std::array<gba::screen_entry, MapSize> map;    ///< Tilemap in screenblock order
    };

    /// @brief 8bpp indexed tile result with palette and tilemap.
    /// @tparam Width Image width in pixels.
    /// @tparam Height Image height in pixels.
    /// @tparam PaletteSize Number of palette entries.
    /// @tparam TileCount Number of unique tiles.
    /// @tparam MapSize Number of screen entries in the tilemap.
    template<unsigned int Width, unsigned int Height, std::size_t PaletteSize, std::size_t TileCount, std::size_t MapSize>
    struct indexed8_result {
        static constexpr unsigned int width = Width;   ///< Image width in pixels
        static constexpr unsigned int height = Height; ///< Image height in pixels
        std::array<gba::color, PaletteSize> palette;
        std::array<gba::tile8bpp, TileCount> tiles;
        std::array<gba::screen_entry, MapSize> map;

        /// @brief Create regular object attributes for this image.
        /// @param tile_idx Base tile index in OBJ VRAM (from gba::tile_index()).
        /// @return A gba::object with shape, size, depth, and tile_index filled in.
        ///
        /// Only valid when the image dimensions match a GBA sprite size.
        ///
        /// Example:
        /// @code{.cpp}
        /// constexpr auto sprite = gba::embed::indexed8<gba::embed::dedup::none>([] {
        ///     return std::to_array<unsigned char>({ #embed "sprite.tga" });
        /// });
        /// gba::obj_mem[0] = sprite.obj(0);
        /// @endcode
        [[nodiscard]]
        static constexpr gba::object obj(unsigned short tile_idx = 0) {
            static_assert(gba::bits::is_valid_sprite_size(Width, Height),
                "Image dimensions do not match a valid GBA sprite size");
            return {
                .depth = depth_8bpp,
                .shape = static_cast<gba::shape>(gba::bits::oam_shape_for(Width, Height)),
                .size = static_cast<unsigned short>(gba::bits::oam_size_for(Width, Height)),
                .tile_index = tile_idx
            };
        }

        /// @brief Create affine object attributes for this image.
        /// @param tile_idx Base tile index in OBJ VRAM (from gba::tile_index()).
        /// @return A gba::object_affine with affine, shape, size, depth, and tile_index filled in.
        ///
        /// Example:
        /// @code{.cpp}
        /// constexpr auto sprite = gba::embed::indexed8<gba::embed::dedup::none>([] {
        ///     return std::to_array<unsigned char>({ #embed "sprite.tga" });
        /// });
        /// gba::obj_aff_mem[0] = sprite.obj_aff(0);
        /// @endcode
        [[nodiscard]]
        static constexpr gba::object_affine obj_aff(unsigned short tile_idx = 0) {
            static_assert(gba::bits::is_valid_sprite_size(Width, Height),
                "Image dimensions do not match a valid GBA sprite size");
            return {
                .depth = depth_8bpp,
                .shape = static_cast<gba::shape>(gba::bits::oam_shape_for(Width, Height)),
                .size = static_cast<unsigned short>(gba::bits::oam_size_for(Width, Height)),
                .tile_index = tile_idx
            };
        }
    };

    /// @brief Convert an image to a flat 15-bit color array (Mode 3).
    ///
    /// Example:
    /// @code{.cpp}
    /// constexpr auto splash = gba::embed::bitmap15([] {
    ///     return std::to_array<unsigned char>({ #embed "splash.ppm" });
    /// });
    /// @endcode
    consteval auto bitmap15(auto supplier) {
        using raw_type = decltype(supplier());
        static constexpr auto size = std::tuple_size<raw_type>::value;
        static constexpr auto pixel_count = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            return h.width * h.height;
        }();
        static constexpr auto buf_size = size > pixel_count ? size : pixel_count;

        static constexpr auto oversized = [&supplier] consteval {
            const auto raw = supplier();
            const auto hdr = bits::parse_header(raw);
            struct result_type {
                unsigned int width, height;
                gba::color data[buf_size];
            } r{hdr.width, hdr.height, {}};
            if (hdr.is_tga) {
                bool transparent[buf_size]{};
                bits::tga_decode_all(raw, hdr, r.data, transparent);
                for (unsigned int i = 0; i < hdr.width * hdr.height; ++i)
                    if (transparent[i]) r.data[i] = {};
            } else {
                for (unsigned int y = 0; y < hdr.height; ++y)
                    for (unsigned int x = 0; x < hdr.width; ++x)
                        r.data[y * hdr.width + x] = bits::ppm_read_pixel(raw, hdr, x, y);
            }
            return r;
        }();

        constexpr auto n = oversized.width * oversized.height;
        bitmap15_result<oversized.width, oversized.height, n> result{};
        for (unsigned int i = 0; i < n; ++i)
            result.data[i] = oversized.data[i];
        return result;
    }

    /// @brief Convert an image to 4bpp tiles, palette, and tilemap.
    ///
    /// Palette index 0 is transparent. For PPM, the first color found
    /// becomes index 1. For TGA, pixels with alpha < 128 map to index 0.
    ///
    /// Image dimensions must be multiples of 8.
    ///
    /// @param supplier A callable returning a std::array<unsigned char, N>.
    /// @tparam Mode Tile deduplication mode (default: dedup::flip).
    ///
    /// Example:
    /// @code{.cpp}
    /// constexpr auto tileset = gba::embed::indexed4([] {
    ///     return std::to_array<unsigned char>({ #embed "tileset.ppm" });
    /// });
    ///
    /// constexpr auto sprite = gba::embed::indexed4<gba::embed::dedup::none>([] {
    ///     return std::to_array<unsigned char>({ #embed "sprite.tga" });
    /// });
    /// @endcode
    template<dedup Mode = dedup::flip>
    consteval auto indexed4(auto supplier) {
        using raw_type = decltype(supplier());
        static constexpr auto raw_size = std::tuple_size<raw_type>::value;
        static constexpr auto pixel_count = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            return h.width * h.height;
        }();
        static constexpr auto buf_size = raw_size > pixel_count ? raw_size : pixel_count;
        static constexpr auto map_buf_size = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            auto sb = ((h.width / 8 + 31) / 32) * ((h.height / 8 + 31) / 32);
            auto n = sb * 1024;
            return n > buf_size ? n : buf_size;
        }();

        static constexpr auto oversized = [&supplier] consteval {
            const auto raw = supplier();
            const auto hdr = bits::parse_header(raw);
            if (hdr.width % 8 != 0) throw "embed: image width must be a multiple of 8";
            if (hdr.height % 8 != 0) throw "embed: image height must be a multiple of 8";
            const auto ws = bits::build_indexed<buf_size>(raw, hdr);
            const auto tw_val = hdr.width / 8;
            const auto th_val = hdr.height / 8;

            struct result_type {
                unsigned int width, height;
                unsigned int palette_count;
                unsigned int tile_count;
                unsigned int map_w, map_h;
                gba::color palette[256];
                gba::tile4bpp tiles[buf_size];
                gba::screen_entry map[map_buf_size];
            } r{hdr.width, hdr.height, ws.palette_count, 0, tw_val, th_val, {}, {}, {}};

            unsigned int bank_count = 0;
            unsigned char bank_used[16]{};
            gba::color bank_palette[16][16]{};

            auto init_bank = [&](unsigned int bank) {
                bank_used[bank] = 1; // index 0 is transparent
                bank_palette[bank][0] = {};
            };

            auto find_in_bank = [&](unsigned int bank, gba::color c) {
                for (unsigned int i = 1; i < bank_used[bank]; ++i) {
                    if (bits::color_eq(bank_palette[bank][i], c)) {
                        return i;
                    }
                }
                return 0u;
            };

            // Build tiles inline
            for (unsigned int ty = 0; ty < th_val; ++ty) {
                for (unsigned int tx = 0; tx < tw_val; ++tx) {
                    unsigned char tile_colors[15]{};
                    unsigned int tile_color_count = 0;

                    for (unsigned int row = 0; row < 8; ++row) {
                        const unsigned int py = ty * 8 + row;
                        for (unsigned int col = 0; col < 8; ++col) {
                            const unsigned int px = tx * 8 + col;
                            const unsigned char idx = (px < ws.width && py < ws.height) ? ws.indices[py * ws.width + px] : 0;
                            if (idx == 0) {
                                continue;
                            }

                            bool seen = false;
                            for (unsigned int i = 0; i < tile_color_count; ++i) {
                                if (tile_colors[i] == idx) {
                                    seen = true;
                                    break;
                                }
                            }
                            if (!seen) {
                                if (tile_color_count >= 15) {
                                    throw "embed::indexed4: tile uses more than 15 opaque colors";
                                }
                                tile_colors[tile_color_count++] = idx;
                            }
                        }
                    }

                    unsigned int tile_bank = 16;
                    unsigned int best_new_needed = 17;

                    for (unsigned int bank = 0; bank < bank_count; ++bank) {
                        unsigned int new_needed = 0;
                        for (unsigned int i = 0; i < tile_color_count; ++i) {
                            if (find_in_bank(bank, ws.palette[tile_colors[i]]) == 0) {
                                ++new_needed;
                            }
                        }
                        if (bank_used[bank] + new_needed <= 16 && new_needed < best_new_needed) {
                            best_new_needed = new_needed;
                            tile_bank = bank;
                        }
                    }

                    if (tile_bank == 16) {
                        if (bank_count >= 16) {
                            throw "embed::indexed4: image requires more than 16 palette banks";
                        }
                        tile_bank = bank_count++;
                        init_bank(tile_bank);
                    }

                    for (unsigned int i = 0; i < tile_color_count; ++i) {
                        if (find_in_bank(tile_bank, ws.palette[tile_colors[i]]) == 0) {
                            if (bank_used[tile_bank] >= 16) {
                                throw "embed::indexed4: selected palette bank overflow";
                            }
                            bank_palette[tile_bank][bank_used[tile_bank]++] = ws.palette[tile_colors[i]];
                        }
                    }

                    gba::tile4bpp tile{};
                    for (unsigned int row = 0; row < 8; ++row) {
                        unsigned int py = ty * 8 + row;
                        unsigned int word = 0;
                        for (unsigned int col = 0; col < 8; ++col) {
                            unsigned int px = tx * 8 + col;
                            unsigned char idx = (px < ws.width && py < ws.height) ? ws.indices[py * ws.width + px] : 0;
                            unsigned int local_idx = 0;
                            if (idx != 0) {
                                local_idx = find_in_bank(tile_bank, ws.palette[idx]);
                                if (local_idx == 0) {
                                    throw "embed::indexed4: internal palette bank mapping failed";
                                }
                            }
                            word |= (local_idx & 0xFu) << (col * 4);
                        }
                        tile[row] = word;
                    }

                    bool found = false;
                    if constexpr (Mode != dedup::none) {
                        for (unsigned int i = 0; i < r.tile_count && !found; ++i) {
                            const auto mi = bits::sb_index(tx, ty, tw_val);

                            bool match = true;
                            for (int rr = 0; rr < 8 && match; ++rr) match = r.tiles[i][rr] == tile[rr];
                            if (match) {
                                r.map[mi] = {
                                    .tile_index = static_cast<unsigned short>(i),
                                    .palette_index = static_cast<unsigned short>(tile_bank)
                                };
                                found = true;
                                continue;
                            }

                            if constexpr (Mode == dedup::flip) {
                                match = true;
                                for (int rr = 0; rr < 8 && match; ++rr) match = bits::flip_nibbles(r.tiles[i][rr]) == tile[rr];
                                if (match) {
                                    r.map[mi] = {
                                        .tile_index = static_cast<unsigned short>(i),
                                        .flip_horizontal = true,
                                        .palette_index = static_cast<unsigned short>(tile_bank)
                                    };
                                    found = true;
                                    continue;
                                }

                                match = true;
                                for (int rr = 0; rr < 8 && match; ++rr) match = r.tiles[i][7 - rr] == tile[rr];
                                if (match) {
                                    r.map[mi] = {
                                        .tile_index = static_cast<unsigned short>(i),
                                        .flip_vertical = true,
                                        .palette_index = static_cast<unsigned short>(tile_bank)
                                    };
                                    found = true;
                                    continue;
                                }

                                match = true;
                                for (int rr = 0; rr < 8 && match; ++rr) match = bits::flip_nibbles(r.tiles[i][7 - rr]) == tile[rr];
                                if (match) {
                                    r.map[mi] = {
                                        .tile_index = static_cast<unsigned short>(i),
                                        .flip_horizontal = true,
                                        .flip_vertical = true,
                                        .palette_index = static_cast<unsigned short>(tile_bank)
                                    };
                                    found = true;
                                    continue;
                                }
                            }
                        }
                    }

                    if (!found) {
                        r.tiles[r.tile_count] = tile;
                        r.map[bits::sb_index(tx, ty, tw_val)] = {
                            .tile_index = static_cast<unsigned short>(r.tile_count),
                            .palette_index = static_cast<unsigned short>(tile_bank)
                        };
                        ++r.tile_count;
                    }
                }
            }

            r.palette_count = 1;
            for (unsigned int bank = 0; bank < bank_count; ++bank) {
                for (unsigned int i = 0; i < bank_used[bank]; ++i) {
                    const unsigned int dst = bank * 16 + i;
                    r.palette[dst] = bank_palette[bank][i];
                    if (dst + 1 > r.palette_count) {
                        r.palette_count = dst + 1;
                    }
                }
            }
            return r;
        }();

        constexpr auto mw = oversized.map_w;
        constexpr auto mh = oversized.map_h;
        constexpr auto sb_count = ((mw + 31) / 32) * ((mh + 31) / 32);
        indexed4_result<oversized.width, oversized.height, oversized.palette_count, oversized.tile_count, sb_count * 1024> result{};
        for (unsigned int i = 0; i < oversized.palette_count; ++i)
            result.palette[i] = oversized.palette[i];
        for (unsigned int i = 0; i < oversized.tile_count; ++i)
            result.sprite.tiles[i] = oversized.tiles[i];
        for (unsigned int i = 0; i < sb_count * 1024; ++i)
            result.map[i] = oversized.map[i];
        return result;
    }

    /// @brief Convert an image to 8bpp tiles, palette, and tilemap.
    ///
    /// Same as `indexed4()` but with 8 bits per pixel (up to 256 colors).
    ///
    /// @param supplier A callable returning a std::array<unsigned char, N>.
    /// @tparam Mode Tile deduplication mode (default: dedup::flip).
    ///
    /// Example:
    /// @code{.cpp}
    /// constexpr auto bg = gba::embed::indexed8([] {
    ///     return std::to_array<unsigned char>({ #embed "bg.tga" });
    /// });
    /// @endcode
    template<dedup Mode = dedup::flip>
    consteval auto indexed8(auto supplier) {
        using raw_type = decltype(supplier());
        static constexpr auto raw_size = std::tuple_size<raw_type>::value;
        static constexpr auto pixel_count = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            return h.width * h.height;
        }();
        static constexpr auto buf_size = raw_size > pixel_count ? raw_size : pixel_count;
        static constexpr auto map_buf_size = [&supplier] consteval {
            auto h = bits::parse_header(supplier());
            auto sb = ((h.width / 8 + 31) / 32) * ((h.height / 8 + 31) / 32);
            auto n = sb * 1024;
            return n > buf_size ? n : buf_size;
        }();

        static constexpr auto oversized = [&supplier] consteval {
            const auto raw = supplier();
            const auto hdr = bits::parse_header(raw);
            if (hdr.width % 8 != 0) throw "embed: image width must be a multiple of 8";
            if (hdr.height % 8 != 0) throw "embed: image height must be a multiple of 8";
            const auto ws = bits::build_indexed<buf_size>(raw, hdr);
            const auto tw_val = hdr.width / 8;
            const auto th_val = hdr.height / 8;

            struct result_type {
                unsigned int width, height;
                unsigned int palette_count;
                unsigned int tile_count;
                unsigned int map_w, map_h;
                gba::color palette[256];
                gba::tile8bpp tiles[buf_size];
                gba::screen_entry map[map_buf_size];
            } r{hdr.width, hdr.height, ws.palette_count, 0, tw_val, th_val, {}, {}, {}};

            for (unsigned int i = 0; i < ws.palette_count; ++i)
                r.palette[i] = ws.palette[i];

            for (unsigned int ty = 0; ty < th_val; ++ty) {
                for (unsigned int tx = 0; tx < tw_val; ++tx) {
                    gba::tile8bpp tile{};
                    for (unsigned int row = 0; row < 8; ++row) {
                        unsigned int py = ty * 8 + row;
                        unsigned int word0 = 0, word1 = 0;
                        for (unsigned int col = 0; col < 4; ++col) {
                            unsigned int px = tx * 8 + col;
                            unsigned char idx = (px < ws.width && py < ws.height) ? ws.indices[py * ws.width + px] : 0;
                            word0 |= static_cast<unsigned int>(idx) << (col * 8);
                        }
                        for (unsigned int col = 4; col < 8; ++col) {
                            unsigned int px = tx * 8 + col;
                            unsigned char idx = (px < ws.width && py < ws.height) ? ws.indices[py * ws.width + px] : 0;
                            word1 |= static_cast<unsigned int>(idx) << ((col - 4) * 8);
                        }
                        tile[row * 2] = word0;
                        tile[row * 2 + 1] = word1;
                    }

                    bool found = false;
                    if constexpr (Mode != dedup::none) {
                        for (unsigned int i = 0; i < r.tile_count && !found; ++i) {
                            bool match = true;
                            for (int rr = 0; rr < 16 && match; ++rr) match = r.tiles[i][rr] == tile[rr];
                            if (match) { r.map[bits::sb_index(tx, ty, tw_val)] = {.tile_index = static_cast<unsigned short>(i)}; found = true; }
                        }
                    }

                    if (!found) {
                        r.tiles[r.tile_count] = tile;
                        r.map[bits::sb_index(tx, ty, tw_val)] = {.tile_index = static_cast<unsigned short>(r.tile_count)};
                        ++r.tile_count;
                    }
                }
            }
            return r;
        }();

        constexpr auto mw = oversized.map_w;
        constexpr auto mh = oversized.map_h;
        constexpr auto sb_count = ((mw + 31) / 32) * ((mh + 31) / 32);
        indexed8_result<oversized.width, oversized.height, oversized.palette_count, oversized.tile_count, sb_count * 1024> result{};
        for (unsigned int i = 0; i < oversized.palette_count; ++i)
            result.palette[i] = oversized.palette[i];
        for (unsigned int i = 0; i < oversized.tile_count; ++i)
            result.tiles[i] = oversized.tiles[i];
        for (unsigned int i = 0; i < sb_count * 1024; ++i)
            result.map[i] = oversized.map[i];
        return result;
    }

}

