/// @file video
/// @brief GBA video memory abstractions and sprite/tile types.
///
/// This header provides C++ abstractions for GBA video memory regions including
/// palette RAM, VRAM, and OAM, as well as types for colors, tiles, and objects.
///
/// Example:
/// @code{.cpp}
/// // Set background color to red
/// gba::pal_bg_mem[0] = { .red = 31 };
/// // Create a simple sprite
/// gba::obj_mem[0] = { .x = 120, .y = 80, .tile_index = 0 };
/// // Create an affine sprite
/// gba::obj_aff_mem[1] = { .x = 60, .affine_index = 0 };
/// @endcode
///
/// TONCLIB Equivalent:
/// @code{.c}
/// pal_bg_mem[0] = RGB15(31, 0, 0);
/// obj_mem[0].attr0 = OBJ_Y(80);
/// obj_mem[0].attr1 = OBJ_X(120);
/// obj_mem[0].attr2 = 0;
/// @endcode
#pragma once

#include <gba/color>
#include <gba/peripherals>

#include <array>
#include <cstdint>

namespace gba {

    // Color and palette-memory APIs are provided by <gba/color>.

    /// Full VRAM (96KB). tonclib: `vid_mem`
    inline constexpr auto mem_vram = registral<short[0xC000]>{0x6000000};

    /// Background VRAM (64KB). tonclib: `vid_mem`
    inline constexpr auto mem_vram_bg = registral<short[0x8000]>{0x6000000};

    /// Object VRAM (32KB). tonclib: `tile_mem_obj`
    inline constexpr auto mem_vram_obj = registral<short[0x4000]>{0x6010000};

    /// @brief Object rendering mode.
    enum mode : short {
        mode_normal = 0, ///< Normal rendering
        mode_blend = 1,  ///< Alpha blending enabled
        mode_window = 2  ///< Object window mode
    };

    /// @brief Object/tile color depth.
    enum depth : short {
        depth_4bpp = 0, ///< 4 bits per pixel (16 colors)
        depth_8bpp = 1  ///< 8 bits per pixel (256 colors)
    };

    /// @brief Object shape.
    enum shape : short {
        shape_square = 0, ///< Square (size determines dimensions)
        shape_wide = 1,   ///< Wider than tall
        shape_tall = 2    ///< Taller than wide
    };

    /// @brief OAM object (sprite) entry for regular (non-affine) rendering.
    ///
    /// Represents a hardware sprite with position, appearance, and flip settings.
    /// Attr0 bit 8 is always 0 (regular mode).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::obj_mem[0] = { .y = 80, .x = 120, .tile_index = 0 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// obj_mem[0].attr0 = OBJ_Y(80);
    /// obj_mem[0].attr1 = OBJ_X(120);
    /// obj_mem[0].attr2 = 0;
    /// @endcode
    struct alignas(short) object {
        // Attribute 0
        unsigned short y : 8;      ///< Y coordinate (0-255)
        bool : 1;
        bool disable : 1;          ///< Disable object (hide)
        gba::mode mode : 2;        ///< Rendering mode
        bool mosaic : 1;           ///< Enable mosaic effect
        gba::depth depth : 1;      ///< Color depth (4bpp/8bpp)
        gba::shape shape : 2;      ///< Object shape

        // Attribute 1
        unsigned short x : 9;      ///< X coordinate (0-511)
        short : 3;
        bool flip_x : 1;           ///< Horizontal flip
        bool flip_y : 1;           ///< Vertical flip
        unsigned short size : 2;   ///< Size (combined with shape)

        // Attribute 2
        unsigned short tile_index : 10;   ///< Base tile index
        unsigned short background : 2;    ///< Priority relative to BG
        unsigned short palette_index : 4; ///< Palette bank (4bpp only)
    };

    static_assert(sizeof(object) == 6);

    /// @brief OAM object (sprite) entry for affine rendering.
    ///
    /// Represents a hardware sprite with position, appearance, and an affine
    /// transformation index. Attr0 bit 8 is always 1 (affine mode).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::obj_aff_mem[0] = { .y = 80, .x = 120, .affine_index = 0 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// obj_mem[0].attr0 = OBJ_Y(80) | ATTR0_AFF;
    /// obj_mem[0].attr1 = OBJ_X(120) | ATTR1_AFF_ID(0);
    /// obj_mem[0].attr2 = 0;
    /// @endcode
    struct alignas(short) object_affine {
        // Attribute 0
        unsigned short y : 8;           ///< Y coordinate (0-255)
        bool affine : 1 = true;         ///< Affine flag (always true)
        bool double_size : 1;           ///< Double rendering area for rotation
        gba::mode mode : 2;             ///< Rendering mode
        bool mosaic : 1;                ///< Enable mosaic effect
        gba::depth depth : 1;           ///< Color depth (4bpp/8bpp)
        gba::shape shape : 2;           ///< Object shape

        // Attribute 1
        unsigned short x : 9;           ///< X coordinate (0-511)
        unsigned short affine_index : 5;///< Affine parameter set index (0-31)
        unsigned short size : 2;        ///< Size (combined with shape)

        // Attribute 2
        unsigned short tile_index : 10;   ///< Base tile index
        unsigned short background : 2;    ///< Priority relative to BG
        unsigned short palette_index : 4; ///< Palette bank (4bpp only)
    };

    static_assert(sizeof(object_affine) == 6);

    /// @brief Raw OAM memory (128 entries as short arrays).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::mem_oam[0][0] = 0x0050; // Y=80
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// oam_mem[0].attr0 = 0x0050;
    /// @endcode
    inline constexpr auto mem_oam = registral<short[128][3]>{0x7000000, sizeof(short[4])};

    /// @brief OAM as typed regular object array.
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::obj_mem[0] = { .y = 80, .x = 120, .tile_index = 0 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// obj_set_attr(&obj_mem[0], OBJ_Y(80), OBJ_X(120), 0);
    /// @endcode
    inline constexpr auto obj_mem = registral_cast<object[128]>(mem_oam);

    /// @brief OAM as typed affine object array.
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::obj_aff_mem[0] = { .x = 120, .affine_index = 0 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// obj_mem[0].attr0 = OBJ_Y(0) | ATTR0_AFF;
    /// obj_mem[0].attr1 = OBJ_X(120) | ATTR1_AFF_ID(0);
    /// @endcode
    inline constexpr auto obj_aff_mem = registral_cast<object_affine[128]>(mem_oam);

    /// @brief Object affine parameters (all 128 interleaved).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::mem_obj_aff[0] = 1.0_fx; // PA of affine entry 0
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// obj_aff_mem[0].pa = 0x0100;
    /// @endcode
    inline constexpr auto mem_obj_aff = registral<fixed<short>[128]>{0x7000006, 8};

    /// Object affine PA parameters (32 entries). tonclib: `obj_aff_mem[n].pa`
    inline constexpr auto mem_obj_affa = registral<fixed<short>[32]>{0x7000006, 32};

    /// Object affine PB parameters (32 entries). tonclib: `obj_aff_mem[n].pb`
    inline constexpr auto mem_obj_affb = registral<fixed<short>[32]>{0x700000E, 32};

    /// Object affine PC parameters (32 entries). tonclib: `obj_aff_mem[n].pc`
    inline constexpr auto mem_obj_affc = registral<fixed<short>[32]>{0x7000016, 32};

    /// Object affine PD parameters (32 entries). tonclib: `obj_aff_mem[n].pd`
    inline constexpr auto mem_obj_affd = registral<fixed<short>[32]>{0x700001E, 32};

    /// @brief Calculate charblock index from a VRAM pointer.
    /// @param ptr Pointer to tile data in VRAM.
    /// @return The charblock index (0-3).
    ///
    /// Example:
    /// @code{.cpp}
    /// auto cbb = gba::char_map(tile_data_ptr);
    /// gba::reg_bgcnt[0] = { .charblock = cbb };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// // Manual calculation: ((u32)ptr - MEM_VRAM) / 0x4000
    /// @endcode
    namespace bits {

        constexpr auto byte_offset(const void* ptr, const void* base) noexcept {
            return reinterpret_cast<std::uintptr_t>(ptr) - reinterpret_cast<std::uintptr_t>(base);
        }

    }

    inline constexpr auto char_map(const void* ptr) noexcept {
        return static_cast<unsigned short>(bits::byte_offset(ptr, memory_map(gba::mem_vram_bg)) / 0x4000U);
    }

    /// @brief Calculate screenblock index from a VRAM pointer.
    /// @param ptr Pointer to tilemap data in VRAM.
    /// @return The screenblock index (0-31).
    ///
    /// Example:
    /// @code{.cpp}
    /// auto sbb = gba::screen_map(tilemap_ptr);
    /// gba::reg_bgcnt[0] = { .screenblock = sbb };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// // Manual calculation: ((u32)ptr - MEM_VRAM) / 0x800
    /// @endcode
    inline constexpr auto screen_map(const void* ptr) noexcept {
        return static_cast<unsigned short>(bits::byte_offset(ptr, memory_map(gba::mem_vram_bg)) / 0x800U);
    }

    /// @brief Calculate OAM tile index from an OBJ VRAM pointer.
    /// @param ptr Pointer into OBJ VRAM (0x6010000+).
    /// @return The tile index for use in object::tile_index / object_affine::tile_index.
    ///
    /// OAM tile indices are in units of 32 bytes (one 4bpp 8x8 tile).
    ///
    /// Example:
    /// @code{.cpp}
    /// auto* dest = gba::memory_map(gba::mem_vram_obj);
    /// std::memcpy(dest, sprite_a.data(), sprite_a.size());
    /// dest += sprite_a.size() / sizeof(*dest);
    /// std::memcpy(dest, sprite_b.data(), sprite_b.size());
    ///
    /// auto attr_a = sprite_a.obj;
    /// attr_a.tile_index = gba::tile_index(gba::memory_map(gba::mem_vram_obj));
    ///
    /// auto attr_b = sprite_b.obj;
    /// attr_b.tile_index = gba::tile_index(dest);
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// // Manual calculation: ((u32)ptr - MEM_VRAM_OBJ) / 32
    /// @endcode
    inline constexpr auto tile_index(const void* ptr) noexcept {
        return static_cast<unsigned short>(bits::byte_offset(ptr, memory_map(gba::mem_vram_obj)) / 32U);
    }

    /// @brief 4bpp tile type (32 bytes, 8x8 pixels at 4 bits each).
    using tile4bpp = std::array<unsigned int, 8>;

    /// @brief 8bpp tile type (64 bytes, 8x8 pixels at 8 bits each).
    using tile8bpp = std::array<unsigned int, 16>;

    /// @brief Tile memory as 4bpp tiles (4 charblocks of 512 tiles each).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::mem_tile_4bpp[0][0] = my_tile_data;
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// tile_mem[0][0] = my_tile_data;
    /// @endcode
    inline constexpr auto mem_tile_4bpp = registral<tile4bpp[512][4]>{0x6000000};

    /// @brief Tile memory as 8bpp tiles (4 charblocks of 256 tiles each).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::mem_tile_8bpp[0][0] = my_tile_data;
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// tile8_mem[0][0] = my_tile_data;
    /// @endcode
    inline constexpr auto mem_tile_8bpp = registral<tile8bpp[256][4]>{0x6000000};

    /// @brief Screen entry (tilemap entry).
    ///
    /// Represents a single tile reference in a background tilemap.
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::mem_se[0][0] = { .tile_index = 1, .flip_horizontal = true };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// se_mem[0][0] = SE_ID(1) | SE_HFLIP;
    /// @endcode
    struct alignas(short) screen_entry {
        unsigned short tile_index : 10;    ///< Tile index (0-1023)
        bool flip_horizontal : 1;          ///< Horizontal flip
        bool flip_vertical : 1;            ///< Vertical flip
        unsigned short palette_index : 4;  ///< Palette bank (4bpp only)
    };

    /// @brief Screen entry memory (32 screenblocks of 1024 entries each).
    ///
    /// Example:
    /// @code{.cpp}
    /// gba::mem_se[31][0] = { .tile_index = 0 };
    /// @endcode
    ///
    /// TONCLIB Equivalent:
    /// @code{.c}
    /// se_mem[31][0] = 0;
    /// @endcode
    inline constexpr auto mem_se = registral<screen_entry[1024][32]>{0x6000000};

}
