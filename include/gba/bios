/**
 * @brief Input parameters for BgAffineSet.
 *
 * Defines the transformation parameters for affine background calculation.
 */
struct background_parameters {
    fixed<int, 8> tex_x;  ///< Texture space center X (8.8 fixed-point).
    fixed<int, 8> tex_y;  ///< Texture space center Y (8.8 fixed-point).
    short scr_x;          ///< Screen space center X.
    short scr_y;          ///< Screen space center Y.
    fixed<short> sx;      ///< Scale X (8.8 fixed-point).
    fixed<short> sy;      ///< Scale Y (8.8 fixed-point).
    packed_angle16 alpha;        ///< Rotation angle.
};

/**
 * @brief Calculate affine background transformation matrices.
 *
 * Computes the affine transformation matrix for rotated/scaled backgrounds.
 *
 * @param src Array of input parameters.
 * @param dest Array of output matrices.
 * @param num Number of transformations to calculate.
 *
 * @note This function is constexpr-capable at compile time.
 *
 * Example:
 * @code{.cpp}
 * using namespace gba::literals;
 * gba::background_parameters params{
 *     .tex_x = 128.0_fx, .tex_y = 128.0_fx,
 *     .scr_x = 120, .scr_y = 80,
 *     .sx = 1.0_fx, .sy = 1.0_fx,
 *     .alpha = 45_deg
 * };
 * gba::background_matrix matrix;
 * gba::BgAffineSet(&params, &matrix, 1);
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * BgAffineSet(&src, &dest, 1);
 * @endcode
 */
[[gnu::nonnull(1, 2)]]
inline constexpr void BgAffineSet(const background_parameters* __restrict__ src, background_matrix* __restrict__ dest, std::size_t num) noexcept {
    if consteval {
        for (std::size_t i = 0; i < num; ++i) {
            const auto& bp = src[i];
            const unsigned int alpha16 = static_cast<unsigned int>(gba::bit_cast(bp.alpha)) & 0xFFFFu;
            const auto [s, c] = bits::sin_cos(alpha16);

            const auto ox = static_cast<long double>(bp.tex_x);
            const auto oy = static_cast<long double>(bp.tex_y);
            const auto cx = static_cast<long double>(bp.scr_x);
            const auto cy = static_cast<long double>(bp.scr_y);
            const auto sx = static_cast<long double>(bp.sx);
            const auto sy = static_cast<long double>(bp.sy);

            const long double a = sx * c;
            const long double b = -sx * s;
            const long double c_ = sy * s;
            const long double d = sy * c;

            dest[i].p[0] = fixed<short>(a);
            dest[i].p[1] = fixed<short>(b);
            dest[i].p[2] = fixed<short>(c_);
            dest[i].p[3] = fixed<short>(d);

            const long double rx = ox - (a * cx + b * cy);
            const long double ry = oy - (c_ * cx + d * cy);

            dest[i].x = fixed<int, 8>(rx);
            dest[i].y = fixed<int, 8>(ry);
        }
    } else {
        // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
        register auto* r0 asm("r0") = src;
        register auto* r1 asm("r1") = dest;
        register auto r2 asm("r2") = num;
        // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
        asm volatile ("swi 0xE << ((1f - . == 4) * -16); 1:" : "+r"(r0), "+r"(r1) : "r"(r2) : "r3", "memory");
    }
}

/**
 * @brief Input parameters for ObjAffineSet.
 *
 * Defines the transformation parameters for affine sprite calculation.
 */
struct object_parameters {
    fixed<short> sx;  ///< Scale X (8.8 fixed-point).
    fixed<short> sy;  ///< Scale Y (8.8 fixed-point).
    packed_angle16 alpha;    ///< Rotation angle.
};

/**
 * @brief Calculate affine sprite transformation matrices.
 *
 * Computes the affine transformation matrix for rotated/scaled sprites.
 * Can write directly to OAM with proper stride.
 *
 * @param src Array of input parameters.
 * @param dest Output location for matrix coefficients.
 * @param num Number of transformations to calculate.
 * @param stride Byte stride between matrix elements (2 for packed, 8 for OAM).
 *
 * @note This function is constexpr-capable at compile time.
 *
 * Example:
 * @code{.cpp}
 * using namespace gba::literals;
 * gba::object_parameters params{
 *     .sx = 1.0_fx, .sy = 1.0_fx,
 *     .alpha = 45_deg
 * };
 * gba::fixed<short> matrix[4];
 * gba::ObjAffineSet(&params, matrix, 1, 2);
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * ObjAffineSet(&src, &dest, 1, 2);
 * @endcode
 */
[[gnu::nonnull(1, 2)]]
inline constexpr void ObjAffineSet(const object_parameters* __restrict__ src, fixed<short>* __restrict__ dest, std::size_t num, std::size_t stride = 2) noexcept {
    if consteval {
        stride /= sizeof(short);
        for (std::size_t i = 0; i < num; ++i) {
            const auto& op = src[i];
            const unsigned int alpha16 = static_cast<unsigned int>(gba::bit_cast(op.alpha)) & 0xFFFFu;
            const auto [s, c] = bits::sin_cos(alpha16);

            const auto sx = static_cast<long double>(op.sx);
            const auto sy = static_cast<long double>(op.sy);

            const long double a = sx * c;
            const long double b = -sx * s;
            const long double c_ = sy * s;
            const long double d = sy * c;

            dest[0] = fixed<short>(a);
            dest[stride] = fixed<short>(b);
            dest[stride * 2] = fixed<short>(c_);
            dest[stride * 3] = fixed<short>(d);

            dest += stride * 4;
        }
    } else {
        // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
        register auto* r0 asm("r0") = src;
        register auto* r1 asm("r1") = dest;
        register auto r2 asm("r2") = num;
        register auto r3 asm("r3") = stride;
        // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
        asm volatile ("swi 0xF << ((1f - . == 4) * -16); 1:" : "+r"(r0), "+r"(r1), "+r"(r3) : "r"(r2) : "memory");
    }
}

/**
 * @brief Configuration for BitUnPack decompression.
 *
 * Specifies how to expand packed bit data to larger bit depths.
 */
struct unpack_parameters {
    unsigned short src_len;   ///< Source data length in bytes.
    unsigned char src_bpp : 4; ///< Source bits per pixel (1, 2, 4, or 8).
    unsigned char dst_bpp : 6; ///< Destination bits per pixel (1, 2, 4, 8, 16, or 32).
    unsigned int dst_ofs : 31; ///< Offset added to each destination unit.
    bool offset_zero : 1;      ///< If true, add offset to zero values too.

    /// @brief Calculate destination data length.
    /// @return The required destination buffer size in bytes.
    [[nodiscard]]
    constexpr auto dst_len() const noexcept {
        return src_len * dst_bpp / src_bpp;
    }
};

/**
 * @brief Unpack bit-packed data to larger bit depth.
 *
 * Expands data from lower to higher bit depth (e.g., 1bpp to 4bpp).
 * Useful for decompressing font or tile data.
 *
 * @param src Source data.
 * @param dest Destination buffer.
 * @param unpack Configuration specifying bit depths and options.
 *
 * Example:
 * @code{.cpp}
 * // Expand 1bpp font data to 4bpp
 * gba::unpack_parameters params{
 *     .src_len = 256,
 *     .src_bpp = 1,
 *     .dst_bpp = 4,
 *     .dst_ofs = 1,      // Color index 1 for set bits
 *     .offset_zero = false
 * };
 * gba::BitUnPack(font_1bpp, font_4bpp, params);
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * BUP bup = {256, 1, 4, 1 << 31};
 * BitUnPack(font_1bpp, font_4bpp, &bup);
 * @endcode
 */
[[gnu::nonnull(1, 2)]]
inline void BitUnPack(const void* __restrict__ src, void* __restrict__ dest, const unpack_parameters& unpack) noexcept {
    // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
    register auto* r0 asm("r0") = src;
    register auto* r1 asm("r1") = dest;
    register auto* r2 asm("r2") = &unpack;
