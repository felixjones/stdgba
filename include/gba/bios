/**
 * @file bios
 * @brief GBA BIOS function wrappers.
 *
 * This header provides C++ wrappers for GBA BIOS software interrupts (SWIs).
 * Functions are constexpr where possible, falling back to BIOS calls at runtime.
 *
 * Example:
 * @code{.cpp}
 * // Wait for vertical blank interrupt
 * gba::VBlankIntrWait();
 *
 * // Calculate square root
 * auto result = gba::Sqrt(144u); // Returns 12
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * VBlankIntrWait();
 * u32 result = Sqrt(144);
 * @endcode
 */
#pragma once

#include <gba/angle>
#include <gba/bits/bios.hpp>
#include <gba/bits/constexpr_trig.hpp>
#include <gba/fixed_point>
#include <gba/peripherals>

namespace gba {

/**
 * @brief Perform a soft reset, returning to the start of the ROM.
 *
 * @note This function never returns.
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * SoftReset();
 * @endcode
 */
[[noreturn]]
inline void SoftReset() noexcept {
    asm volatile ("swi 0x0 << ((1f - . == 4) * -16); 1:");
    __builtin_unreachable();
}

/**
 * @brief Flags for RegisterRamReset specifying which memory regions to clear.
 */
struct register_ram_mask {
    bool ewram : 1;     ///< Clear external work RAM (256KB).
    bool iwram : 1;     ///< Clear internal work RAM (32KB).
    bool palette : 1;   ///< Clear palette RAM (1KB).
    bool vram : 1;      ///< Clear video RAM (96KB).
    bool oam : 1;       ///< Clear object attribute memory (1KB).
    bool reg_sio : 1;   ///< Reset serial IO registers.
    bool reg_sound : 1; ///< Reset sound registers.
    bool reg : 1;       ///< Reset other registers.
};

/**
 * @brief Reset specified memory regions and registers.
 *
 * @param flags Bitmask specifying which regions to reset.
 *
 * Example:
 * @code{.cpp}
 * // Clear VRAM and OAM
 * gba::RegisterRamReset({.vram = true, .oam = true});
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * RegisterRamReset(RESET_VRAM | RESET_OAM);
 * @endcode
 */
inline void RegisterRamReset(register_ram_mask flags) noexcept {
    // ReSharper disable once CppDeprecatedRegisterStorageClassSpecifier
    register auto r0 asm("r0") = flags;
    asm volatile ("swi 0x1 << ((1f - . == 4) * -16); 1:" : "+r"(r0) :: "r1", "r3", "memory");
}

/**
 * @brief Halt CPU until an interrupt occurs.
 *
 * Puts the CPU into low-power mode until any enabled interrupt fires.
 * More efficient than busy-waiting.
 *
 * Example:
 * @code{.cpp}
 * gba::reg_ie = {.timer0 = true};
 * gba::reg_ime = true;
 * gba::Halt(); // Wait for timer interrupt
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * Halt();
 * @endcode
 */
inline void Halt() noexcept {
    asm volatile ("swi 0x2 << ((1f - . == 4) * -16); 1:");
}

/**
 * @brief Stop CPU and LCD until an interrupt occurs.
 *
 * Puts the system into deep sleep mode. Only certain interrupts
 * (keypad, cartridge, serial) can wake the system.
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * Stop();
 * @endcode
 */
inline void Stop() noexcept {
    asm volatile ("swi 0x3 << ((1f - . == 4) * -16); 1:" ::: "r0", "r1", "r3");
}

/**
 * @brief Wait for specified interrupt(s) to occur.
 *
 * @param clearCurrent If true, clear any pending matching interrupts before waiting.
 * @param flags The interrupt(s) to wait for.
 *
 * Example:
 * @code{.cpp}
 * // Wait for VBlank or HBlank
 * gba::IntrWait(true, {.vblank = true, .hblank = true});
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * IntrWait(1, IRQ_VBLANK | IRQ_HBLANK);
 * @endcode
 */
inline void IntrWait(bool clearCurrent, irq flags) noexcept {
    // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
    register auto r0 asm("r0") = clearCurrent;
    register auto r1 asm("r1") = __builtin_bit_cast(short, flags);
    // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
    asm volatile ("swi 0x4 << ((1f - . == 4) * -16); 1:" : "+r"(r0), "+r"(r1)  :: "r3");
}

/**
 * @brief Wait for vertical blank interrupt.
 *
 * Equivalent to IntrWait(true, {.vblank = true}). This is the standard
 * way to synchronize game logic to the display refresh rate (~60Hz).
 *
 * Example:
 * @code{.cpp}
 * while (true) {
 *     update_game();
 *     render();
 *     gba::VBlankIntrWait();
 * }
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * VBlankIntrWait();
 * @endcode
 */
inline void VBlankIntrWait() noexcept {
    asm volatile ("swi 0x5 << ((1f - . == 4) * -16); 1:" ::: "r0", "r1", "r3");
}

/**
 * @brief Signed integer division.
 *
 * @param number The dividend.
 * @param denom The divisor.
 * @return Vector containing [quotient, remainder].
 *
 * @note This function is constexpr-capable at compile time.
 *
 * Example:
 * @code{.cpp}
 * auto [quot, rem] = gba::Div(17, 5); // quot=3, rem=2
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * int quot = Div(17, 5);
 * int rem = DivMod(17, 5);
 * @endcode
 */
[[nodiscard, gnu::const]]
constexpr auto Div(int number, int denom) noexcept -> int [[gnu::vector_size(sizeof(int) * 2)]] {
    if consteval {
        return (int [[gnu::vector_size(sizeof(int) * 2)]]){number / denom, number % denom};
    } else {
        // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
        register auto r0 asm("r0") = number;
        register auto r1 asm("r1") = denom;
        // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
        asm volatile ("swi 0x6 << ((1f - . == 4) * -16); 1:" : "+r"(r0), "+r"(r1) :: "r3");
        return (int [[gnu::vector_size(sizeof(int) * 2)]]){r0, r1};
    }
}

/**
 * @brief Signed integer division (ARM calling convention).
 *
 * Same as Div but with arguments swapped to match ARM division convention.
 *
 * @param denom The divisor.
 * @param number The dividend.
 * @return Vector containing [quotient, remainder].
 *
 * @note This function is constexpr-capable at compile time.
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * int quot = DivArm(5, 17); // Note: args swapped vs Div
 * @endcode
 */
[[nodiscard, gnu::const]]
constexpr auto DivArm(int denom, int number) noexcept -> int [[gnu::vector_size(sizeof(int) * 2)]] {
    if consteval {
        return (int [[gnu::vector_size(sizeof(int) * 2)]]){number / denom, number % denom};
    } else {
        // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
        register auto r0 asm("r0") = denom;
        register auto r1 asm("r1") = number;
        // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
        asm volatile ("swi 0x7 << ((1f - . == 4) * -16); 1:" : "+r"(r0), "+r"(r1) :: "r3");
        return (int [[gnu::vector_size(sizeof(int) * 2)]]){r0, r1};
    }
}

/**
 * @brief Calculate integer square root.
 *
 * @param arg The value to take the square root of.
 * @return The integer square root (floor).
 *
 * @note This function is constexpr-capable at compile time.
 *
 * Example:
 * @code{.cpp}
 * auto root = gba::Sqrt(144u); // Returns 12
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * u32 root = Sqrt(144);
 * @endcode
 */
[[nodiscard, gnu::const]]
// ReSharper disable once CppDFAConstantParameter
constexpr unsigned int Sqrt(unsigned int arg) noexcept {
    if consteval {
        if (arg == 0 || arg == 1) {
            return arg;
        }

        unsigned int low = 0, high = arg, result = 0;
        while (low <= high) {
            if (auto mid = low + (high - low) / 2; mid * mid == arg) {
                return mid;
            } else if (mid * mid < arg) {
                low = mid + 1;
                result = mid;
            } else {
                high = mid - 1;
            }
        }
        return result;
    } else {
        // ReSharper disable once CppDeprecatedRegisterStorageClassSpecifier
        register auto r0 asm("r0") = arg;
        asm volatile ("swi 0x8 << ((1f - . == 4) * -16); 1:" : "+r"(r0) :: "r1", "r3");
        return r0;
    }
}

/**
 * @brief Calculate square root of a fixed-point value.
 *
 * @tparam T Fixed-point type with <= 16 integer bits.
 * @param arg The fixed-point value.
 * @return The square root in the same fixed-point format.
 *
 * Example:
 * @code{.cpp}
 * using namespace gba::literals;
 * auto root = gba::Sqrt(4.0_fx); // ~2.0
 * @endcode
 */
[[nodiscard, gnu::const]]
constexpr auto Sqrt(fixed_point auto arg) noexcept -> decltype(arg) requires (std::numeric_limits<typename fixed_point_traits<decltype(arg)>::underlying_type>::digits <= 16) {
    const auto higherPrecision = __builtin_bit_cast(typename fixed_point_traits<decltype(arg)>::underlying_type, arg) << fixed_point_traits<decltype(arg)>::fractional_digits;
    const auto result = static_cast<typename fixed_point_traits<decltype(arg)>::underlying_type>(Sqrt(higherPrecision));
    return __builtin_bit_cast(decltype(arg), result);
}

/**
 * @brief Calculate arctangent.
 *
 * @param arg The tangent value in 1.14 fixed-point format.
 * @return 16-bit angle where 0x10000 = 360 degrees.
 *
 * @note This function is constexpr-capable at compile time.
 *
 * Example:
 * @code{.cpp}
 * using namespace gba::literals;
 * auto angle = gba::ArcTan(gba::fixed<int, 14>{1.0_fx}); // ~45 degrees
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * s16 angle = ArcTan(1 << 14); // 1.0 in .14 fixed
 * @endcode
 */
[[nodiscard, gnu::const]]
constexpr packed_angle16 ArcTan(fixed<int, 14> arg) noexcept {
    if consteval {
        return packed_angle16{static_cast<std::uint16_t>(bits::arc_tan(__builtin_bit_cast(int, arg)))};
    } else {
        // ReSharper disable once CppDeprecatedRegisterStorageClassSpecifier
        register auto r0 asm("r0") = __builtin_bit_cast(int, arg);
        asm volatile ("swi 0x9 << ((1f - . == 4) * -16); 1:" : "+r"(r0) :: "r1", "r3");
        return packed_angle16{static_cast<std::uint16_t>(r0)};
    }
}

/**
 * @brief Calculate arctangent of y/x (two-argument arctangent).
 *
 * Determines the angle from the positive x-axis to the point (x, y).
 * Handles all four quadrants correctly.
 *
 * @param x The x coordinate.
 * @param y The y coordinate.
 * @return 16-bit angle where 0x10000 = 360 degrees.
 *
 * @note This function is constexpr-capable at compile time.
 *
 * Example:
 * @code{.cpp}
 * auto angle = gba::ArcTan2(100, 100); // 45 degrees
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * s16 angle = ArcTan2(100, 100);
 * @endcode
 */
[[nodiscard, gnu::const]]
constexpr packed_angle16 ArcTan2(int x, int y) noexcept {
    if consteval {
        return packed_angle16{static_cast<std::uint16_t>(bits::arc_tan2(x, y))};
    } else {
        // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
        register auto r0 asm("r0") = x;
        register auto r1 asm("r1") = y;
        // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
        asm volatile ("swi 0xA << ((1f - . == 4) * -16); 1:" : "+r"(r0) : "r"(r1) : "r3");
        return packed_angle16{static_cast<std::uint16_t>(r0)};
    }
}

/**
 * @brief Calculate arctangent of y/x for fixed-point values.
 *
 * @param x The x coordinate (fixed-point).
 * @param y The y coordinate (fixed-point).
 * @return 16-bit angle where 0x10000 = 360 degrees.
 */
[[nodiscard, gnu::const]]
constexpr packed_angle16 ArcTan2(fixed_point auto x, fixed_point auto y) noexcept {
    return ArcTan2(bit_cast(x), bit_cast(y));
}

/**
 * @brief Configuration for CpuSet memory copy/fill operation.
 */
struct cpu_set {
    unsigned int count : 21; ///< Number of units to copy/fill.
    int : 3;
    bool fill : 1;           ///< If true, fill with first value; if false, copy.
    int : 1;
    bool set_32bit : 1;      ///< If true, use 32-bit transfers; if false, 16-bit.
};

/**
 * @brief Copy or fill memory using CPU.
 *
 * @param src Source address (or fill value if fill mode).
 * @param dest Destination address.
 * @param lenmode Configuration specifying count, fill mode, and transfer size.
 *
 * Example:
 * @code{.cpp}
 * // Copy 256 halfwords
 * gba::CpuSet(src, dest, {.count = 256, .fill = false, .set_32bit = false});
 *
 * // Fill with 32-bit value
 * unsigned int fill_val = 0;
 * gba::CpuSet(&fill_val, dest, {.count = 100, .fill = true, .set_32bit = true});
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * CpuSet(src, dest, 256 | COPY16);
 * CpuSet(&fill_val, dest, 100 | FILL | COPY32);
 * @endcode
 */
[[gnu::nonnull(1, 2)]]
inline void CpuSet(const void* __restrict__ src, void* __restrict__ dest, cpu_set lenmode) noexcept {
    // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
    register auto* r0 asm("r0") = src;
    register auto* r1 asm("r1") = dest;
    register auto r2 asm("r2") = lenmode;
    // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
    asm volatile ("swi 0xB << ((1f - . == 4) * -16); 1:" : "+r"(r0), "+r"(r1) : "r"(r2) : "r3", "memory");
}

/**
 * @brief Configuration for CpuFastSet memory copy/fill operation.
 *
 * @note CpuFastSet always uses 32-bit transfers and requires 4-byte alignment.
 */
struct cpu_fast_set {
    unsigned int count : 21; ///< Number of 32-bit words to copy/fill.
    int : 3;
    bool fill : 1;           ///< If true, fill with first value; if false, copy.
};

/**
 * @brief Fast copy or fill memory using CPU.
 *
 * Faster than CpuSet but requires 4-byte alignment and copies in multiples of 8 words.
 *
 * @param src Source address (or fill value if fill mode). Must be 4-byte aligned.
 * @param dest Destination address. Must be 4-byte aligned.
 * @param lenmode Configuration specifying count and fill mode.
 *
 * Example:
 * @code{.cpp}
 * // Fast copy 1024 words
 * gba::CpuFastSet(src, dest, {.count = 1024, .fill = false});
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * CpuFastSet(src, dest, 1024);
 * @endcode
 */
[[gnu::nonnull(1, 2)]]
inline void CpuFastSet(const void* __restrict__ src, void* __restrict__ dest, cpu_fast_set lenmode) noexcept {
    // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
    register auto* r0 asm("r0") = src;
    register auto* r1 asm("r1") = dest;
    register auto r2 asm("r2") = lenmode;
    // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
    asm volatile ("swi 0xC << ((1f - . == 4) * -16); 1:" : "+r"(r0), "+r"(r1) : "r"(r2) : "r3", "memory");
}

