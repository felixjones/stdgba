[[nodiscard, gnu::const]]
// ReSharper disable once CppDFAConstantParameter
constexpr unsigned int Sqrt(unsigned int arg) noexcept {
    if consteval {
        if (arg == 0 || arg == 1) {
            return arg;
        }

        unsigned int low = 0, high = arg, result = 0;
        while (low <= high) {
            if (auto mid = low + (high - low) / 2; mid * mid == arg) {
                return mid;
            } else if (mid * mid < arg) {
                low = mid + 1;
                result = mid;
            } else {
                high = mid - 1;
            }
        }
        return result;
    } else {
        // ReSharper disable once CppDeprecatedRegisterStorageClassSpecifier
        register auto r0 asm("r0") = arg;
        asm volatile ("swi 0x8 << ((1f - . == 4) * -16); 1:" : "+r"(r0) :: "r1", "r3");
        return r0;
    }
}

[[nodiscard, gnu::const]]
constexpr auto Sqrt(fixed_point auto arg) noexcept -> decltype(arg) requires (std::numeric_limits<typename fixed_point_traits<decltype(arg)>::underlying_type>::digits <= 16) {
    const auto higherPrecision = __builtin_bit_cast(typename fixed_point_traits<decltype(arg)>::underlying_type, arg) << fixed_point_traits<decltype(arg)>::fractional_digits;
    const auto result = static_cast<typename fixed_point_traits<decltype(arg)>::underlying_type>(Sqrt(higherPrecision));
    return __builtin_bit_cast(decltype(arg), result);
}

