/**
 * @brief Configuration for SoundBias BIOS function.
 */
struct sound_bias_config {
    unsigned int delay_shift : 2; ///< Delay between bias changes (0-3). Higher = slower transition.
    unsigned int : 29;
    bool enable : 1;      ///< If true, set bias to 0x200; if false, set to 0.
};

/**
 * @brief Gradually adjust sound bias level.
 *
 * Changes SOUNDBIAS to 0x200 (normal) or 0 over a delay period.
 * Call with enable=false before Stop() to prevent audio popping,
 * and enable=true after Stop() to restore sound output.
 *
 * @param bias Configuration specifying delay and enable/disable.
 *
 * Example:
 * @code{.cpp}
 * gba::SoundBias({.delay_shift = 0, .enable = true});  // Enable sound bias
 * gba::SoundBias({.delay_shift = 0, .enable = false}); // Disable before Stop()
 * gba::Stop();
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * // r0 = delay_shift | (enable << 31)
 * swi_call(0x19);
 * @endcode
 */
inline void SoundBias(sound_bias_config bias) noexcept {
    // ReSharper disable once CppDeprecatedRegisterStorageClassSpecifier
    register auto r0 asm("r0") = __builtin_bit_cast(unsigned int, bias);
    asm volatile ("swi 0x19 << ((1f - . == 4) * -16); 1:" : "+r"(r0) :: "r1", "r3");
}

/**
 * @brief MultiBoot transfer mode.
 *
 * Selects the serial communication mode for the MultiBoot transfer.
 *
 * @see MultiBoot
 */
enum class multiboot_mode : unsigned int {
    normal_256k = 0, ///< 256KHz, 32-bit, Normal mode (fast, single slave).
    multi_115k = 1,  ///< 115KHz, 16-bit, MultiPlay mode (up to 3 slaves).
    normal_2m = 2    ///< 2MHz, 32-bit, Normal mode (fastest, may be unstable).
};

/**
 * @brief Compute an animated palette_data byte for MultiBoot.
 *
 * The slave boot screen shows a color sweep animation.
 *
 * @param color Palette color index (0-6).
 * @param speed Animation speed (0-3).
 * @param ascending true for ascending sweep, false for descending.
 * @return Encoded palette_data byte for multiboot_param::palette_data.
 *
 * @see multiboot_param
 */
consteval unsigned char multiboot_palette(int color, int speed, bool ascending) {
    if (color < 0 || color > 6)
        throw "multiboot_palette: color out of range (0-6)";
    if (speed < 0 || speed > 3)
        throw "multiboot_palette: speed out of range (0-3)";
    return static_cast<unsigned char>(0x81 + color * 0x10 + ascending * 0x8 + speed * 0x2);
}

/**
 * @brief Compute a fixed palette_data byte for MultiBoot.
 *
 * The slave boot screen shows a single solid color.
 *
 * @param color Palette color index (0-6).
 * @return Encoded palette_data byte for multiboot_param::palette_data.
 *
 * @see multiboot_param
 */
consteval unsigned char multiboot_palette_fixed(int color) {
    if (color < 0 || color > 6)
        throw "multiboot_palette_fixed: color out of range (0-6)";
    return static_cast<unsigned char>(0xF1 + color * 0x2);
}

/**
 * @brief Parameter structure for MultiBoot (SWI 0x25).
 *
 * Must be exactly 0x4C (76) bytes. Before calling MultiBoot(), set:
 * - boot_srcp: start of program data to send (typically 0x080000C0)
 * - boot_endp: end of program data to send
 * - palette_data: boot screen palette (use multiboot_palette())
 * - client_bit: bitmask of detected slaves (bits 1-3)
 * - client_data[0-2]: random bytes received from each slave
 * - handshake_data: 0x11 + client_data[0] + client_data[1] + client_data[2]
 *
 * The transfer length (boot_endp - boot_srcp) must be a multiple of
 * 0x10, minimum 0x100, maximum 0x3FF40 (approximately 256KB).
 *
 * Fields marked "internal" are used by the BIOS during transfer and
 * should not be modified by user code.
 *
 * @code{.cpp}
 * gba::multiboot_param param{};
 * param.palette_data = gba::multiboot_palette(0, 1, true);
 * param.client_bit = detected_slaves;
 * param.client_data[0] = slave1_cc;
 * param.client_data[1] = slave2_cc;
 * param.client_data[2] = slave3_cc;
 * param.handshake_data = 0x11 + slave1_cc + slave2_cc + slave3_cc;
 * param.boot_srcp = reinterpret_cast<const void*>(0x080000C0);
 * param.boot_endp = reinterpret_cast<const void*>(0x080000C0 + length);
 * auto result = gba::MultiBoot(&param, gba::multiboot_mode::multi_115k);
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * MultiBootParam param = { ... };
 * int result = MultiBoot(&param, 1);
 * @endcode
 *
 * @see MultiBoot
 */
struct multiboot_param {
    unsigned int reserved1[5];        ///< Internal BIOS state.
    unsigned char handshake_data;     ///< Handshake byte (Normal mode only).
    unsigned char reserved_pad;       ///< Internal.
    unsigned short handshake_timeout; ///< Internal timeout counter.
    unsigned char probe_count;        ///< Internal probe counter.
    unsigned char client_data[3];     ///< Random data received from slaves 1-3.
    unsigned char palette_data;       ///< Boot screen palette encoding.
    unsigned char response_bit;       ///< Internal response tracking.
    unsigned char client_bit;         ///< Detected slaves bitmask (bits 1-3).
    unsigned char reserved2;          ///< Reserved.
    const void* boot_srcp;            ///< Start of ROM data to transfer.
    const void* boot_endp;            ///< End of ROM data to transfer.
    const void* masterp;              ///< Internal BIOS pointer.
    unsigned char reserved3[0x20];    ///< Internal BIOS state.
};
static_assert(sizeof(multiboot_param) == 0x4C);

/**
 * @brief Upload and start a program on slave GBAs (SWI 0x25).
 *
 * Transfers program data from the master cartridge to connected slave
 * GBAs via the link cable. The slaves execute the transferred program
 * from EWRAM (0x02000000).
 *
 * @warning This SWI covers only the data transfer phase (approximately
 *          45% of the full MultiBoot protocol). The master program must
 *          implement the initiation handshake before calling this
 *          function. See gbatek "Multiboot Transfer Protocol" for the
 *          full sequence.
 *
 * @param param Pointer to initialized multiboot_param structure.
 * @param mode Transfer mode (serial communication speed and protocol).
 * @return 0 on success, 1 on failure.
 *
 * Example:
 * @code{.cpp}
 * // After completing the initiation handshake:
 * auto result = gba::MultiBoot(&param, gba::multiboot_mode::multi_115k);
 * if (result != 0) {} // handle failure
 * @endcode
 *
 * TONCLIB Equivalent:
 * @code{.c}
 * int result = MultiBoot(&param, 1);
 * @endcode
 *
 * @see multiboot_param, multiboot_mode
 */
[[gnu::nonnull(1)]]
inline int MultiBoot(multiboot_param* param, multiboot_mode mode) noexcept {
    // ReSharper disable CppDeprecatedRegisterStorageClassSpecifier
    register auto r0 asm("r0") = reinterpret_cast<unsigned int>(param);
    register auto r1 asm("r1") = static_cast<unsigned int>(mode);
    // ReSharper restore CppDeprecatedRegisterStorageClassSpecifier
    asm volatile ("swi 0x25 << ((1f - . == 4) * -16); 1:" : "+r"(r0) : "r"(r1) : "r2", "r3", "memory");
    return static_cast<int>(r0);
}

