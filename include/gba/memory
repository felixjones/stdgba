/**
 * @brief Unique ownership pointer with type-erased deleter.
 *
 * Similar to std::unique_ptr but with a constexpr-compatible type-erased deleter.
 * Useful for managing resources from custom allocators like bitpool.
 *
 * Example:
 * @code{.cpp}
 * // Create with custom deleter
 * gba::unique<int> ptr{new int{42}, [](const int* p) { delete p; }};
 * *ptr = 100;
 *
 * // Create via make_unique
 * auto ptr2 = gba::make_unique<int>(42);
 * @endcode
 *
 * @tparam T The managed object type.
 */
template<typename T>
struct unique {
    /// @brief Default constructor (null pointer).
    constexpr unique() noexcept : m_ptr{nullptr}, m_deleter{[](const T*) constexpr static {}} {}

    /// @brief Construct from nullptr.
    constexpr unique(std::nullptr_t) noexcept : m_ptr{nullptr}, m_deleter{[](const T*) constexpr static {}} {}

    /// @brief Construct with pointer and custom deleter.
    /// @tparam Deleter The deleter type (must be callable with const T*).
    /// @param ptr The pointer to manage.
    /// @param deleter The deleter to invoke on destruction.
    template<typename Deleter>
    constexpr unique(T* ptr, Deleter&& deleter) noexcept : m_ptr{ptr}, m_deleter{std::forward<Deleter>(deleter)} {}

    /// @brief Destructor. Invokes the deleter if pointer is non-null.
    constexpr ~unique() {
        reset();
    }

    unique(const unique&) = delete;
    unique& operator=(const unique&) = delete;

    /// @brief Move constructor.
    constexpr unique(unique&& other) noexcept : m_ptr{other.m_ptr}, m_deleter{std::move(other.m_deleter)} {
        other.m_ptr = nullptr;
    }

    /// @brief Move assignment operator.
    constexpr unique& operator=(unique&& other) noexcept {
        if (this != &other) {
            reset();
            m_ptr = other.m_ptr;
            m_deleter = std::move(other.m_deleter);
            other.m_ptr = nullptr;
        }
        return *this;
    }

    /// @brief Release ownership and invoke deleter.
    constexpr void reset() noexcept {
        if (m_ptr) {
            std::invoke(m_deleter, m_ptr);
            m_ptr = nullptr;
        }
    }

    /// @brief Get the managed pointer.
    /// @return The raw pointer.
    constexpr T* get() const noexcept { return m_ptr; }

    /// @brief Arrow operator for member access.
    /// @return The raw pointer.
    constexpr T* operator->() const noexcept { return m_ptr; }

    /// @brief Dereference operator.
    /// @return Reference to the managed object.
    constexpr T& operator*() const noexcept { return *m_ptr; }

    /// @brief Check if pointer is non-null.
    /// @return True if managing a valid pointer.
    constexpr explicit operator bool() const noexcept { return m_ptr != nullptr; }
private:
    T* m_ptr;
    bits::handler<const T*> m_deleter;
};

/// @brief Create a unique pointer with default delete.
/// @tparam T The object type to create.
/// @tparam Args Constructor argument types.
/// @param args Arguments forwarded to T's constructor.
/// @return A unique pointer managing the new object.
///
/// Example:
/// @code{.cpp}
/// auto ptr = gba::make_unique<int>(42);
/// auto obj = gba::make_unique<MyClass>(arg1, arg2);
/// @endcode
template<typename T, typename... Args>
constexpr unique<T> make_unique(Args&&... args) {
    return {new T{std::forward<Args>(args)...}, [](const T* ptr) constexpr static { delete ptr; }};
}

/**
 * @brief Bitmap-based fixed memory pool allocator.
 *
 * Manages a contiguous memory region using a 32-bit bitmap to track allocations.
 * Each bit represents one chunk, allowing up to 32 chunks per pool.
 * Ideal for managing VRAM regions for dynamic sprite or tile allocation.
 *
 * @note The pool is limited to exactly 32 chunks due to the 32-bit bitmask.
 * Choose your chunk size accordingly: for 32KB of VRAM, use 1KB chunks (32 * 1KB = 32KB).
 *
 * Example:
 * @code{.cpp}
 * // Create a pool over object VRAM (32KB with 1KB chunks)
 * gba::bitpool obj_vram{gba::memory_map(gba::mem_vram_obj), 1024};
 *
 * // Allocate 2KB for sprite tiles
 * void* tiles = obj_vram.allocate(2048);
 *
 * // Allocate with alignment (e.g., for 8bpp tiles)
 * void* aligned_tiles = obj_vram.allocate(1024, 1024);
 *
 * // Deallocate when sprite is destroyed
 * obj_vram.deallocate(tiles, 2048);
 *
 * // Use allocate_unique for RAII
 * auto sprite_tiles = obj_vram.allocate_unique<char>(1024);
 * @endcode
 */
struct bitpool {
    /// @brief Construct a bitpool over a memory region.
    /// @param base Pointer to the start of the managed memory.
    /// @param chunkSize Size of each allocation chunk in bytes. Must be a power of two.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Manage object VRAM with 512-byte chunks (16 tiles each)
    /// gba::bitpool obj_vram{gba::memory_map(gba::mem_vram_obj), 512};
    /// @endcode
    constexpr explicit bitpool(void* base, const std::size_t chunkSize) noexcept
        : m_base{reinterpret_cast<std::uintptr_t>(base)}
        , m_chunkShift{static_cast<std::uint8_t>(std::countr_zero(chunkSize))}
        , m_bitmask{} {}

    /// @brief Get the maximum number of chunks (always 32).
    /// @return The chunk capacity.
    /// @note This is fixed at 32 due to the underlying 32-bit bitmask.
    static constexpr std::size_t capacity() noexcept { return std::numeric_limits<std::uint32_t>::digits; }

    /// @brief Get the chunk size in bytes.
    /// @return The chunk size.
    [[nodiscard]]
    constexpr std::size_t chunk_size() const noexcept { return std::size_t{1} << m_chunkShift; }

    /// @brief Get the total pool size in bytes.
    /// @return capacity() * chunk_size().
    [[nodiscard]]
    constexpr std::size_t size() const noexcept { return capacity() * chunk_size(); }

    /// @brief Allocate memory from the pool.
    /// @param bytes Number of bytes to allocate.
    /// @return Pointer to allocated memory, or nullptr if allocation fails.
    ///
    /// Example:
    /// @code{.cpp}
    /// void* ptr = pool.allocate(256);
    /// if (ptr) { // use memory }
    /// @endcode
    constexpr void* allocate(const std::size_t bytes) noexcept {
        const std::size_t chunkLen = (bytes + (chunk_size() - 1)) >> m_chunkShift;

        std::size_t chunkMask = (1 << chunkLen) - 1;
        std::uintptr_t chunkStart = 0;
        while (chunkStart < capacity()) {
            if ((m_bitmask & chunkMask) == 0) {
                m_bitmask |= chunkMask;
                return reinterpret_cast<void*>(m_base + (chunkStart << m_chunkShift));
            }
            chunkMask <<= 1;
            chunkStart += 1;
        }

        return nullptr;
    }

    /// @brief Allocate memory with alignment.
    /// @param bytes Number of bytes to allocate.
    /// @param chunkAlignment Alignment in bytes (rounded up to chunk boundaries).
    /// @return Pointer to allocated memory, or nullptr if allocation fails.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Allocate 256 bytes aligned to 1KB boundary
    /// void* ptr = pool.allocate(256, 1024);
    /// @endcode
    constexpr void* allocate(const std::size_t bytes, const std::size_t chunkAlignment) noexcept {
        const std::size_t chunkLen = (bytes + (chunk_size() - 1)) >> m_chunkShift;
        const std::size_t chunkStep = (chunkAlignment + (chunk_size() - 1)) >> m_chunkShift;

        std::size_t chunkMask = (1 << chunkLen) - 1;
        std::uintptr_t chunkStart = 0;
        while (chunkStart < capacity()) {
            if ((m_bitmask & chunkMask) == 0) {
                m_bitmask |= chunkMask;
                return reinterpret_cast<void*>(m_base + (chunkStart << m_chunkShift));
            }
            chunkMask <<= chunkStep;
            chunkStart += chunkStep;
        }

        return nullptr;
    }

    /// @brief Deallocate memory back to the pool.
    /// @param ptr Pointer previously returned by allocate().
    /// @param bytes The same size passed to allocate().
    ///
    /// Example:
    /// @code{.cpp}
    /// pool.deallocate(ptr, 256);
    /// @endcode
    constexpr void deallocate(const void* ptr, const std::size_t bytes) noexcept {
        const std::size_t chunkLen = (bytes + (chunk_size() - 1)) >> m_chunkShift;
        const std::size_t chunkMask = (1 << chunkLen) - 1;

        const std::uintptr_t chunkStart = (reinterpret_cast<std::uintptr_t>(ptr) - m_base) >> m_chunkShift;
        m_bitmask &= ~(chunkMask << chunkStart);
    }

    /// @brief Allocate raw memory and return a unique pointer with automatic deallocation.
    /// @tparam T The pointer type (used for alignment, no constructor called).
    /// @param bytes Number of bytes to allocate.
    /// @param chunkAlignment Alignment in bytes (default: alignof(T)).
    /// @return A unique pointer that deallocates on destruction.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Allocate VRAM for sprite tiles with RAII
    /// auto sprite_tiles = vram_pool.allocate_unique<char>(512);
    /// std::memcpy(sprite_tiles.get(), tile_data, 512);
    /// // Memory is automatically returned to pool when sprite_tiles goes out of scope
    /// @endcode
    template<typename T>
    constexpr unique<T> allocate_unique(const std::size_t bytes, const std::size_t chunkAlignment = alignof(T)) noexcept {
        void* ptr = allocate(bytes, chunkAlignment);
        if (!ptr) {
            return nullptr;
        }

        return {static_cast<T*>(ptr), [this, bytes](const T* p) constexpr {
            this->deallocate(p, bytes);
        }};
    }

    /// @brief Construct an object in pool memory and return a unique pointer.
    /// @tparam T The object type to construct.
    /// @tparam Args Constructor argument types.
    /// @param args Arguments forwarded to T's constructor.
    /// @return A unique pointer that destructs and deallocates on destruction.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Construct an object in the pool
    /// auto obj = pool.make_unique<MySprite>(x, y, tile_index);
    /// obj->update();
    /// // Destructor called and memory returned to pool when obj goes out of scope
    /// @endcode
    template<typename T, typename... Args>
    constexpr unique<T> make_unique(Args&&... args) {
        void* ptr = allocate(sizeof(T), alignof(T));
        if (!ptr) {
            return nullptr;
        }

        auto* obj = new(ptr) T{std::forward<Args>(args)...};
        return {obj, [this](const T* p) constexpr {
            p->~T();
            this->deallocate(p, sizeof(T));
        }};
    }

    /// @brief Create a sub-pool from this pool's memory.
    /// @param bytes Size of the sub-pool in bytes.
    /// @param chunkAlignment Alignment for the sub-pool's base address.
    /// @return A unique pointer to the sub-pool.
    ///
    /// @warning The parent bitpool must outlive all subpools created from it.
    /// Destroying the parent while subpools still exist results in undefined behavior.
    ///
    /// Example:
    /// @code{.cpp}
    /// // Create a 4KB sub-pool for a specific sprite sheet
    /// auto sheet_pool = vram_pool.subpool(4096);
    /// void* frame1 = sheet_pool->allocate(256);
    /// void* frame2 = sheet_pool->allocate(256);
    /// // Sub-pool memory returned to parent when sheet_pool goes out of scope
    /// @endcode
    constexpr unique<bitpool> subpool(const std::size_t bytes, const std::size_t chunkAlignment = 1) noexcept {
        const std::size_t chunkBytes = ((bytes + (chunk_size() - 1)) >> m_chunkShift) << m_chunkShift;

        void* ptr = allocate(chunkBytes, chunkAlignment);
        if (!ptr) {
            return nullptr;
        }

        auto* sub = new bitpool{ptr, chunkBytes / 32};
        return unique<bitpool>{sub, [this, ptr, chunkBytes](const bitpool* p) constexpr {
            this->deallocate(ptr, chunkBytes);
            delete p;
        }};
    }
private:
    std::uintptr_t m_base;
    std::uint8_t m_chunkShift;
    std::uint32_t m_bitmask;
};

/**
 * @brief PMR memory resource adapter for bitpool.
 *
 * Wraps a bitpool as a std::pmr::memory_resource, enabling use with
 * PMR containers like std::pmr::vector and std::pmr::string.
 *
 * Example:
 * @code{.cpp}
 * char buffer[4096];
 * gba::bitpool pool{buffer, 128};
 * gba::bitpool_buffer_resource resource{pool};
 *
 * std::pmr::vector<int> vec{&resource};
 * vec.push_back(42);
 * @endcode
 */
struct bitpool_buffer_resource : std::pmr::memory_resource {
    /// @brief Construct a PMR resource backed by a bitpool.
    /// @param parent The bitpool to allocate from.
    constexpr explicit bitpool_buffer_resource(bitpool& parent) noexcept : m_bitpool{&parent} {}
protected:
    /// @brief Allocate memory from the underlying bitpool.
    void* do_allocate(const std::size_t bytes, const std::size_t alignment) override {
        return m_bitpool->allocate(bytes, alignment);
    }

    /// @brief Deallocate memory back to the underlying bitpool.
    void do_deallocate(void* ptr, const std::size_t bytes, std::size_t) override {
        m_bitpool->deallocate(ptr, bytes);
    }

    /// @brief Check if two resources are the same object.
    [[nodiscard]]
    bool do_is_equal(const memory_resource& other) const noexcept override {
        return this == &other;
    }
private:
    bitpool* m_bitpool;
};

