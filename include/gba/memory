/**
 * @file memory
 * @brief GBA memory management utilities.
 *
 * This header provides memory management utilities optimized for GBA,
 * including a unique pointer type and a bitmap-based memory pool allocator.
 *
 * Example:
 * @code{.cpp}
 * // Create a bitpool over object VRAM (32KB with 1KB chunks)
 * gba::bitpool vram_pool{gba::memory_map(gba::mem_vram_obj), 1024};
 * auto tiles = vram_pool.allocate_unique<char>(2048); // Allocate 2KB for sprite tiles
 * @endcode
 */
#pragma once

#include <gba/bits/handler.hpp>

#include <bit>
#include <cstddef>
#include <cstdint>
#include <functional>
#include <limits>
#include <memory_resource>
#include <type_traits>
#include <utility>

namespace gba {

/**
 * @brief Trivially copyable tuple type for register-compatible data.
 *
 * A fixed-size heterogeneous container that is guaranteed to be trivially copyable
 * and fit within 32 bits. Unlike std::tuple, plex can be safely bit-casted to an
 * integer for hardware register writes.
 *
 * Supports 1 to 4 elements. Use structured bindings or get<I>() for element access.
 *
 * @tparam Ts The member types. Total size must be <= 4 bytes.
 *
 * Example:
 * @code{.cpp}
 * // 2-element plex (like std::pair)
 * gba::plex<unsigned short, unsigned short> p{0x1234, 0x5678};
 * auto [a, b] = p; // Structured bindings
 *
 * // 4-element plex (four bytes)
 * gba::plex<char, char, char, char> rgba{255, 128, 64, 255};
 * auto r = gba::get<0>(rgba);
 * @endcode
 */
template<typename... Ts>
struct plex;

/**
 * @brief Single-element plex specialization.
 *
 * @tparam T1 The element type. Must fit in 32 bits.
 */
template<typename T1>
struct plex<T1> {
    static_assert(sizeof(T1) <= sizeof(unsigned int), "plex must fit in 32 bits");

    using value_type = T1;  ///< Type of the single member.

    T1 first;  ///< The single member.

    /// @brief Default constructor.
    constexpr plex() = default;

    /// @brief Copy constructor.
    constexpr plex(const plex&) = default;

    /// @brief Move constructor.
    constexpr plex(plex&&) = default;

    /// @brief Construct from value.
    /// @param x The value.
    constexpr plex(const T1& x) : first{x} {}

    /// @brief Construct from convertible value.
    /// @tparam U1 Type convertible to T1.
    /// @param x The value.
    template<typename U1>
    constexpr plex(U1&& x) : first{std::forward<U1>(x)} {} // NOLINT(*-forwarding-reference-overload)

    /// @brief Construct from another plex type.
    /// @tparam U1 Element type of source plex.
    /// @param p Source plex.
    template<typename U1>
    constexpr plex(const plex<U1>& p) : first{p.first} {}

    /// @brief Copy assignment.
    constexpr plex& operator=(const plex&) = default;

    /// @brief Move assignment.
    constexpr plex& operator=(plex&&) = default;

    /// @brief Assign from another plex type.
    /// @tparam U1 Element type of source plex.
    /// @param p Source plex.
    template<typename U1>
    constexpr plex& operator=(const plex<U1>& p) {
        first = p.first;
        return *this;
    }

    /// @brief Swap contents with another plex.
    /// @param other The plex to swap with.
    constexpr void swap(plex& other) noexcept {
        using std::swap;
        swap(first, other.first);
    }

    /// @brief Equality comparison.
    [[nodiscard]]
    constexpr bool operator==(const plex&) const = default;

    /// @brief Three-way comparison.
    [[nodiscard]]
    constexpr auto operator<=>(const plex&) const = default;
};

/**
 * @brief Two-element plex specialization (std::pair compatible).
 *
 * Provides first/second member names and constructors compatible with std::pair.
 *
 * @tparam T1 First element type.
 * @tparam T2 Second element type.
 *
 * Example:
 * @code{.cpp}
 * gba::plex<unsigned short, gba::timer_control> config{0xFFFF, {.enabled = true}};
 * auto [reload, ctrl] = config;
 * @endcode
 */
template<typename T1, typename T2>
struct plex<T1, T2> {
    static_assert(sizeof(T1) + sizeof(T2) <= sizeof(unsigned int), "plex must fit in 32 bits");

    using first_type = T1;   ///< Type of the first member.
    using second_type = T2;  ///< Type of the second member.

    T1 first;   ///< The first member.
    T2 second;  ///< The second member.

    /// @brief Default constructor.
    constexpr plex() = default;

    /// @brief Copy constructor.
    constexpr plex(const plex&) = default;

    /// @brief Move constructor.
    constexpr plex(plex&&) = default;

    /// @brief Construct from values.
    constexpr plex(const T1& x, const T2& y) : first{x}, second{y} {}

    /// @brief Construct from convertible values.
    template<typename U1, typename U2>
    constexpr plex(U1&& x, U2&& y) : first{std::forward<U1>(x)}, second{std::forward<U2>(y)} {}

    /// @brief Construct from another plex type.
    template<typename U1, typename U2>
    constexpr plex(const plex<U1, U2>& p) : first{p.first}, second{p.second} {}

    /// @brief Construct from std::pair.
    template<typename U1, typename U2>
    constexpr plex(const std::pair<U1, U2>& p) : first{p.first}, second{p.second} {}

    /// @brief Move construct from another plex type.
    template<typename U1, typename U2>
    constexpr plex(plex<U1, U2>&& p) : first{std::forward<U1>(p.first)}, second{std::forward<U2>(p.second)} {}

    /// @brief Copy assignment.
    constexpr plex& operator=(const plex&) = default;

    /// @brief Move assignment.
    constexpr plex& operator=(plex&&) = default;

    /// @brief Assign from another plex type.
    template<typename U1, typename U2>
    constexpr plex& operator=(const plex<U1, U2>& p) {
        first = p.first;
        second = p.second;
        return *this;
    }

    /// @brief Assign from std::pair.
    template<typename U1, typename U2>
    constexpr plex& operator=(const std::pair<U1, U2>& p) {
        first = p.first;
        second = p.second;
        return *this;
    }


    /// @brief Swap contents with another plex.
    constexpr void swap(plex& other) noexcept {
        using std::swap;
        swap(first, other.first);
        swap(second, other.second);
    }

    /// @brief Equality comparison.
    [[nodiscard]]
    constexpr bool operator==(const plex&) const = default;

    /// @brief Three-way comparison.
    [[nodiscard]]
    constexpr auto operator<=>(const plex&) const = default;
};

/**
 * @brief Three-element plex specialization.
 *
 * @tparam T1 First element type.
 * @tparam T2 Second element type.
 * @tparam T3 Third element type.
 *
 * Example:
 * @code{.cpp}
 * gba::plex<char, char, short> p{1, 2, 300};
 * auto [a, b, c] = p;
 * @endcode
 */
template<typename T1, typename T2, typename T3>
struct plex<T1, T2, T3> {
    static_assert(sizeof(T1) + sizeof(T2) + sizeof(T3) <= sizeof(unsigned int), "plex must fit in 32 bits");

    T1 first;   ///< The first member.
    T2 second;  ///< The second member.
    T3 third;   ///< The third member.

    /// @brief Default constructor.
    constexpr plex() = default;

    /// @brief Copy constructor.
    constexpr plex(const plex&) = default;

    /// @brief Move constructor.
    constexpr plex(plex&&) = default;

    /// @brief Construct from values.
    /// @param x First value.
    /// @param y Second value.
    /// @param z Third value.
    constexpr plex(const T1& x, const T2& y, const T3& z) : first{x}, second{y}, third{z} {}

    /// @brief Construct from convertible values.
    template<typename U1, typename U2, typename U3>
    constexpr plex(U1&& x, U2&& y, U3&& z) : first{std::forward<U1>(x)}, second{std::forward<U2>(y)}, third{std::forward<U3>(z)} {}

    /// @brief Copy assignment.
    constexpr plex& operator=(const plex&) = default;

    /// @brief Move assignment.
    constexpr plex& operator=(plex&&) = default;

    /// @brief Swap contents with another plex.
    /// @param other The plex to swap with.
    constexpr void swap(plex& other) noexcept {
        using std::swap;
        swap(first, other.first);
        swap(second, other.second);
        swap(third, other.third);
    }

    /// @brief Equality comparison.
    [[nodiscard]]
    constexpr bool operator==(const plex&) const = default;

    /// @brief Three-way comparison.
    [[nodiscard]]
    constexpr auto operator<=>(const plex&) const = default;
};

/**
 * @brief Four-element plex specialization.
 *
 * @tparam T1 First element type.
 * @tparam T2 Second element type.
 * @tparam T3 Third element type.
 * @tparam T4 Fourth element type.
 *
 * Example:
 * @code{.cpp}
 * gba::plex<char, char, char, char> rgba{255, 128, 64, 255};
 * auto [r, g, b, a] = rgba;
 * @endcode
 */
template<typename T1, typename T2, typename T3, typename T4>
struct plex<T1, T2, T3, T4> {
    static_assert(sizeof(T1) + sizeof(T2) + sizeof(T3) + sizeof(T4) <= sizeof(unsigned int), "plex must fit in 32 bits");

    T1 first;   ///< The first member.
    T2 second;  ///< The second member.
    T3 third;   ///< The third member.
    T4 fourth;  ///< The fourth member.

    /// @brief Default constructor.
    constexpr plex() = default;

    /// @brief Copy constructor.
    constexpr plex(const plex&) = default;

    /// @brief Move constructor.
    constexpr plex(plex&&) = default;

    /// @brief Construct from values.
    /// @param a First value.
    /// @param b Second value.
    /// @param c Third value.
    /// @param d Fourth value.
    constexpr plex(const T1& a, const T2& b, const T3& c, const T4& d) : first{a}, second{b}, third{c}, fourth{d} {}

    /// @brief Construct from convertible values.
    template<typename U1, typename U2, typename U3, typename U4>
    constexpr plex(U1&& a, U2&& b, U3&& c, U4&& d) : first{std::forward<U1>(a)}, second{std::forward<U2>(b)}, third{std::forward<U3>(c)}, fourth{std::forward<U4>(d)} {}

    /// @brief Copy assignment.
    constexpr plex& operator=(const plex&) = default;

    /// @brief Move assignment.
    constexpr plex& operator=(plex&&) = default;

    /// @brief Swap contents with another plex.
    /// @param other The plex to swap with.
    constexpr void swap(plex& other) noexcept {
        using std::swap;
        swap(first, other.first);
        swap(second, other.second);
        swap(third, other.third);
        swap(fourth, other.fourth);
    }

    /// @brief Equality comparison.
    [[nodiscard]]
    constexpr bool operator==(const plex&) const = default;

    /// @brief Three-way comparison.
    [[nodiscard]]
    constexpr auto operator<=>(const plex&) const = default;
};

/// @brief Deduction guide for 1-element plex.
template<typename T1>
plex(T1) -> plex<T1>;

/// @brief Deduction guide for 2-element plex.
template<typename T1, typename T2>
plex(T1, T2) -> plex<T1, T2>;

/// @brief Deduction guide for 3-element plex.
template<typename T1, typename T2, typename T3>
plex(T1, T2, T3) -> plex<T1, T2, T3>;

/// @brief Deduction guide for 4-element plex.
template<typename T1, typename T2, typename T3, typename T4>
plex(T1, T2, T3, T4) -> plex<T1, T2, T3, T4>;

/// @brief Create a 1-element plex.
/// @tparam T1 The element type.
/// @param x The value.
/// @return A plex containing the value.
template<typename T1>
[[nodiscard]]
constexpr plex<std::decay_t<T1>> make_plex(T1&& x) {
    return {std::forward<T1>(x)};
}

/// @brief Create a 2-element plex.
/// @tparam T1 First element type.
/// @tparam T2 Second element type.
/// @param x First value.
/// @param y Second value.
/// @return A plex containing the values.
template<typename T1, typename T2>
[[nodiscard]]
constexpr plex<std::decay_t<T1>, std::decay_t<T2>> make_plex(T1&& x, T2&& y) {
    return {std::forward<T1>(x), std::forward<T2>(y)};
}

/// @brief Create a 3-element plex.
/// @tparam T1 First element type.
/// @tparam T2 Second element type.
/// @tparam T3 Third element type.
/// @param x First value.
/// @param y Second value.
/// @param z Third value.
/// @return A plex containing the values.
template<typename T1, typename T2, typename T3>
[[nodiscard]]
constexpr plex<std::decay_t<T1>, std::decay_t<T2>, std::decay_t<T3>> make_plex(T1&& x, T2&& y, T3&& z) {
    return {std::forward<T1>(x), std::forward<T2>(y), std::forward<T3>(z)};
}

/// @brief Create a 4-element plex.
/// @tparam T1 First element type.
/// @tparam T2 Second element type.
/// @tparam T3 Third element type.
/// @tparam T4 Fourth element type.
/// @param a First value.
/// @param b Second value.
/// @param c Third value.
/// @param d Fourth value.
/// @return A plex containing the values.
template<typename T1, typename T2, typename T3, typename T4>
[[nodiscard]]
constexpr plex<std::decay_t<T1>, std::decay_t<T2>, std::decay_t<T3>, std::decay_t<T4>> make_plex(T1&& a, T2&& b, T3&& c, T4&& d) {
    return {std::forward<T1>(a), std::forward<T2>(b), std::forward<T3>(c), std::forward<T4>(d)};
}

/// @brief Get element by index from 1-element plex.
/// @tparam I Index (must be 0).
/// @tparam T1 Element type.
/// @param p The plex.
/// @return Reference to the element.
template<std::size_t I, typename T1>
[[nodiscard]]
constexpr auto& get(plex<T1>& p) noexcept {
    static_assert(I < 1, "Index out of bounds");
    return p.first;
}

/// @copydoc get(plex<T1>&)
template<std::size_t I, typename T1>
[[nodiscard]]
constexpr const auto& get(const plex<T1>& p) noexcept {
    static_assert(I < 1, "Index out of bounds");
    return p.first;
}

/// @copydoc get(plex<T1>&)
template<std::size_t I, typename T1>
[[nodiscard]]
constexpr auto&& get(plex<T1>&& p) noexcept {
    static_assert(I < 1, "Index out of bounds");
    return std::move(p.first);
}

/// @brief Get element by index from 2-element plex.
/// @tparam I Index (0 or 1).
/// @tparam T1 First element type.
/// @tparam T2 Second element type.
/// @param p The plex.
/// @return Reference to the element.
template<std::size_t I, typename T1, typename T2>
[[nodiscard]]
constexpr auto& get(plex<T1, T2>& p) noexcept {
    static_assert(I < 2, "Index out of bounds");
    if constexpr (I == 0) return p.first;
    else return p.second;
}

/// @copydoc get(plex<T1,T2>&)
template<std::size_t I, typename T1, typename T2>
[[nodiscard]]
constexpr const auto& get(const plex<T1, T2>& p) noexcept {
