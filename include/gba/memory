#pragma once

#include <gba/bits/handler.hpp>

#include <cstddef>
#include <cstdint>
#include <functional>
#include <limits>
#include <memory_resource>

namespace gba {

template<typename T>
struct unique {
    constexpr unique() noexcept : m_ptr{nullptr}, m_deleter{[](const T*) constexpr static {}} {}
    constexpr unique(std::nullptr_t) noexcept : m_ptr{nullptr}, m_deleter{[](const T*) constexpr static {}} {}

    template<typename Deleter>
    constexpr unique(T* ptr, Deleter&& deleter) noexcept : m_ptr{ptr}, m_deleter{std::forward<Deleter>(deleter)} {}

    constexpr ~unique() {
        reset();
    }

    unique(const unique&) = delete;
    unique& operator=(const unique&) = delete;

    constexpr unique(unique&& other) noexcept : m_ptr{other.m_ptr}, m_deleter{std::move(other.m_deleter)} {
        other.m_ptr = nullptr;
    }

    constexpr unique& operator=(unique&& other) noexcept {
        if (this != &other) {
            reset();
            m_ptr = other.m_ptr;
            m_deleter = std::move(other.m_deleter);
            other.m_ptr = nullptr;
        }
        return *this;
    }

    constexpr void reset() noexcept {
        if (m_ptr) {
            std::invoke(m_deleter, m_ptr);
            m_ptr = nullptr;
        }
    }

    constexpr T* get() const noexcept { return m_ptr; }
    constexpr T* operator->() const noexcept { return m_ptr; }
    constexpr T& operator*() const noexcept { return *m_ptr; }
    constexpr explicit operator bool() const noexcept { return m_ptr != nullptr; }
private:
    T* m_ptr;
    bits::handler<const T*> m_deleter;
};

template<typename T, typename... Args>
constexpr unique<T> make_unique(Args&&... args) {
    return {new T{std::forward<Args>(args)...}, [](const T* ptr) constexpr static { delete ptr; }};
}

struct bitpool {
    constexpr explicit bitpool(void* base, const std::size_t chunkSize) noexcept : m_base{reinterpret_cast<std::uintptr_t>(base)}, m_chunkSize{chunkSize}, m_bitmask{} {}

    static constexpr std::size_t capacity() noexcept { return std::numeric_limits<std::uint32_t>::digits; }

    [[nodiscard]]
    constexpr std::size_t chunk_size() const noexcept { return m_chunkSize; }

    [[nodiscard]]
    constexpr std::size_t size() const noexcept { return capacity() * chunk_size(); }

    constexpr void* allocate(const std::size_t bytes) noexcept {
        const std::size_t chunkLen = (bytes + (chunk_size() - 1)) / chunk_size();

        std::size_t chunkMask = (1 << chunkLen) - 1;
        std::uintptr_t chunkStart = 0;
        while (chunkStart < capacity()) {
            if ((m_bitmask & chunkMask) == 0) {
                m_bitmask |= chunkMask;
                return reinterpret_cast<void*>(m_base + (chunk_size() * chunkStart));
            }
            chunkMask <<= 1;
            chunkStart += 1;
        }

        return nullptr;
    }

    constexpr void* allocate(const std::size_t bytes, const std::size_t chunkAlignment) noexcept {
        const std::size_t chunkLen = (bytes + (chunk_size() - 1)) / chunk_size();
        const std::size_t chunkStep = (chunkAlignment + (chunk_size() - 1)) / chunk_size();

        std::size_t chunkMask = (1 << chunkLen) - 1;
        std::uintptr_t chunkStart = 0;
        while (chunkStart < capacity()) {
            if ((m_bitmask & chunkMask) == 0) {
                m_bitmask |= chunkMask;
                return reinterpret_cast<void*>(m_base + (chunk_size() * chunkStart));
            }
            chunkMask <<= chunkStep;
            chunkStart += chunkStep;
        }

        return nullptr;
    }

    constexpr void deallocate(const void* ptr, const std::size_t bytes) noexcept {
        const std::size_t chunkLen = (bytes + (chunk_size() - 1)) / chunk_size();
        const std::size_t chunkMask = (1 << chunkLen) - 1;

        const std::uintptr_t chunkStart = (reinterpret_cast<std::uintptr_t>(ptr) - m_base) / chunk_size();
        m_bitmask &= ~(chunkMask << chunkStart);
    }

    template<typename T>
    constexpr unique<T> make_unique(const std::size_t bytes, const std::size_t chunkAlignment = alignof(T)) noexcept {
        void* ptr = allocate(bytes, chunkAlignment);
        if (!ptr) {
            return nullptr;
        }

        return {static_cast<T*>(ptr), [this, bytes](const T* p) constexpr {
            deallocate(p, bytes);
        }};
    }

    constexpr unique<bitpool> subpool(const std::size_t bytes, const std::size_t chunkAlignment = 1) noexcept {
        const std::size_t chunkBytes = ((bytes + (chunk_size() - 1)) / chunk_size()) * chunk_size();

        void* ptr = allocate(chunkBytes, chunkAlignment);
        if (!ptr) {
            return nullptr;
        }

        auto* sub = new bitpool{ptr, chunkBytes / 32};
        return {sub, [this, chunkBytes](const bitpool* p) constexpr {
            deallocate(p, chunkBytes);
            delete p;
        }};
    }
private:
    std::uintptr_t m_base;
    std::size_t m_chunkSize;
    std::uint32_t m_bitmask;
};

struct bitpool_buffer_resource : std::pmr::memory_resource {
    constexpr explicit bitpool_buffer_resource(bitpool& parent) noexcept : m_bitpool{&parent} {}
protected:
    void* do_allocate(const std::size_t bytes, const std::size_t alignment) override {
        return m_bitpool->allocate(bytes, alignment);
    }

    void do_deallocate(void* ptr, const std::size_t bytes, std::size_t) override {
        m_bitpool->deallocate(ptr, bytes);
    }

    [[nodiscard]]
    bool do_is_equal(const memory_resource& other) const noexcept override {
        return this == &other;
    }
private:
    bitpool* m_bitpool;
};

}
